Cell["Its arc-length can be compute by ", "Text",
 CellChangeTimes->{{3.759682979311018*^9, 
  3.759682993975265*^9}},ExpressionUUID->"84d7e350-4921-490b-bfdd-\
6aef87b5d37d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "0", 
   RowBox[{"2", "\[Pi]"}]], 
  RowBox[{
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], ")"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], ")"}], "2"]}]], 
   RowBox[{"\[DifferentialD]", "t"}]}]}]], "Input",
 CellChangeTimes->{{3.759683003005073*^9, 
  3.7596830356851053`*^9}},ExpressionUUID->"64d5dd3f-2152-43b2-8348-\
36d360b0da26"],

Cell[BoxData["$Aborted"], "Output",
 CellChangeTimes->{
  3.759683092876772*^9},ExpressionUUID->"c8efd10f-e96a-46f6-9ae1-\
33a46e91008e"]
}, Open  ]],

Cell["No go with that, so we try it numerically.", "Text",
 CellChangeTimes->{{3.759683083963571*^9, 
  3.759683106649795*^9}},ExpressionUUID->"70a0129a-6b6f-4dbd-9015-\
03ff39c3e8c0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NIntegrate", "[", 
  RowBox[{
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], ")"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], ")"}], "2"]}]], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.759683056610736*^9, 
  3.7596830782034683`*^9}},ExpressionUUID->"83a29bd5-4a0f-4ef2-bb89-\
c0b8bc8abede"],

Cell[BoxData["11.972996476397716`"], "Output",
 CellChangeTimes->{
  3.759683095081161*^9},ExpressionUUID->"30935a78-ccf7-4e2f-bbba-\
25c26b804246"]
}, Open  ]],

Cell["Now we move this curve into 3 dimensions.", "Text",
 CellChangeTimes->{{3.759683134097465*^9, 
  3.759683145912575*^9}},ExpressionUUID->"105baa7e-ce6d-440d-9432-\
654fdbb5e96e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"x", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Cos", "[", "t", "]"}], " ", 
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"Cos", "[", "t", "]"}], "-", 
      RowBox[{
       FractionBox["1", "6"], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "t"}], "]"}]}]}], ")"}]}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"y", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Sin", "[", "t", "]"}], " ", 
    RowBox[{"(", 
     RowBox[{"1.5", "-", 
      RowBox[{"Sin", "[", "t", "]"}], "+", 
      RowBox[{
       FractionBox["1", "8"], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"3", " ", "t"}], "]"}]}]}], ")"}]}]}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"z", "[", "t_", "]"}], ":=", 
   RowBox[{"Sin", "[", 
    RowBox[{"3", "t"}], "]"}]}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Rplot", "=", 
  RowBox[{"ParametricPlot3D", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}], ",", 
      RowBox[{"z", "[", "t", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", 
      RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", "\n", "\t\t", 
    RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Thickness", "[", "0.01", "]"}]}], "}"}], "}"}]}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{
  3.759682897643175*^9, {3.759683174777034*^9, 3.7596832609658213`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"5432d271-25f0-4ad4-accc-dd2121d183c2"],

