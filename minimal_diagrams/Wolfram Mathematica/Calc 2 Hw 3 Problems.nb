Cell[CellGroupData[{
Cell[TextData[{
 "Math 137 Sp 19 \t",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " Hw 3     Integration, Volumes and Arclength.\tErnst"
}], "Section",
 CellChangeTimes->{{3.586700405253828*^9, 3.586700436749889*^9}, 
   3.586876005098486*^9, {3.5868832585707006`*^9, 3.58688325929895*^9}, {
   3.587899490250379*^9, 3.58789949557388*^9}, 3.588078378190113*^9, {
   3.599957668826419*^9, 3.599957687523932*^9}, {3.600525084181932*^9, 
   3.600525092712934*^9}, {3.6005260849682302`*^9, 3.6005260938611097`*^9}, 
   3.632139728242982*^9, 3.727095848957075*^9, 3.758376749720854*^9, {
   3.759682642858117*^9, 3.759682649156199*^9}, {3.7597561022710247`*^9, 
   3.759756111692737*^9}},ExpressionUUID->"8df01a85-fd1e-4190-9917-\
cafa239aec3f"],

Cell[TextData[{
 "Form groups of two. Each member of the group must understand and be able to \
explain (in detail) all of the homework turned in. We allow you to work in \
groups so that you have someone with whom you can talk about your work in \
detail. This is ",
 StyleBox["not ",
  FontWeight->"Bold"],
 "meant for group members to only do half of the work. "
}], "Text",
 CellChangeTimes->{{3.5867002280443563`*^9, 3.586700259274942*^9}, {
  3.7270959837863617`*^9, 3.7270960069840612`*^9}, {3.759756096389081*^9, 
  3.759756096973301*^9}},ExpressionUUID->"569c40cc-e319-42bd-b0ad-\
6d3216246c6b"],

Cell[TextData[StyleBox["Due: Friday, March 15  ",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.586700310541088*^9, 3.5867003400757313`*^9}, 
   3.5867342805118723`*^9, {3.586876008167721*^9, 3.586876008662834*^9}, {
   3.5880283141008663`*^9, 3.5880283142966843`*^9}, {3.599957833868779*^9, 
   3.599957842021747*^9}, {3.600534108636919*^9, 3.600534108833461*^9}, 
   3.6321397627776823`*^9, 3.727095879624824*^9, 3.758376769755246*^9, {
   3.759756069224613*^9, 
   3.759756071333918*^9}},ExpressionUUID->"5a686de5-ac2c-4a79-bc4e-\
f8c4878a4d87"],

Cell[CellGroupData[{

Cell["An example of problem 1", "Subsubsection",
 CellChangeTimes->{{3.7294357198730383`*^9, 
  3.7294357259198914`*^9}},ExpressionUUID->"6889eb90-55e7-4318-939c-\
6cd52f7ea9f4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Integral]", 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    SuperscriptBox["x", "2"]], 
   RowBox[{"\[DifferentialD]", "x"}]}]}]], "Input",
 CellChangeTimes->{{3.635775901395378*^9, 
  3.6357759072729597`*^9}},ExpressionUUID->"d65b7dcc-460c-474d-849b-\
312e35c0d255"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  SqrtBox["\[Pi]"], " ", 
  RowBox[{"Erfi", "[", "x", "]"}]}]], "Output",
 CellChangeTimes->{
  3.635775908175785*^9},ExpressionUUID->"e1c049c5-9cea-4083-b644-\
776b6a441e9e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "Erfi"}]], "Input",
 CellChangeTimes->{{3.635775914312498*^9, 
  3.635775921639895*^9}},ExpressionUUID->"4d9e9cc2-5800-4551-8124-\
e9cec33c3c4c"],

Cell[BoxData[
 RowBox[{
  StyleBox["\<\"\\!\\(\\*RowBox[{\\\"Erfi\\\", \\\"[\\\", StyleBox[\\\"z\\\", \
\\\"TI\\\"], \\\"]\\\"}]\\) gives the imaginary error function \
\\!\\(\\*RowBox[{RowBox[{\\\"erf\\\", \\\"(\\\", RowBox[{StyleBox[\\\"i\\\", \
\\\"TI\\\"], \\\"\[InvisibleSpace]\\\", StyleBox[\\\"z\\\", \\\"TI\\\"]}], \\\
\")\\\"}], \\\"/\\\", StyleBox[\\\"i\\\", \\\"TI\\\"]}]\\). \"\>", "MSG"], 
  "\[NonBreakingSpace]", 
  ButtonBox[
   StyleBox["\[RightSkeleton]", "SR"],
   Active->True,
   BaseStyle->"Link",
   ButtonData->"paclet:ref/Erfi"]}]], "Print", "PrintUsage",
 CellChangeTimes->{3.6357759228181763`*^9},
 CellTags->
  "Info3635757922-6515863",ExpressionUUID->"edb2ffe3-9f64-4b3a-a30b-\
c83ad4c7bd75"]
}, {1, 2}]],

Cell["Form the documentation center", "Text",
 CellChangeTimes->{{3.6357762802656116`*^9, 
  3.63577628788866*^9}},ExpressionUUID->"e9164bcd-34bd-4ce1-be6d-\
71fbf947ee51"],

Cell[TextData[{
 "The ",
 StyleBox["imaginary error function",
  FontSlant->"Italic"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"erfi", "(", "z", ")"}], "\[LongEqual]", 
    RowBox[{
     RowBox[{"erf", "(", 
      RowBox[{"i", "\[InvisibleSpace]", "z"}], ")"}], "/", "i"}]}], 
   TraditionalForm]], "InlineMath",ExpressionUUID->
  "42747f3d-7376-48f5-bbdc-9a8205e4ca77"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"erf", "(", "z", ")"}], "\[LongEqual]", 
    RowBox[{
     RowBox[{"2", "/", 
      SqrtBox["\[Pi]"]}], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "z"], 
      RowBox[{
       SuperscriptBox["e", 
        RowBox[{"-", 
         SuperscriptBox["t", "2"]}]], "d", "t"}]}]}]}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"d33da93d-046b-4ee5-82d7-edc58385e59a"]
}], "Text",
 CellChangeTimes->{{3.635776086595091*^9, 
  3.635776116802391*^9}},ExpressionUUID->"a5027aa3-f346-4b44-a26e-\
4ecd197e5950"],

Cell["\<\
At http://www.mathworks.com/help/symbolic/mupad_ref/erfi.html\
\>", "Text",
 CellChangeTimes->{{3.635776291047924*^9, 
  3.635776302837141*^9}},ExpressionUUID->"d3553dea-82a5-46a8-9093-\
9d4e14595810"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"erfi", 
     RowBox[{"(", "x", ")"}]}], "=", 
    RowBox[{
     FractionBox["2", 
      SqrtBox["\[Pi]"]], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "x"], 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        SuperscriptBox["t", "2"]], 
       RowBox[{"\[DifferentialD]", "t"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"fdb0ea28-c725-4be2-ad87-0ba0606286b1"],
 "    ",
 "computes the imaginary error function."
}], "Text",
 CellChangeTimes->{{3.6357763393753843`*^9, 
  3.6357764063909397`*^9}},ExpressionUUID->"b7144435-0bc3-4995-88b8-\
518d834c68ed"]
}, Closed]],

Cell[CellGroupData[{

Cell["ArcLength - a more general formula using parametric plots", \
"Subsubsection",
 CellChangeTimes->{{3.7596829309138603`*^9, 3.759682933336898*^9}, {
  3.759683343392845*^9, 
  3.759683355136034*^9}},ExpressionUUID->"948dc8af-7b1b-4cdc-a0be-\
7edccd4dfd7e"],

Cell[TextData[{
 "Here's a strange region ",
 Cell[BoxData["R"],ExpressionUUID->"9e858e1c-142c-41ca-9029-736079c9b642"],
 " plotted in the ",
 Cell[BoxData["xy"],ExpressionUUID->"955037ee-e8e9-4ae3-806e-cd86f7bda5cb"],
 "-plane."
}], "Text",
 CellChangeTimes->{{3.7596829483842087`*^9, 
  3.759682954983917*^9}},ExpressionUUID->"e18d9231-eec5-497a-8475-\
eb8792d22042"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "y", ",", "t"}], "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"x", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Cos", "[", "t", "]"}], " ", 
    RowBox[{"(", 
     RowBox[{"2", "+", 
      RowBox[{"Cos", "[", "t", "]"}], "-", 
      RowBox[{
       FractionBox["1", "6"], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "t"}], "]"}]}]}], ")"}]}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"y", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Sin", "[", "t", "]"}], " ", 
    RowBox[{"(", 
     RowBox[{"1.5", "-", 
      RowBox[{"Sin", "[", "t", "]"}], "+", 
      RowBox[{
       FractionBox["1", "8"], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"3", " ", "t"}], "]"}]}]}], ")"}]}]}], "\n"}], "\n", 
 RowBox[{"Rplot", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", 
      RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", "\n", "\t\t", 
    RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Thickness", "[", "0.01", "]"}]}], "}"}], "}"}]}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{
  3.759682897643175*^9, {3.759683153112926*^9, 3.759683180520529*^9}, {
   3.759683246342963*^9, 3.759683246853014*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"ef887c3c-3cd2-4152-a9fd-9ccdff283bd1"],

