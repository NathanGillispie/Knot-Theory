Cell["Its arc-length can be compute by ", "Text",
 CellChangeTimes->{{3.759682979311018*^9, 
  3.759682993975265*^9}},ExpressionUUID->"ee673ae2-9a00-4382-ad5c-\
1d2efaa42fc0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "0", 
   RowBox[{"2", "\[Pi]"}]], 
  RowBox[{
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], ")"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], ")"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"z", "'"}], "[", "t", "]"}], ")"}], "2"]}]], 
   RowBox[{"\[DifferentialD]", "t"}]}]}]], "Input",
 CellChangeTimes->{{3.759683003005073*^9, 3.7596830356851053`*^9}, {
  3.759683299148946*^9, 
  3.7596833022504663`*^9}},ExpressionUUID->"daf1118c-f9aa-466b-8a39-\
f27d7e1173b1"],

Cell[BoxData["$Aborted"], "Output",
 CellChangeTimes->{3.759683092876772*^9, 
  3.759683308218286*^9},ExpressionUUID->"f4ab3402-3b30-403f-a2f0-\
7eb41542a1b3"]
}, Open  ]],

Cell["No go with that, so we try it numerically.", "Text",
 CellChangeTimes->{{3.759683083963571*^9, 
  3.759683106649795*^9}},ExpressionUUID->"807cb98f-408e-4a4d-b38a-\
0fded50677c4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NIntegrate", "[", 
  RowBox[{
   SqrtBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "'"}], "[", "t", "]"}], ")"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"y", "'"}], "[", "t", "]"}], ")"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"z", "'"}], "[", "t", "]"}], ")"}], "2"]}]], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.759683056610736*^9, 3.7596830782034683`*^9}, {
  3.759683312843261*^9, 
  3.7596833167697268`*^9}},ExpressionUUID->"609562cb-a3d8-4232-af31-\
a6cc621c5f2a"],

Cell[BoxData["17.823280310446908`"], "Output",
 CellChangeTimes->{3.759683095081161*^9, 
  3.7596833175635242`*^9},ExpressionUUID->"0071154b-80b8-4443-9e7f-\
3eb808e73f78"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Homework", "Subsection",
 CellChangeTimes->{{3.759683591471655*^9, 
  3.7596835955745373`*^9}},ExpressionUUID->"00a4ffbf-d9c5-4554-a0f3-\
f880b5c0e3ef"],

Cell[CellGroupData[{

Cell["Problem 1 Integration yields special functions", "Subsubsection",
 CellChangeTimes->{{3.604604638998808*^9, 3.604604640092885*^9}, {
   3.604605567669958*^9, 3.6046055702525997`*^9}, {3.635775540527629*^9, 
   3.635775545614521*^9}, 3.729435679587015*^9, {3.729435946591157*^9, 
   3.7294359569006863`*^9}},ExpressionUUID->"25093ad7-bab1-4ea5-b6d4-\
972e40e174ad"],

Cell[TextData[{
 "We all know that integration is \[OpenCurlyDoubleQuote]difficult\
\[CloseCurlyDoubleQuote]. ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " uses a number of tricks to still give answers to difficult functions. In \
this exercise we test ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 "\[CloseCurlyQuote]s integration skills."
}], "Text",
 CellChangeTimes->{{3.60460465421382*^9, 3.6046047797856503`*^9}, {
   3.6046052054651012`*^9, 3.6046054149911547`*^9}, {3.60460545593708*^9, 
   3.604605544907737*^9}, {3.604605595573655*^9, 3.604605596293392*^9}, {
   3.604662182669935*^9, 3.6046621832789354`*^9}, {3.63577555025478*^9, 
   3.635775772110379*^9}, 
   3.729435872394121*^9},ExpressionUUID->"7262009e-a6b9-4a6c-9afc-\
8cde1b5c61ec"],

Cell[TextData[{
 "(i) Find five different functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"f", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "4e13540b-2107-434b-8858-0d0d6e5fbb15"],
 " where ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " returns the integral ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Integral]", 
    RowBox[{
     RowBox[{"f", "(", "x", ")"}], 
     RowBox[{"\[DifferentialD]", "x"}]}]}], TraditionalForm]],ExpressionUUID->
  "39ee27d7-04c2-4a48-bb40-27353ee2826d"],
 " unchanged. Not different means that you should ",
 StyleBox["not",
  FontWeight->"Bold"],
 " use the same function and make simple changes such as multiply it by a \
constant or add a \[OpenCurlyDoubleQuote]trivial term to it\
\[CloseCurlyDoubleQuote]."
}], "Text",
 CellChangeTimes->{3.6357757742544518`*^9, 
  3.7294358763168287`*^9},ExpressionUUID->"077563b3-1243-4e97-bf84-\
94851590f49c"],

Cell[TextData[{
 "(ii) Find five different functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"f", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "6cc8d5b5-b4a6-4d3c-8510-5248a8dfd775"],
 " where ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " returns the integral ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Integral]", 
    RowBox[{
     RowBox[{"f", "(", "x", ")"}], 
     RowBox[{"\[DifferentialD]", "x"}]}]}], TraditionalForm]],ExpressionUUID->
  "89cfb288-f8d3-4778-af30-8a0de6eb3662"],
 " by using a \[OpenCurlyDoubleQuote]special \
function\[CloseCurlyDoubleQuote], which is defined as an integral. Here the \
five functions should have answers involving five different special \
functions. \n\nFor each function \nFind the definition of the function (as an \
integral). \n(You can do this by looking at the documentation center. This \
may take some time to find it so you can also google this if you like.)"
}], "Text",
 CellChangeTimes->{{3.635775776631218*^9, 3.635775891104768*^9}, {
  3.635775936807584*^9, 3.635775973837429*^9}, {3.635776126127837*^9, 
  3.635776143398638*^9}, {3.635776187804933*^9, 3.6357762189476023`*^9}, {
  3.729435899635559*^9, 3.729435921422575*^9}, {3.7596826994193068`*^9, 
  3.759682700802334*^9}},ExpressionUUID->"3d6ece62-201c-4811-82d3-\
e1e35e09eea5"]
}, Closed]],

Cell[CellGroupData[{

Cell["Problem I1 Knotted curves", "Subsubsection",
 CellChangeTimes->{{3.604604638998808*^9, 3.604604640092885*^9}, {
   3.604605567669958*^9, 3.6046055702525997`*^9}, {3.635775540527629*^9, 
   3.635775545614521*^9}, 3.729435679587015*^9, {3.729435946591157*^9, 
   3.7294359569006863`*^9}, {3.75968368571597*^9, 
   3.759683693346739*^9}},ExpressionUUID->"67834ee8-7a69-47a7-b6bc-\
8c4ae0c215fa"],

Cell[TextData[{
 "Given a two parameter family of knotted curves in three space. Assume that \
p and q are positive integers with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", ">", "q", "\[GreaterEqual]", "2"}], TraditionalForm]],
  ExpressionUUID->"90bc9a17-7108-40c6-8b4a-c2cbf12d16c0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"gcd", "(", 
     RowBox[{"p", ",", "q"}], ")"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"3a01ea87-e6db-454c-afd8-0ecd4b9619d2"],
 ".\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", 
     RowBox[{"(", "t", ")"}]}], " ", "=", 
    RowBox[{"cos", 
     RowBox[{"(", 
      RowBox[{"q", " ", "t"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"3", "+", 
       RowBox[{"cos", 
        RowBox[{"(", 
         RowBox[{"p", " ", "t"}], ")"}]}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"e5301ab3-3c60-4819-a0ee-e40255dbc456"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"y", 
     RowBox[{"(", "t", ")"}]}], " ", "=", 
    RowBox[{"sin", 
     RowBox[{"(", 
      RowBox[{"q", " ", "t"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"3", "+", 
       RowBox[{"cos", 
        RowBox[{"(", 
         RowBox[{"p", " ", "t"}], ")"}]}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"8b1cc4c5-607b-4521-902e-d2e1ae410d07"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"z", "(", "t", ")"}], " ", "=", 
    RowBox[{"sin", "(", 
     RowBox[{"p", " ", "t"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "768906f1-7a99-4054-a64c-d04d0bbe7c43"]
}], "Text",
 CellChangeTimes->{
  3.7596836741679296`*^9, {3.759683705650793*^9, 3.7596839044666243`*^9}, {
   3.759684249622054*^9, 3.759684258687393*^9}, {3.759754102810046*^9, 
   3.759754104013619*^9}, {3.7597541761722507`*^9, 3.759754188326614*^9}, {
   3.759754444054756*^9, 
   3.759754445470742*^9}},ExpressionUUID->"336241f2-d4ac-44a6-bacb-\
952136edeb80"],

Cell[TextData[{
 "Here is an example of such a curve for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", "3"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "9940779a-dc30-46c1-a11c-28b0d26cc510"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "=", "2."}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "8fedbe3c-f0c9-4e89-ac5c-035a13609aa9"]
}], "Text",
 CellChangeTimes->{{3.759754480022574*^9, 
  3.7597544987760763`*^9}},ExpressionUUID->"25807df0-3dad-499e-9903-\
07ec6f70afd0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ParametricPlot3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "[", 
      RowBox[{"t", ",", "3", ",", "2"}], "]"}], ",", 
     RowBox[{"y", "[", 
      RowBox[{"t", ",", "3", ",", "2"}], "]"}], ",", 
     RowBox[{"z", "[", 
      RowBox[{"t", ",", "3", ",", "2"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", "\n", "\t\t", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"Thickness", "[", "0.03", "]"}], "}"}]}], ",", 
   RowBox[{"ColorFunction", "\[Rule]", "\"\<DarkRainbow\>\""}], ",", 
   RowBox[{"AxesLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.7596842666927547`*^9, 3.759684278428288*^9}, {
  3.759684420872512*^9, 3.7596844412394876`*^9}, {3.760351470867592*^9, 
