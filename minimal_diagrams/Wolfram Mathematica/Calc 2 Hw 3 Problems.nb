Cell[TextData[{
 "(i) Compute the arc-length of these curves or all pairs (see the above \
restrictions) with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"3", "\[LessEqual]", "p", "\[LessEqual]", "8"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "ddd62f39-d03b-4352-a02b-1165cefe1835"],
 ".\n(ii) Look at the plots of the examples generated by (i) and see if you \
can figure out how to describe the curves using the parameters p and q. "
}], "Text",
 CellChangeTimes->{{3.7597541170050983`*^9, 3.7597541603241568`*^9}, {
  3.759754195715638*^9, 3.759754235451388*^9}, {3.759754365467616*^9, 
  3.759754439422957*^9}},ExpressionUUID->"c923b8dd-beda-43ec-ae2f-\
0258c1065e1f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Problem I1I Volume measurements for tubes and horns", "Subsubsection",
 CellChangeTimes->{{3.759755811563121*^9, 3.759755821714678*^9}},
 CellTags->"2.03.G4",ExpressionUUID->"5255fece-9300-4c87-b60e-902159b8c112"],

Cell["\<\
Here is a modest curve shown with the three coordinate axes in three \
dimensions:\
\>", "Text",ExpressionUUID->"53415310-c052-461a-b7bd-b339293d5b7c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"h", "=", "5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"spacer", "=", 
   FractionBox["h", "10"]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"threedims", "=", 
   RowBox[{"Graphics3D", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "h"}], ",", "0", ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"h", ",", "0", ",", "0"}], "}"}]}], "}"}], "]"}]}], "}"}],
       ",", 
      RowBox[{"Text", "[", 
       RowBox[{"\"\<x\>\"", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"h", "+", "spacer"}], ",", "0", ",", "0"}], "}"}]}], "]"}], 
      ",", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", 
             RowBox[{"-", "h"}], ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", 
             RowBox[{"h", "+", "1"}], ",", "0"}], "}"}]}], "}"}], "]"}]}], 
       "}"}], ",", 
      RowBox[{"Text", "[", 
       RowBox[{"\"\<y\>\"", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"h", "+", "1", "+", "spacer"}], ",", "0"}], "}"}]}], "]"}], 
      ",", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", 
             RowBox[{"-", 
              FractionBox["h", "2"]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", 
             RowBox[{"h", "+", "2"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
      RowBox[{"Text", "[", 
       RowBox[{"\"\<z\>\"", ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", 
          RowBox[{"h", "+", "2", "+", "spacer"}]}], "}"}]}], "]"}]}], "}"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"t", ",", "curveplotter"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"curveplotter", "[", "t_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", "t", "]"}], ",", 
     RowBox[{"3", " ", "t", " ", 
      RowBox[{"Sin", "[", "t", "]"}]}], ",", 
     RowBox[{"3", " ", "t"}]}], "}"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"curve", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{"curveplotter", "[", "t", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "2"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{"threedims", ",", "curve", ",", 
   RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.759755004235382*^9, 3.759755076464304*^9}, {
  3.7597558336078053`*^9, 3.759755834979525*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"1e2cb6ec-1258-442e-ab70-ee6507ae7630"],

Cell[TextData[{
 "Here is the same curve shown with a few sample circles parallel to the ",
 Cell[BoxData["xy"],ExpressionUUID->"f2c65cb7-5b92-4eca-8155-0bc28639de9b"],
 "-plane and centered on the curve:"
}], "Text",ExpressionUUID->"766c0521-bfba-40c3-8cf0-111659cf5abe"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "t", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"circle1", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"curveplotter", "[", "0.5", "]"}], "+", 
        RowBox[{"2", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", "t", "]"}], ",", 
           RowBox[{"Sin", "[", "t", "]"}], ",", "0"}], "}"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", 
        RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"circle2", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"curveplotter", "[", "1", "]"}], "+", 
        RowBox[{"2", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", "t", "]"}], ",", 
           RowBox[{"Sin", "[", "t", "]"}], ",", "0"}], "}"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", 
        RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"circle3", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"curveplotter", "[", "1.5", "]"}], "+", 
        RowBox[{"2", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Cos", "[", "t", "]"}], ",", 
           RowBox[{"Sin", "[", "t", "]"}], ",", "0"}], "}"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", 
        RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{
  "threedims", ",", "curve", ",", "circle1", ",", "circle2", ",", "circle3", 
   ",", 
   RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.759755101505391*^9, 3.759755118918686*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"cf44bea2-bfce-42ac-b08f-55db47025581"],

Cell["\<\
Here's what you get when you make a tube consisting of all such circles:\
\>", "Text",ExpressionUUID->"d2a9b9a2-265b-4e38-ab01-2fb873e13dfc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"tubeplotter", ",", "s", ",", "t"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tubeplotter", "[", 
    RowBox[{"s_", ",", "t_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"curveplotter", "[", "t", "]"}], "+", 
    RowBox[{"2", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Cos", "[", "s", "]"}], ",", 
       RowBox[{"Sin", "[", "s", "]"}], ",", "0"}], "}"}]}]}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tube", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"tubeplotter", "[", 
        RowBox[{"s", ",", "t"}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", 
        RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"tubeplot", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"threedims", ",", "tube", ",", "curve", ",", 
    RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.759755133983411*^9, 3.759755152365758*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"5a673ec5-9ed4-409c-994c-6bb560ea179b"],

Cell[TextData[{
 "Move each circle in its own plane but so that it is centered on the ",
 Cell[BoxData["z"],ExpressionUUID->"d63c5afc-3e0b-499b-8ba2-5898f16204fa"],
 "-axis:"
}], "Text",ExpressionUUID->"3321786e-7dac-4acb-b3d3-80157c30d491"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"cylinderplotter", ",", "s", ",", "t"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cylinderplotter", "[", 
   RowBox[{"s_", ",", "t_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", 
     RowBox[{
      RowBox[{"curveplotter", "[", "t", "]"}], "\[LeftDoubleBracket]", "3", 
      "\[RightDoubleBracket]"}]}], "}"}], "+", 
   RowBox[{"2", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Cos", "[", "s", "]"}], ",", 
      RowBox[{"Sin", "[", "s", "]"}], ",", "0"}], "}"}]}]}]}]}], "Input",
 CellChangeTimes->{3.7597551788381166`*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"814a138b-0410-4303-ae00-26c3ac2c7c8e"],

Cell["Compare:", "Text",ExpressionUUID->"8c90fd21-0759-4134-9863-7517880fa59d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tubeplotter", "[", 
  RowBox[{"s", ",", "t"}], "]"}]], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"75523c76-920a-47eb-aea6-3f9e32095db4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"2", " ", 
     RowBox[{"Cos", "[", "s", "]"}]}], "+", 
    RowBox[{"Cos", "[", "t", "]"}]}], ",", 
   RowBox[{
    RowBox[{"2", " ", 
     RowBox[{"Sin", "[", "s", "]"}]}], "+", 
    RowBox[{"3", " ", "t", " ", 
     RowBox[{"Sin", "[", "t", "]"}]}]}], ",", 
   RowBox[{"3", " ", "t"}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.7597552367876797`*^9},ExpressionUUID->"ade4ea87-973a-4530-b3bc-\
31bb24e5c0e1"]
}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"s", ",", "t"}], "]"}], ";"}], "\n", 
 RowBox[{"cylinder", "=", 
  RowBox[{"ParametricPlot3D", "[", 
   RowBox[{
    RowBox[{"cylinderplotter", "[", 
     RowBox[{"s", ",", "t"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"s", ",", "0", ",", 
      RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", 
    RowBox[{"Boxed", "\[Rule]", "False"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.759755218305645*^9, 3.7597553020418*^9}, {
  3.7597553352195797`*^9, 3.759755342576572*^9}, {3.7597553792664213`*^9, 
  3.759755381167404*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"23b2bda5-1e20-4e38-bbcb-62eff77dee9d"],

Cell["Here it is all combined:", "Text",
 CellChangeTimes->{{3.759755423206506*^9, 
  3.759755441781455*^9}},ExpressionUUID->"342ab560-01c5-4918-aa3a-\
369f41685c68"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{"cylinder", ",", "threedims", ",", "tube", ",", 
   RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.759755388087976*^9, 
  3.759755419399651*^9}},ExpressionUUID->"a04cece3-b2b6-468c-8f0d-\
2a8b0e92067e"],

Cell[TextData[{
 "(i) The cylinder has a base with radius ",
 Cell[BoxData["2"],ExpressionUUID->"90ecab5f-2d6b-42d0-ae41-5dafa0bef0a4"],
 ", and the height of the cylinder is ",
 Cell[BoxData[
  RowBox[{"6", "=", 
   RowBox[{"3", 
    RowBox[{"(", "2", ")"}]}]}]],ExpressionUUID->
  "261f72dc-be7b-49ea-adaa-2f66b366f3b6"],
 ", so the volume of the cylinder measures out to\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox["2", "2"], "\[Pi]", " ", 
    RowBox[{"(", "6", ")"}]}], "=", 
   RowBox[{"24", "\[Pi]"}]}]],ExpressionUUID->
  "70fcaa83-fedd-4108-a1e7-4636e0c42187"],
 " cubic units. \nExplain why the volume of the tube also measures out to ",
 Cell[BoxData[
  RowBox[{"24", "\[Pi]"}]],ExpressionUUID->
  "5dabbcfd-73c1-4aff-9e2d-9b5c360c5b8d"],
 " cubic units. "
}], "Text",
 CellChangeTimes->{{3.759755914678297*^9, 
  3.759755915733251*^9}},ExpressionUUID->"e2fe2b1f-c518-4feb-b9c5-\
91c13e45debd"],

Cell[TextData[{
 "(ii) If you go back to the beginning, keeping everything the same but \
changing \n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"curveplotter", "[", "t", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Cos", "[", "t", "]"}], ",", 
     RowBox[{"3", 
      RowBox[{"tSin", "[", "t", "]"}]}], ",", 
     RowBox[{"3", "t"}]}], "}"}]}]],ExpressionUUID->
  "0aa55181-1b7e-4ad7-9420-5cc1ebd6b1ed"],
 " \nto\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"curveplotter", "[", "t", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "t", "]"}], ",", 
     RowBox[{"g", "[", "t", "]"}], ",", 
     RowBox[{"3", "t"}]}], "}"}]}]],ExpressionUUID->
  "065045ca-ef3f-42b2-ade6-3edb36d87f34"],
 "\nwhere ",
 Cell[BoxData[
  RowBox[{"f", "[", "t", "]"}]],ExpressionUUID->
  "e99ddc91-113d-45ba-abf1-0c988e7f3a31"],
 " and ",
 Cell[BoxData[
  RowBox[{"g", "[", "t", "]"}]],ExpressionUUID->
  "b68884d2-1cee-443b-96bf-a98eb35f7f72"],
 " are any functions you care to use, then how do you know that the volume of \
the resulting tube measures out to ",
 Cell[BoxData[
  RowBox[{"12", "\[Pi]"}]],ExpressionUUID->
  "26c15907-a3f7-427b-adfb-3421bec74391"],
 " cubic units? Explain and produce a new tube plot for a new set of \
functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "t", ")"}], " "}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "3ade2a6e-1302-4366-805b-27e745e64b6e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", "t", ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "e87ce118-eecd-4fe4-88e2-dd91342ea4de"]
}], "Text",
 CellChangeTimes->{{3.7597555219001102`*^9, 3.759755574069029*^9}, {
  3.759755919173128*^9, 
  3.7597559206930027`*^9}},ExpressionUUID->"e482c1fc-4805-4b3c-adb1-\
82a5b2575aaa"],

Cell["(iii) Look at this plot:", "Text",
 CellChangeTimes->{{3.759755927388981*^9, 
  3.759755929299979*^9}},ExpressionUUID->"e0a41bd0-f4c9-426e-9563-\
421a989bd408"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"h", "=", "5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"spacer", "=", 
   FractionBox["h", "10"]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"threedims", "=", 
    RowBox[{"Graphics3D", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Blue", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "h"}], ",", "0", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"h", ",", "0", ",", "0"}], "}"}]}], "}"}], "]"}]}], 
        "}"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<x\>\"", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"h", "+", "spacer"}], ",", "0", ",", "0"}], "}"}]}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"Blue", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"-", "h"}], ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{"h", "+", "1"}], ",", "0"}], "}"}]}], "}"}], "]"}]}], 
        "}"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<y\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"h", "+", "1", "+", "spacer"}], ",", "0"}], "}"}]}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"Blue", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", 
              RowBox[{"-", 
               FractionBox["h", "2"]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", 
              RowBox[{"h", "+", "2"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<z\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", 
           RowBox[{"h", "+", "2", "+", "spacer"}]}], "}"}]}], "]"}]}], "}"}], 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"CMView", "=", 
   RowBox[{"{", 
    RowBox[{"2.7", ",", "1.6", ",", "1.2"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{
    "s", ",", "t", ",", "curveplotter", ",", "hornplotter", ",", "radius"}], 
    "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"curveplotter", "[", "t_", "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"t", " ", 
       RowBox[{"(", 
        RowBox[{"4", "-", "t"}], ")"}]}], ",", "t", ",", 
      FractionBox[
       SuperscriptBox["t", "2"], "4"]}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"radius", "[", "t_", "]"}], "=", 
    RowBox[{"0.75", " ", "t"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"hornplotter", "[", 
     RowBox[{"s_", ",", "t_"}], "]"}], "=", 
    RowBox[{
     RowBox[{"curveplotter", "[", "t", "]"}], "+", 
     RowBox[{
      RowBox[{"radius", "[", "t", "]"}], " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cos", "[", "s", "]"}], ",", "0", ",", 
        RowBox[{"Sin", "[", "s", "]"}]}], "}"}]}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"horn", "=", 
    RowBox[{"ParametricPlot3D", "[", 
     RowBox[{
      RowBox[{"hornplotter", "[", 
       RowBox[{"s", ",", "t"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", 
        RowBox[{"2", " ", "\[Pi]"}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"hornplot", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"threedims", ",", "horn", ",", 
    RowBox[{"Boxed", "\[Rule]", "False"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.759755588193712*^9, 3.759755624840685*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"4400b7c3-eee0-41aa-8bf2-f5b3c4e2e9d7"],

Cell[TextData[{
 "The cross sections of this horn sliced by planes parallel to the ",
 Cell[BoxData["xz"],ExpressionUUID->"c17283ae-689f-4c66-bf26-ace73393ef74"],
 "-plane are circles of varying radiuses. Move each circle in its own plane \
but so that it is centered on the ",
 Cell[BoxData["y"],ExpressionUUID->"13ec7c04-fa39-4e20-9f41-6653d17c53ff"],
 "-axis; and use what you see to measure the volume of this horn."
}], "Text",
 CellChangeTimes->{{3.759755705919276*^9, 
  3.759755706758016*^9}},ExpressionUUID->"795ce7b2-5d90-473a-8312-\
623aa2562450"],

Cell[TextData[{
 "(iv) Start with a base curve specified by\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"curveplotter", "[", "t", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"t", ",", 
     RowBox[{"f", "[", "t", "]"}], ",", 
     RowBox[{"g", "[", "t", "]"}]}], "}"}]}]],ExpressionUUID->
  "62e46568-adec-44e8-b883-36d6e5cf7b5c"],
 " \nwith ",
 Cell[BoxData[
  RowBox[{"a", "\[LessEqual]", "t", "\[LessEqual]", "b"}]],ExpressionUUID->
  "14b08bbc-cbb7-4221-bbd9-51dd13cab92a"],
 ". \nBuild a horn by centering at each point ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"t", ",", 
    RowBox[{"f", "[", "t", "]"}], ",", 
    RowBox[{"g", "[", "t", "]"}]}], "}"}]],ExpressionUUID->
  "9e1144fe-691d-4d63-957f-4288efc8c48b"],
 " a circle of radius ",
 Cell[BoxData[
  RowBox[{"r", "[", "t", "]"}]],ExpressionUUID->
  "ce6645c7-226a-4271-90a7-adaad5e33137"],
 " parallel to the ",
 Cell[BoxData["yz"],ExpressionUUID->"1b304d89-a979-47a7-a53c-29319406f4c0"],
 " plane.\nWrite down a formula that everyone can use to measure the volume \
of this horn. "
}], "Text",
 CellChangeTimes->{{3.759755939484466*^9, 
  3.7597559407558727`*^9}},ExpressionUUID->"f98ede8c-ca59-4abf-b3dd-\
bf91b33dc9e3"]
}, Closed]]
}, Open  ]]
}, Open  ]]
},
