   3.758411761642177*^9}, 
   3.758500049405244*^9},ExpressionUUID->"5671b4d0-70b5-41e9-b13d-\
d79ac20bafce"]
}, Closed]],

Cell[CellGroupData[{

Cell["Functions needed to solve the problem ", "Subsubsection",
 CellChangeTimes->{{3.7584254583906107`*^9, 3.7584255260744815`*^9}, {
