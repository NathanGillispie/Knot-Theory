Cell[TextData[{
 "d) Write a function  ",
 StyleBox["findAllWords[letterRect, wordLst]",
  FontWeight->"Bold"],
 ", which checks all the words in the ",
 StyleBox["wordLst",
  FontSlant->"Italic"],
 " and returns the matches. If a word was not found at all, no info about it \
is included in the result. For each word which has a multiple match return a \
list which indicates this: \
{\[OpenCurlyDoubleQuote]re\[CloseCurlyDoubleQuote], \
\[OpenCurlyDoubleQuote]multiple matches\[CloseCurlyDoubleQuote]}. For words \
which have exactly one match return a list {word, matchinfo}, where matchinfo \
is the result of findWord."
}], "Text",
 CellChangeTimes->{
  3.6326624366535063`*^9, {3.6326667123296137`*^9, 3.6326667352536135`*^9}, {
