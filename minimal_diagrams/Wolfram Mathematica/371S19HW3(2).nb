Cell[TextData[{
 "d) Write a function ",
 StyleBox["lowerUpper3D[lower, upper, start, repeat] ",
  FontWeight->"Bold"],
 " that uses the earlier function ",
 StyleBox["stopPointRandomWalk3D[lower, upper, start]",
  FontWeight->"Bold"],
 ". The function ",
 StyleBox["lowerUpper3D[lower, upper, start, repeat] ",
  FontWeight->"Bold"],
 "runs ",
 StyleBox["stopPointRandomWalk3D[lower, upper, start]",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   StyleBox["repeat",
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "bd59e085-81a4-4553-9b37-a27a744d2cca"],
 " many times and counts and returns how often the walk ends at ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     RowBox[{"lower", " ", "y"}], "-", "coordinate"}],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "b1006aa7-d305-41dc-a1d1-658cd64502fc"],
 ", ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     RowBox[{"upper", " ", "y"}], " ", "-", "coordinate"}],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "b9f9bfb4-45d7-414f-891b-3fbd6938407f"],
 ", lower z-coordinate  and ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     RowBox[{"upper", " ", "z"}], " ", "-", "coordinate"}],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "d239688c-b33d-4ce5-8663-ff5e7564e79d"],
 ". A fifth value indicates how many walks ended at a corner.\nFor example if \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["repeat",
     FontSlant->"Italic"], "=", "10"}], TraditionalForm]],ExpressionUUID->
  "ab5965f5-cae1-4549-92d7-cad49764df03"],
 " the it might return ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"2", ",", "1", ",", "4", ",", "3", ",", " ", "0"}], "}"}], 
   TraditionalForm]],ExpressionUUID->"3d9dcae0-8c10-4857-a6a7-c3ea62255643"],
 " then this means in the 10 walks generated,  2 walks stopped when they \
reached the value lower y-coordinate and 1 walk stopped when it reached the \
upper y-coordinate and so on. The 0 means none ended in a corner.  A second \
example if repeat = 10 a returned list of {2, 3, 4, 3, 2}, means that two of \
the walks ended in a corner and are counted twice. That is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"2", "+", "3", "+", "4", "+", "3"}], "=", "12"}], 
   TraditionalForm]],ExpressionUUID->"eaaa9587-938e-48c5-a11f-ff9a425112d6"],
 ".",
 StyleBox[" ",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.568640235127554*^9, 3.568640624533382*^9}, {
  3.568640706506723*^9, 3.568641158029327*^9}, {3.5686797386809154`*^9, 
  3.5686797662617636`*^9}, {3.5686811483095913`*^9, 3.56868131830309*^9}, {
  3.568681494037399*^9, 3.568681507391022*^9}, {3.568681676350519*^9, 
  3.5686817044461684`*^9}, {3.568684763286577*^9, 3.5686847881272173`*^9}, {
  3.757374801058711*^9, 3.757374813859572*^9}, {3.757375827050112*^9, 
  3.757375968715679*^9}, {3.757375999368474*^9, 3.757376044146431*^9}, {
  3.758379287813198*^9, 3.758379336785095*^9}, {3.758391762976506*^9, 
  3.758391907071748*^9}, {3.7584105143617973`*^9, 3.758410534694119*^9}, {
  3.758410582658022*^9, 
  3.7584106185917377`*^9}},ExpressionUUID->"c93691b4-a21d-4616-8b2c-\
8c4ab7ffa055"]
}, Closed]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Problem 2: ",
  FontWeight->"Bold"],
 " ",
 StyleBox[" Wonderword",
  FontWeight->"Bold"]
}], "Subsubsection",
 CellChangeTimes->{{3.6326162073864613`*^9, 3.632616210112747*^9}, {
  3.632620099563983*^9, 3.632620103372201*^9}, {3.758424719858369*^9, 
  3.75842474295969*^9}},ExpressionUUID->"7254d108-85d7-4c70-8a62-\
bf117dbb1e84"],

Cell[CellGroupData[{

Cell["The general problem", "Subsubsection",
 CellChangeTimes->{{3.7584254583906107`*^9, 
  3.758425470306292*^9}},ExpressionUUID->"6e461e44-d024-4f86-8e3a-\
3ae2b5a4f6ed"],

Cell["\<\
Below is an example of a Wonderword game: A letterRect of letters and a list \
of words. The game consists of finding each of the words in the letterRect in \
any of the 8 directions. Any word appears exactly once. Letters which are not \
part of any of the words are the solution of the puzzle.  Note that a letter \
may be part of more than one word.
Here is the problem to be solved: Given a letterRect of letters and a list of \
words, check whether the letterRect makes up a Wonderword game. That means, \
check each word in the list to make sure it appears exactly most once. Your \
solution must return the following three pieces of information: 1) The list \
of words (from the given list of words) which were found exactly once; 2) The \
list of words which were found more than once. 3) The list of words which \
were not found at all. (The details of what to return are described below.)\
\>", "Text",
 CellChangeTimes->{
  3.632661430965632*^9, 3.6326614667703114`*^9, {3.758398891639965*^9, 
   3.7583991143897057`*^9}, {3.758399151432824*^9, 3.758399167380737*^9}, {
   3.758399336946435*^9, 3.7583994454556417`*^9}, {3.758399616838444*^9, 
   3.7583996372616124`*^9}, {3.7584248335428715`*^9, 3.758425372419693*^9}, {
   3.75842830749457*^9, 3.758428318411194*^9}, {3.758487890011278*^9, 
   3.7584879486161375`*^9}, {3.7584879853178077`*^9, 
   3.7584879858148575`*^9}, {3.75848830687396*^9, 3.7584883107083435`*^9}, {
   3.758488354002672*^9, 3.7584883888071527`*^9}, {3.758499769757249*^9, 
   3.758499789233363*^9}, {3.758500064982135*^9, 
   3.7585000651681457`*^9}},ExpressionUUID->"7051a38f-a960-4c0e-a77e-\
9809f69e9ea4"],

