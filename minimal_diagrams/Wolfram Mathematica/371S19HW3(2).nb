Cell[CellGroupData[{

Cell["Representing the letterRect as a list of lists", "Subsubsection",
 CellChangeTimes->{{3.7584254583906107`*^9, 3.7584255260744815`*^9}, 
   3.758500065180146*^9},ExpressionUUID->"04a63e43-d591-42a2-9dad-\
6db88f356938"],

Cell[TextData[{
 "The letterRect has ",
 StyleBox["rows",
  FontWeight->"Bold"],
 " and ",
 StyleBox["columns",
  FontWeight->"Bold"],
 ". Each row is a horizontal arrangement of letters. Rows are stacked \
vertically. The first row in the given example contains the letters \
\[OpenCurlyDoubleQuote]b\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]r\
\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]e\[CloseCurlyDoubleQuote],\
\[CloseCurlyDoubleQuote]a\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]d\
\[CloseCurlyDoubleQuote]. The third row contains the letters \
\[OpenCurlyDoubleQuote]s\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]t\
\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]o\[CloseCurlyDoubleQuote],\
\[CloseCurlyDoubleQuote]v\[CloseCurlyDoubleQuote],\[CloseCurlyDoubleQuote]e\
\[CloseCurlyDoubleQuote]. A column is a vertical arrangement of letters. \
Columns are side-by-side. The first column in the given example contains the \
letters \[OpenCurlyDoubleQuote]b\[CloseCurlyDoubleQuote], \
\[OpenCurlyDoubleQuote]m\[CloseCurlyDoubleQuote], \[OpenCurlyDoubleQuote]s\
\[CloseCurlyDoubleQuote], \[OpenCurlyDoubleQuote]f\[CloseCurlyDoubleQuote], \
\[OpenCurlyDoubleQuote]g\[CloseCurlyDoubleQuote].  Below is the code to \
specify a letterRect and how to display it nicely. "
}], "Text",
 CellChangeTimes->{
  3.632661430965632*^9, 3.6326614667703114`*^9, {3.758398891639965*^9, 
   3.7583991143897057`*^9}, {3.758399151432824*^9, 3.758399167380737*^9}, {
   3.758399336946435*^9, 3.7583994454556417`*^9}, {3.758399616838444*^9, 
   3.7583996372616124`*^9}, {3.758425567399845*^9, 3.758425568515909*^9}, {
   3.758500065194147*^9, 
   3.758500065208148*^9}},ExpressionUUID->"2d24691c-f626-49d9-8225-\
8fffcc599fbf"],

Cell["\<\
Note that the code specifies each row in a list, and the entire letterRect is \
a list of lists. Note that the first row is at the top of the letterRect and \
that moving from row to row+1 means moving down. Moving from  column to \
column +1 means moving to the right. The notation {row, col} is REVERSE from \
the usual {x,y} coordinates, but make it easy to access the letter in the \
letterRect. I recommend to stick with thinking about {row, col} to make it \
less likely that you switch the parameters.\
\>", "Text",
 CellChangeTimes->{{3.758399177456313*^9, 3.7583992167445602`*^9}, {
  3.758399254581724*^9, 3.7583992887256775`*^9}, {3.7583994393012896`*^9, 
  3.758399494136426*^9}, {3.758399637782642*^9, 3.758399638370676*^9}, {
  3.758400095599828*^9, 3.758400142711522*^9}, {3.758425669548688*^9, 
  3.7584256973742795`*^9}, {3.758499830977751*^9, 3.758499913396465*^9}, {
  3.758500065222149*^9, 
  3.7585000652531505`*^9}},ExpressionUUID->"b1f5ec8f-4210-48f6-b453-\
2fca21304b5b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"letterRect", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\"\<b\>\"", ",", "\"\<r\>\"", ",", "\"\<e\>\"", ",", "\"\<a\>\"", ",", 
       "\"\<d\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<m\>\"", ",", "\"\<o\>\"", ",", "\"\<u\>\"", ",", "\"\<s\>\"", ",", 
       "\"\<e\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<s\>\"", ",", "\"\<t\>\"", ",", "\"\<o\>\"", ",", "\"\<v\>\"", ",", 
       "\"\<e\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<f\>\"", ",", "\"\<l\>\"", ",", "\"\<o\>\"", ",", "\"\<w\>\"", ",", 
       "\"\<r\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
      "\"\<g\>\"", ",", "\"\<r\>\"", ",", "\"\<a\>\"", ",", "\"\<p\>\"", ",", 
       "\"\<e\>\""}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"display", " ", "=", " ", 
  RowBox[{"Grid", "[", 
   RowBox[{"letterRect", ",", " ", 
    RowBox[{"Frame", "\[Rule]", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.632663227493803*^9, 3.632663236597438*^9}, {
  3.758399639987768*^9, 3.7583996404227934`*^9}, {3.758425728843079*^9, 
  3.758425746496089*^9}, {3.758500025941902*^9, 
  3.758500047029108*^9}},ExpressionUUID->"75df302b-18d8-400b-b908-\
1b32decaa369"],

