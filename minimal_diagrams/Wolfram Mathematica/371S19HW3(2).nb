Cell[TextData[{
 "f) ",
 StyleBox["Bonus",
  FontWeight->"Bold"],
 ": Write a function checkWonder[sq, wordlst, color] (which calls \
findAllWords) which returns a list containing four items: a) the list of \
words from wordlst which appear exactly once b) the list of words from \
wordlst which appear more than once c) the list of words from wordlst which \
do not appear at all and d) the letterRect with the words found exactly once \
colored with the given color."
}], "Text",
 CellChangeTimes->{
  3.6326624366535063`*^9, {3.6326667123296137`*^9, 3.6326667352536135`*^9}, {
   3.758399647634206*^9, 3.758399647696209*^9}, {3.7584005771163692`*^9, 
