Cell["Submission details", "Subsubsection",
 CellChangeTimes->{{3.6005568947642603`*^9, 3.600556923210887*^9}, {
  3.757609566737742*^9, 3.7576095708139753`*^9}, {3.7576109995416937`*^9, 
