       "]]},
     Annotation[#, "Charting`Private`Tag$35744#2"]& ]}, 
   {RGBColor[1, 0, 0], Thickness[0.01], 
    LineBox[{{-0.5, -0.5}, {1.75, -0.5}}]}},
  Axes->{True, True},
  AxesLabel->{
    FormBox["\"x\"", TraditionalForm], 
    FormBox["\"y\"", TraditionalForm]},
  AxesOrigin->{0, 0},
  DisplayFunction->Identity,
  Epilog->{
    InsetBox[
     FormBox["\"x = left[y]\"", TraditionalForm], {-1, -0.6}], 
    InsetBox[
     FormBox["\"x = right[y]\"", TraditionalForm], {1.5, -1}], 
    InsetBox[
     FormBox["\"R\"", TraditionalForm], {1, -0.5}]},
  FrameLabel->{{None, None}, {None, None}},
  FrameTicks->{{Automatic, Automatic}, {Automatic, Automatic}},
  GridLinesStyle->Directive[
    GrayLevel[0.5, 0.4]],
