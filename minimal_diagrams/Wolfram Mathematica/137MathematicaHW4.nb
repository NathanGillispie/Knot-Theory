Cell[TextData[{
 "The region ",
 Cell[BoxData["R"],ExpressionUUID->"a5144c75-6a5a-43ad-a3ef-551f7354bef1"],
 " consists of all points between and on the plotted curves. Calculate\n      \
 ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "17b7a44a-8cc2-42b8-a040-9514817ab6dc"],
 " \nfor\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{"x", " ", "y"}]}]],ExpressionUUID->
  "031b71e8-38ee-4ff6-9fa7-cd53450fad4a"],
 "."
}], "Text",ExpressionUUID->"79aa41cd-3d2b-4d08-9ba9-4a30e0d12df6"],

Cell["Answer:", "Special1",ExpressionUUID->"ee4592db-cab7-413a-b9cd-2ff830eb1691"],

Cell[TextData[{
 "Enter the function ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y"}], "]"}]],ExpressionUUID->
  "47ed26d5-5bdc-4162-94ca-0c230b5e6658"],
 ":"
}], "SmallText",ExpressionUUID->"20295181-2536-4758-b678-f6eb499f6edc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"f", ",", "x", ",", "y"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], "=", 
  RowBox[{"x", " ", "y"}]}]}], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"95ce5c19-6fa1-4c56-8894-57538187a5a7"],

Cell[TextData[{
 "To set up\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "f9055a5d-3ec6-4980-99be-98e3f0bd595e"],
 " \nfor calculation, you need a convenient way of slicing ",
 Cell[BoxData["R"],ExpressionUUID->"27ddd349-0fc9-46ca-b00b-3359649aa9bb"],
 ".\nHere's one:"
}], "SmallText",ExpressionUUID->"da3a7473-5e10-4f56-b8b6-a8993060ad56"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"slice", ",", "sliceplot", ",", "y"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"slice", "[", "y_", "]"}], ":=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{"Red", ",", 
      RowBox[{"Thickness", "[", "0.01", "]"}], ",", 
      RowBox[{"Line", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"left", "[", "y", "]"}], ",", "y"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"right", "[", "y", "]"}], ",", "y"}], "}"}]}], "}"}], 
       "]"}]}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"sliceplot", "[", "y_", "]"}], ":=", 
    RowBox[{"Show", "[", 
     RowBox[{"regionplot", ",", 
      RowBox[{"slice", "[", "y", "]"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{"sliceplot", "[", 
   RowBox[{"-", "0.5"}], "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.761573675798664*^9, 3.7615736819893503`*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"cfb5a86a-b07c-4f3d-b123-4641bffaba8d"],

