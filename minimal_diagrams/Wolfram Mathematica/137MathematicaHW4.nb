Cell[CellGroupData[{
Cell[TextData[{
 "Math 137 Sp 19  ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " Hw 4   More volumes and the importance of polynomials\tErnst"
}], "Section",
 CellChangeTimes->{{3.586700405253828*^9, 3.586700436749889*^9}, 
   3.586876005098486*^9, {3.5868832585707006`*^9, 3.58688325929895*^9}, {
   3.587899490250379*^9, 3.58789949557388*^9}, 3.588078378190113*^9, {
   3.599957668826419*^9, 3.599957687523932*^9}, {3.600525084181932*^9, 
   3.600525092712934*^9}, {3.6005260849682302`*^9, 3.6005260938611097`*^9}, {
   3.6018185650835667`*^9, 3.6018185741996717`*^9}, {3.603038387742138*^9, 
   3.603038397460518*^9}, 3.603061349344893*^9, {3.603064741308786*^9, 
   3.603064751162403*^9}, {3.604428404659155*^9, 3.604428418608073*^9}, {
   3.606126738204846*^9, 3.6061267566109324`*^9}, 3.6370589027540135`*^9, 
   3.731330044883811*^9, {3.761573773289596*^9, 3.761573807626978*^9}, {
   3.7615772422636347`*^9, 3.761577245461856*^9}, 
   3.761577633128373*^9},ExpressionUUID->"32719270-ee4f-4990-89b3-\
65068cca9104"],

Cell[TextData[{
 "Form groups of two. Each member of the group must understand and be able to \
explain (in detail) all of the homework turned in. We allow you to work in \
groups so that you have someone with whom you can talk about your work in \
detail. This is ",
 StyleBox["not ",
  FontWeight->"Bold"],
 "meant for group members to only do half of the work. \nEach group turns in \
one (stapled) printout at the beginning of class."
}], "Text",
 CellChangeTimes->{{3.5867002280443563`*^9, 
  3.586700259274942*^9}},ExpressionUUID->"e8591181-f3db-440c-86f0-\
346c856f4586"],

Cell[TextData[StyleBox["Due: Friday, April 5  ",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.586700310541088*^9, 3.5867003400757313`*^9}, 
   3.5867342805118723`*^9, {3.586876008167721*^9, 3.586876008662834*^9}, {
   3.5880283141008663`*^9, 3.5880283142966843`*^9}, {3.599957833868779*^9, 
   3.599957842021747*^9}, {3.600534108636919*^9, 3.600534108833461*^9}, {
   3.601818605176908*^9, 3.601818606440959*^9}, {3.60306479915849*^9, 
   3.603064805108623*^9}, {3.603193667379362*^9, 3.6031936692193623`*^9}, {
   3.604429374654108*^9, 3.604429378784893*^9}, 3.604605761707739*^9, 
