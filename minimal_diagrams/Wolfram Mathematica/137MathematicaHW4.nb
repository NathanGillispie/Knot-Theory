Cell[TextData[{
 "How do you use the double integral\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "addc105a-f326-4e0c-b436-f8ebc08c2c7c"],
 " \nto measure the volume of the solid consisting of everything between the \
surface plotted above and the ",
 Cell[BoxData["xy"],ExpressionUUID->"b8b2914d-c58e-4bdc-af43-722e83bfa84a"],
 "-plane?"
}], "Text",ExpressionUUID->"92655235-7958-41d5-aec3-8b058a4bcf55"],

Cell["Answer:", "Special1",ExpressionUUID->"268ae868-47e7-4179-88bf-77876981d3db"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", "a", "b"], 
  RowBox[{
   SubsuperscriptBox["\[Integral]", "c", "d"], 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], 
    RowBox[{"\[DifferentialD]", "y"}], 
    RowBox[{"\[DifferentialD]", "x"}]}]}]}]], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"a6e6a759-b9e7-4a4e-a296-f090027f81a9"],

Cell[BoxData["430.`"], "Output",
 CellChangeTimes->{
  3.761573195403222*^9},ExpressionUUID->"c5ba4d09-6c9d-4696-a435-\
b22cbb7df0c6"]
}, Open  ]],

Cell[TextData[{
 "The volume of the solid measures out to ",
 Cell[BoxData["430"],ExpressionUUID->"b3298567-6d9e-4221-8fcb-a072d630e76a"],
 " cubic units."
}], "SmallText",ExpressionUUID->"4bd293b7-677d-408c-97c7-b3fc2f85aae8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Why double integrals measure volume", "Subsubsection",
 CellChangeTimes->{
  3.761573442159267*^9},ExpressionUUID->"1987809c-8014-4897-aa26-\
42ae0bdcda76"],

Cell[TextData[{
 "What is the physical process that confirms that the double integral\n       \
",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[Integral]", 
    RowBox[{
     SubscriptBox["\[Integral]", "R"], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}], "=", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "c", "d"], 
    RowBox[{
     SubsuperscriptBox["\[Integral]", "a", "b"], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}]}]],ExpressionUUID->
  "7fb70ee6-55f5-462d-b26e-19869d8af12c"],
 "\nactually measures the volume of the solid described in part i)?  "
}], "Text",ExpressionUUID->"936b40ca-7554-4832-a17c-fe08a51546a4"],

Cell["Answer:", "Special1",ExpressionUUID->"993acd16-0675-4be5-a172-74911387d689"],

Cell[TextData[{
 "Look at some slices of the solid consisting of everything between the \
surface plotted above and the ",
 Cell[BoxData["xy"],ExpressionUUID->"1fa711b0-1227-47c7-a4b3-5ef604ce6a49"],
 "-plane:"
}], "SmallText",ExpressionUUID->"443f7e11-15dc-40df-83d9-1f380d2b36e2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"slice", ",", "x", ",", "y", ",", "t"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"slice", "[", "y_", "]"}], ":=", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "y", ",", "0"}], "}"}], "+", 
      RowBox[{"t", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         RowBox[{"f", "[", 
          RowBox[{"x", ",", "y"}], "]"}]}], "}"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"jump", "=", 
    FractionBox[
     RowBox[{"d", "-", "c"}], "3"]}], ";"}], "\n"}], "\n", 
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{"fplot", ",", 
     RowBox[{"slice", "[", "y", "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", "c", ",", "d", ",", "jump"}], "}"}]}], "]"}]}], "Input",\

