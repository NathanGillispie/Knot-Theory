50f4bdefd49e"],

Cell[CellGroupData[{

Cell[TextData[{
 "2D integrals ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[Integral]", 
    RowBox[{"\[Integral]", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["\[InvisiblePrefixScriptBase]", 
         AdjustmentBox["R",
          BoxBaselineShift->0.8,
          BoxMargins->{{0, 0}, {-0.8, 0.8}}]], 
        RowBox[{"\[InvisiblePrefixScriptBase]", " ", "f"}]}], "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}], " "}]],ExpressionUUID->
  "2f242909-baa5-4843-b58c-838b49adedc6"],
 " for volume measurements"
}], "Subsubsection",
 CellChangeTimes->{3.761573015736912*^9},
 CellTags->"2.05.B1",ExpressionUUID->"df90bc7d-7285-4b4a-95fb-7117307b8f2e"],

Cell[TextData[{
 "You can plot a surface ",
 Cell[BoxData[
  RowBox[{"z", "=", 
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}]}]],ExpressionUUID->
  "1e4c1706-0c02-4e48-95c3-6a4b73e58fe5"],
 " like this:"
}], "Text",ExpressionUUID->"01a91fbd-25eb-4470-9ca9-6723433cdecc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"f", ",", "x", ",", "y"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"3.1", " ", 
     SuperscriptBox["x", "2"]}], "+", 
    RowBox[{"2.3", " ", 
     SuperscriptBox["y", "2"]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "b"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"c", ",", "d"}], "}"}]}], "}"}], " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "4"}], "}"}]}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"surfaceplot", " ", "=", " ", 
    RowBox[{"Plot3D", "[", 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "a", ",", "b"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "c", ",", "d"}], "}"}]}], "]"}]}], ";"}], "\n", 
  "   "}], "\n", 
 RowBox[{
  RowBox[{"spacer", " ", "=", " ", "0.2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"threedims", " ", "=", " ", "\n", "      ", 
    RowBox[{"Graphics3D", "[", 
     RowBox[{"{", "\n", "            ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Blue", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"a", ",", "0", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"b", ",", "0", ",", "0"}], "}"}]}], "}"}], "]"}]}], 
        "}"}], ",", "\n", "                    ", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<x\>\"", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"b", " ", "+", " ", "spacer"}], ",", "0", ",", "0"}], 
          "}"}]}], "]"}], ",", "\n", "            ", 
       RowBox[{"{", 
        RowBox[{"Blue", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "c", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "d", ",", "0"}], "}"}]}], "}"}], "]"}]}], 
        "}"}], ",", "\n", "                    ", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<y\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", 
           RowBox[{"d", " ", "+", " ", "spacer"}], ",", "0"}], "}"}]}], "]"}],
        ",", "\n", "            ", 
       RowBox[{"{", 
        RowBox[{"Blue", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "50"}], "}"}]}], "}"}], "]"}]}], 
        "}"}], ",", "\n", "                    ", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<z\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", 
           RowBox[{"50", " ", "+", " ", "spacer"}]}], "}"}]}], "]"}]}], "}"}],
      "]"}]}], ";"}], "\n", "                    "}], "\n", 
 RowBox[{"fplot", " ", "=", " ", 
  RowBox[{"Show", "[", 
   RowBox[{"surfaceplot", ",", "threedims", ",", "\n", "        ", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "\n"}], "Input",
 CellChangeTimes->{{3.761573057383958*^9, 3.761573094916205*^9}},
 CellLabel->
  "In[119]:=",ExpressionUUID->"48f169a8-7645-4449-b4fc-75545151a966"],

