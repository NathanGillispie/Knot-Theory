Cell["Animate these.", "Special2",ExpressionUUID->"1098b64f-b393-4287-a89e-57dd48b4fc56"],

Cell[TextData[{
 "The physical process of calculating \n       ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox["\[Integral]", "c", "d"], 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "a", "b"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "400ceca7-9fcd-4885-ac92-a49852fc8153"],
 " \ninvolves two steps.\nFirst step:\nFor each ",
 Cell[BoxData["y"],ExpressionUUID->"11398dab-4a59-4187-ab5f-9c949ed38eac"],
 " with ",
 Cell[BoxData[
  RowBox[{"c", "\[LessEqual]", "y", "\[LessEqual]", "d"}]],ExpressionUUID->
  "374b0011-b0b4-49ca-99e9-b09c7258734d"],
 ", you calculate\n       ",
 Cell[BoxData[
  RowBox[{
   SubsuperscriptBox["\[Integral]", "a", "b"], 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], 
    RowBox[{"\[DifferentialD]", "x"}]}]}]],ExpressionUUID->
  "4604016a-1a7c-46b2-a802-9adefc47d11d"],
 ":"
}], "SmallText",ExpressionUUID->"d189f33c-e633-45a4-a9b7-9ebd9511d498"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"first", ",", "x", ",", "y"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"first", "[", "y_", "]"}], "=", 
  RowBox[{
   SubsuperscriptBox["\[Integral]", "a", "b"], 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], 
    RowBox[{"\[DifferentialD]", "x"}]}]}]}]}], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"175b0925-6c06-41ef-9a52-fd9bdf03353a"],

Cell[BoxData[
 RowBox[{"36.166666666666664`", "\[VeryThinSpace]", "+", 
  RowBox[{"11.5`", " ", 
   SuperscriptBox["y", "2"]}]}]], "Output",
 CellChangeTimes->{
  3.7615733177519493`*^9},ExpressionUUID->"168e94e0-b35a-495c-9e5b-\
10ae3df8e17c"]
}, Open  ]],

Cell[TextData[{
 "As ",
 Cell[BoxData["y"],ExpressionUUID->"85d2a984-a8c6-47bf-aff7-c2efab95baeb"],
 " advances from ",
 Cell[BoxData["c"],ExpressionUUID->"046cc90c-9d2b-4176-b118-79e113aa7afb"],
 " to ",
 Cell[BoxData["d"],ExpressionUUID->"a69ecf1c-74a3-47ce-bd48-49d9c8d786ea"],
 ", ",
 Cell[BoxData[
  RowBox[{"first", "[", "y", "]"}]],ExpressionUUID->
  "b3307926-a868-452b-b957-495a5715ef18"],
 " measures the area of the slices that sweep out the solid. \nFor instance,"
}], "SmallText",ExpressionUUID->"38464aff-b9cf-46ee-b1ce-c33cb0897a8e"],

