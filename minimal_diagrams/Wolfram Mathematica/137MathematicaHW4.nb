Cell[CellGroupData[{

Cell["B. Generalize", "Subsubsection",
 CellChangeTimes->{{3.523805691084187*^9, 3.523805710258966*^9}, {
   3.523901445889201*^9, 3.52390144628507*^9}, {3.525010712629616*^9, 
   3.525010740428034*^9}, {3.525011365373949*^9, 3.525011371910165*^9}, {
   3.5250114177044277`*^9, 3.525011433567017*^9}, {3.5255447708358173`*^9, 
   3.525544783036274*^9}, {3.5262231665807943`*^9, 3.526223168443118*^9}, 
   3.526386314575691*^9, {3.761577071996908*^9, 
   3.761577072492567*^9}},ExpressionUUID->"cd953e40-6037-4a79-9e79-\
0e7f50548f7f"],

Cell[TextData[{
 "The functions ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "i"], TraditionalForm]],ExpressionUUID->
  "e401f738-fe53-4b15-bdd4-8ebce5f21ade"],
 " follow a pattern. What is that pattern?\nWrite down the general formula \
for the pattern.\nWrite a function ",
 StyleBox["uPoly[f,n,a,h] ",
  FontWeight->"Bold"],
 "that given a positive integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "bb2faae4-0890-450c-a536-71d9b6f9c5a4"],
 ",  a number ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "d767fda1-6532-4457-a45d-90e6323e62fd"],
 ", a number ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "1e432240-734d-4b33-a5f7-eafa2a2d0ef0"],
 ", and a function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"f", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "9d0be793-f639-48de-b0bd-e8c454d29f98"],
 " computes the function ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "n"], TraditionalForm]],ExpressionUUID->
  "c077dbe4-5595-472d-bb6e-5d6eb5007af9"],
 " and plots the functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "2f58af9a-1345-4d53-9963-1ec093d03254"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "n"], TraditionalForm]],ExpressionUUID->
  "e3a354d9-2fac-4f0d-9936-b3b58444c748"],
 " together over the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"a", "-", "h"}], ",", 
     RowBox[{"a", "+", "h"}]}], "]"}], TraditionalForm]],ExpressionUUID->
  "c4be0427-dd4d-4a7a-a3c3-7876f1edbd3d"],
 ". \nThe function should be red and thick and the polynomial should be blue \
and not quite so thick.\nGive three examples of different functions to show \
that your code works.\nTwo examples:"
}], "Text",
 CellChangeTimes->{{3.526223196511849*^9, 3.526223363289063*^9}, {
  3.606127322885474*^9, 3.6061274257350273`*^9}, {3.606127932457993*^9, 
  3.606128010698146*^9}, {3.6061280471708717`*^9, 3.6061280501934433`*^9}, {
  3.606128188910479*^9, 3.606128215692762*^9}, {3.636922539187305*^9, 
  3.63692254226299*^9}},ExpressionUUID->"b10fb310-3191-4f6a-a9ab-\
0b8c555ac926"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"x", " ", 
    RowBox[{"Sin", "[", "x", "]"}]}], "-", 
   FractionBox[
    SuperscriptBox["x", "2"], "3"]}]}], "\[IndentingNewLine]", 
 RowBox[{"uPoly", "[", 
  RowBox[{"f", ",", "5", ",", "2", ",", "3"}], "]"}]}], "Input",
 CellChangeTimes->{{3.6061275601992207`*^9, 3.606127600579414*^9}, {
   3.606127885210392*^9, 3.606127921746497*^9}, 
   3.6061279841143436`*^9},ExpressionUUID->"ef065fa2-4231-4430-a4f9-\
bf7fe214a0e0"],

