 "Fancy dudes say that this is the cardiod described in polar coordinates\n \
by the polar equation ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"r", "[", "t", "]"}], "=", 
   RowBox[{"1", "-", 
    RowBox[{"Cos", "[", "t", "]"}]}]}]],ExpressionUUID->
  "5578d582-df9c-4bd1-a463-065e16e67cdb"],
 "."
}], "Special2",ExpressionUUID->"7db25642-ba4c-4a9e-a9cf-811b3af7de53"],

Cell[TextData[{
 "Go with \n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{"3", "+", "y", "-", "x"}]}]],ExpressionUUID->
  "23b3c513-6a05-4863-bc71-d39cf0f7b0c1"],
 "\nand calculate\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "5186aaaf-03d4-4f22-ab4a-6be62d9b3c20"],
 "\nby the method of least labor on your part.\n\nNext, go with\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"g", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{"3", "-", "x"}]}]],ExpressionUUID->
  "f1b9f847-ba58-436c-ab29-276a17517be3"],
 " \nand calculate\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"g", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "8b4070b5-5a2c-4dc6-b965-34a048d22591"],
 "\nby the method of least labor on your part.\n\nCompare the values of\n     \
  ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "c2409a5e-81f7-49cf-b4f5-55e05f2bdbaf"],
 " and ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"g", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "56e943c8-3ed6-442c-a0af-f44bc9e0af1c"],
 ".\nDiscuss how you think that the shape and position of ",
 Cell[BoxData["R"],ExpressionUUID->"a4b56967-a4d4-4a1d-97a3-a98a9cf03536"],
 " account for the relationship between these two numbers."
}], "Text",
 CellChangeTimes->{{3.7616461928356485`*^9, 
  3.7616461951324873`*^9}},ExpressionUUID->"6c378b20-dfc0-44ec-80ac-\
e613a27636f9"],

Cell[TextData[{
 "(iii) Here is another region ",
 Cell[BoxData["R"],ExpressionUUID->"18f8fe90-044c-4812-942c-a93dbbc0314f"],
 " plotted in the ",
 Cell[BoxData["xy"],ExpressionUUID->"6b009f5d-6254-4d09-92f5-ce9e47a0c06f"],
 "-plane."
}], "Text",
 CellChangeTimes->{{3.761576913075338*^9, 
  3.76157691420288*^9}},ExpressionUUID->"6c5ef544-26cb-458f-8c54-\
b4c23d5b494e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"high", ",", "low", ",", "y"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"xhigh", "[", "y_", "]"}], "=", 
   SuperscriptBox["E", 
    RowBox[{"-", 
     SuperscriptBox["y", "2"]}]]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"xlow", "[", "y_", "]"}], "=", 
    RowBox[{"1", "-", 
     SuperscriptBox["y", "2"]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Rplot", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"xhigh", "[", "y", "]"}], ",", "y"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"xlow", "[", "y", "]"}], ",", "y"}], "}"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", "\n", "\t\t", 
    RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", " ", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
    RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
    RowBox[{"Epilog", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"xlow", "[", 
               RowBox[{"-", "2"}], "]"}], ",", 
              RowBox[{"-", "2"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"xhigh", "[", 
               RowBox[{"-", "2"}], "]"}], ",", 
              RowBox[{"-", "2"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"Line", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"xlow", "[", "2", "]"}], ",", "2"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"xhigh", "[", "2", "]"}], ",", "2"}], "}"}]}], "}"}], 
          "]"}]}], "}"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<Top half of R\>\"", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1.7"}], "}"}]}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<Bottom half of R\>\"", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "1.7"}]}], "}"}]}], "]"}]}], "}"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{
  3.7615769234123383`*^9, {3.76164683443653*^9, 3.7616468381546*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"5f2689b0-34e8-4ebc-b68f-7656e7bcd999"],

