Cell[BoxData["Integrate"], "Input",
 CellChangeTimes->{{3.761646853307324*^9, 
  3.761646854727333*^9}},ExpressionUUID->"ef630dac-0073-470d-9fe5-\
2737bb5c109c"],

Cell[TextData[{
 "Go with \n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{"y", " ", 
    SuperscriptBox["E", 
     RowBox[{"-", "x"}]]}]}]],ExpressionUUID->
  "a62bc13b-38cb-4a7c-8dc6-aad6ba6fea0b"],
 "\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"g", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{
    SuperscriptBox["y", "2"], 
    SuperscriptBox["E", 
     RowBox[{"-", "x"}]]}]}]],ExpressionUUID->
  "a42150af-b0de-44f8-ac91-747790944b15"],
 " and\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"h", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{
    SuperscriptBox["y", "3"], 
    SuperscriptBox["E", 
     RowBox[{"-", "x"}]]}]}]],ExpressionUUID->
  "4f260eb1-3571-4e77-96e0-5ffe78d96d6d"],
 " \nand calculate\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "de6e77a3-1f80-424a-9d00-3293a416dc1a"],
 ",\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"g", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "24509ea5-72bb-402a-993e-315531a7e85c"],
 ", and \n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"h", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "915d83d0-5033-4c7f-9bc1-c4df3c81667e"],
 "\nby the method of least labor on your part.\nLook at the formulas for ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y"}], "]"}]],ExpressionUUID->
  "3afe3a73-5ae4-434c-8c93-dd5a9480555d"],
 " and ",
 Cell[BoxData[
  RowBox[{"g", "[", 
   RowBox[{"x", ",", "y"}], "]"}]],ExpressionUUID->
  "eaae30fe-e422-48c0-8323-4521df1f8afc"],
 " and then look at the shape and position of ",
 Cell[BoxData["R"],ExpressionUUID->"b7ce93bc-1971-4c16-9d44-06be5e070c24"],
 " and explain why it was no surprise that\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "77c13747-47f2-4c46-9f52-40eef3b628ff"],
 " and ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"h", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "e5d03b80-28e9-4191-afa3-671729fc4392"],
 " \ncame out the way they did."
}], "Text",ExpressionUUID->"2064ce4f-90e1-45cd-a48e-edc0a931f1f1"],

Cell[TextData[{
 "(iv) Here is another region ",
 Cell[BoxData["R"],ExpressionUUID->"55007281-296a-4fa4-a537-f3c08a4618ce"],
 " plotted in the ",
 Cell[BoxData["xy"],ExpressionUUID->"9d00993d-0f4b-4bfe-a483-2c4b10c659d0"],
 "-plane."
}], "Text",
 CellChangeTimes->{{3.761576948058196*^9, 
  3.761576950217235*^9}},ExpressionUUID->"fad141b5-3bb4-4993-b6a7-\
b4870cd71bc9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"x", ",", "y", ",", "Rplot"}], "]"}], ";"}], "\n", 
 RowBox[{"Rplot", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"3", " ", 
       SuperscriptBox[
