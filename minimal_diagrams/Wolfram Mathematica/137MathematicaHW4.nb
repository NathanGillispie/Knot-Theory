Cell[TextData[{
 "Second step: \nCalculate ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubsuperscriptBox["\[Integral]", "c", "d"], 
    RowBox[{
     RowBox[{"first", "[", "y", "]"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}], "=", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "c", "d"], 
    RowBox[{
     SubsuperscriptBox["\[Integral]", "a", "b"], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}]}]],ExpressionUUID->
  "fcae9bab-9eda-4390-b401-33c3c1cd09fc"],
 ".\nThis second integral sums up the area measurements of the individual \
slices and measures the volume. "
}], "SmallText",ExpressionUUID->"743ba889-eb0b-4eca-a161-4cbb9c0b19f4"],

