Cell[CellGroupData[{

Cell["\<\
C. More examples using the function you generated in part II B.\
\>", "Subsubsection",
 CellChangeTimes->{{3.523805691084187*^9, 3.523805710258966*^9}, {
   3.523901445889201*^9, 3.52390144628507*^9}, {3.525010712629616*^9, 
   3.525010740428034*^9}, {3.525011365373949*^9, 3.525011371910165*^9}, {
   3.5250114177044277`*^9, 3.525011433567017*^9}, {3.5255447708358173`*^9, 
   3.525544783036274*^9}, {3.5262231665807943`*^9, 3.526223168443118*^9}, 
   3.526386314575691*^9, {3.606128232090561*^9, 3.6061282393090887`*^9}, {
   3.7313317941759787`*^9, 3.731331802359743*^9}, {3.761577074868471*^9, 
   3.761577092187847*^9}},ExpressionUUID->"04251837-8b49-441c-8baa-\
fae72b253bfa"],

Cell[TextData[{
 "a) Use the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{"x", " ", 
      RowBox[{"tan", "(", 
       RowBox[{"x", "/", "6"}], ")"}]}], "-", 
     FractionBox["x", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"x", "/", "5"}]]], "+", 
     SqrtBox[
      RowBox[{"ln", "(", 
       RowBox[{"x", "+", "12"}], ")"}]]}]}], TraditionalForm]],
  ExpressionUUID->"4651272c-7f5d-4f71-8596-08ceff5fa042"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "eff403d4-b0c7-4694-907d-3692413de85a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "=", "8"}], TraditionalForm]],ExpressionUUID->
  "1621ccae-5572-448c-958b-7067522b5601"],
 ".\nFind a value of n large enough that when you call the uPoly function you \
see no difference between the the two graphs. If this is not possible then \
show you best attempt and explain what you observe. If it is not possible, \
explain why you think this is not possible. "
}], "Text",
 CellChangeTimes->{{3.606128243862872*^9, 3.606128254461115*^9}, {
   3.606128631540969*^9, 3.606128739637762*^9}, {3.606128805567049*^9, 
   3.606128843903233*^9}, {3.636922727397584*^9, 3.636922748567935*^9}, {
   3.637317984878764*^9, 3.6373179879971404`*^9}, 3.731329713161497*^9, {
   3.731331459317622*^9, 3.731331485100382*^9}, {3.761577116971017*^9, 
   3.761577126594602*^9}},ExpressionUUID->"ea78f44e-96d6-4605-8b45-\
7b576bf67ff2"],

Cell[TextData[{
 "b) Use the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{"x", " ", 
      RowBox[{"cos", "(", 
       RowBox[{"sin", "(", "x", ")"}], ")"}]}], "-", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{".02", "x"}]]}]}], TraditionalForm]],ExpressionUUID->
  "98f4a2c4-3d44-4cce-b2d1-2f1080095334"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "5"}], TraditionalForm]],ExpressionUUID->
  "80d9f242-6702-4432-895a-3eaf439bae85"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "=", "3"}], TraditionalForm]],ExpressionUUID->
  "10559747-67e5-4692-b0fc-19bb906bd499"],
 ".\nFind a value of n large enough that when you call the uPoly function you \
see no difference between the the two graphs.  If this is not possible then \
show you best attempt and explain what you observe. If it is not possible, \
explain why you think this is not possible. \n\nc) Use the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{"ln", "(", "x", ")"}], "-", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{".02", "x"}]]}]}], TraditionalForm]],ExpressionUUID->
  "311f3e46-8edc-40c0-8b15-b13bcc2b7c0e"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "2"}], TraditionalForm]],ExpressionUUID->
  "188be196-348f-4d2e-ad01-07bc26410755"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "=", "3"}], TraditionalForm]],ExpressionUUID->
  "a3563ff9-0089-4367-9756-aa18fe689835"],
 ".\nFind a value of n large enough that when you call the uPoly function you \
see no difference between the the two graphs.  If this is not possible then \
show you best attempt and explain what you observe. If it is not possible, \
explain why you think this is not possible. \n\nd) Use the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["x", "2"], "+", "5"}]]}], TraditionalForm]],
  ExpressionUUID->"df0a6589-2eb1-4bb9-9106-1229f744b16f"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "2e29d841-c164-4850-adcb-603fa3ce05cc"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "=", "5"}], TraditionalForm]],ExpressionUUID->
  "7372056e-112e-498c-bb45-934e8d90b606"],
 ".\nFind a value of n large enough that when you call the uPoly function you \
see no difference between the the two graphs.  If this is not possible then \
show you best attempt and explain what you observe. If it is not possible, \
explain why you think this is not possible. "
}], "Text",
 CellChangeTimes->{{3.606128243862872*^9, 3.606128254461115*^9}, {
  3.606128631540969*^9, 3.606128798239955*^9}, {3.606128848600904*^9, 
  3.606128849008511*^9}, {3.731329730084029*^9, 3.731329731349724*^9}, {
  3.731331408400154*^9, 3.73133144921612*^9}, {3.731331499884808*^9, 
  3.731331532355199*^9}, {3.761577136213079*^9, 3.76157714234109*^9}, {
  3.761577175533696*^9, 
  3.761577178600758*^9}},ExpressionUUID->"926d9856-109a-42cb-908e-\
58e94b25aa98"],

Cell[TextData[{
 "e) Use the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "100"], 
      SuperscriptBox["x", "6"]}], "-", 
     RowBox[{
      FractionBox["3", "100"], 
      SuperscriptBox["x", "5"]}], "+", 
     RowBox[{
      FractionBox["1", "20"], 
      SuperscriptBox["x", "4"]}], "-", 
     RowBox[{
      FractionBox["1", "10"], 
      SuperscriptBox["x", "3"]}], "+", 
     RowBox[{
      FractionBox["1", "5"], 
      SuperscriptBox["x", "2"]}], "+", "x", "-", "100"}]}], TraditionalForm]],
  ExpressionUUID->"a57840ab-ca12-4b34-af08-36704e6fa85d"],
 "\nCompute the functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], ",", 
    SubscriptBox["y", "2"], ",", 
    RowBox[{
     SubscriptBox["y", 
      RowBox[{"3", ",", 
       RowBox[{"...", ".."}]}]], " ", 
     RowBox[{
      SubscriptBox["y", 
       RowBox[{"n", ",", "...", " "}]], "."}]}]}], TraditionalForm]],
  ExpressionUUID->"bf061301-318c-4941-920b-5f504297b035"],
 " Choose any a-value you like and simplify you answer for each function.\n\
What do you observe?"
}], "Text",
 CellChangeTimes->{{3.606128243862872*^9, 3.606128254461115*^9}, {
  3.606128631540969*^9, 3.606128798239955*^9}, {3.606128848600904*^9, 
  3.606128849008511*^9}, {3.636932685374457*^9, 3.636932718110159*^9}, {
  3.636932797252199*^9, 3.636932933244533*^9}, {3.636933013875538*^9, 
  3.636933015539132*^9}, {3.636933867782069*^9, 3.636933890989709*^9}, {
  3.731331534818398*^9, 
  3.7313315381702414`*^9}},ExpressionUUID->"4e9a4fcd-b71d-44f9-9513-\
23f2d59f56b8"]
}, Closed]],

Cell[CellGroupData[{

Cell["D. Approximate two values of trig functions", "Subsubsection",
 CellChangeTimes->{{3.523805691084187*^9, 3.523805710258966*^9}, {
   3.523901445889201*^9, 3.52390144628507*^9}, {3.525010712629616*^9, 
   3.525010740428034*^9}, {3.525011365373949*^9, 3.525011371910165*^9}, {
   3.5250114177044277`*^9, 3.525011433567017*^9}, {3.5255447708358173`*^9, 
   3.525544783036274*^9}, {3.5262231665807943`*^9, 3.526223168443118*^9}, 
   3.526386314575691*^9, {3.606128232090561*^9, 3.6061282393090887`*^9}, {
   3.731331546930868*^9, 3.731331554441526*^9}, 3.7313317856247997`*^9, {
   3.761577227414464*^9, 
   3.761577235678141*^9}},ExpressionUUID->"1634d7cb-d020-4bc6-9693-\
eda3526e2c4d"],

Cell[TextData[{
 "For a suitable choice of a, we can evaluate trig-functions without \
difficulty, examples are ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"a", "=", "0"}], ",", " ", 
    RowBox[{"\[Pi]", "/", "6"}], ",", " ", 
    RowBox[{
     RowBox[{"\[Pi]", "/", "4"}], "..."}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "f804bf5c-fa59-42ef-b69d-719b6eaf0656"]
}], "Text",
 CellChangeTimes->{{3.7313315668568163`*^9, 
  3.731331643342038*^9}},ExpressionUUID->"2a1886e3-1c4e-4608-a419-\
c01e2a23da0c"],

Cell[TextData[{
 "a) You want to compute sin(2) with a forty digits of precision\nUse one of \
the functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], ",", 
    SubscriptBox["y", "2"], ",", 
    RowBox[{
     SubscriptBox["y", 
      RowBox[{"3", ",", 
       RowBox[{"...", ".."}]}]], " ", 
     SubscriptBox["y", 
      RowBox[{"n", ",", "...", " "}]]}]}], TraditionalForm]],ExpressionUUID->
  "16a31d2c-491d-4b8f-94ac-2484d0f211c5"],
 " with a suitable a-value of your choice to compute cos(2) with this \
precision.\nHere because of your choice of a this can be done in principle \
using only addition/subtraction/multiplication/division.\nHow do you know \
that you have the desired precision?\n\nb) You want to compute cos(10) with a \
fifty digits of precision\nUse one of the functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], ",", 
    SubscriptBox["y", "2"], ",", 
    RowBox[{
     SubscriptBox["y", 
      RowBox[{"3", ",", 
       RowBox[{"...", ".."}]}]], " ", 
     SubscriptBox["y", 
      RowBox[{"n", ",", "...", " "}]]}]}], TraditionalForm]],ExpressionUUID->
  "0f00fb53-6365-4574-98a0-dcf159802962"],
 " with a suitable a-value of your choice to compute sin(10) with this \
precision.\nHere because of your choice of a this can be done in principle \
using only addition/subtraction/multiplication/division.\nHow do you know \
that you have the desired precision?"
}], "Text",
