Cell[TextData[{
 "You slice from low to high, and this means that you integrate with respect \
to ",
 Cell[BoxData["y"],ExpressionUUID->"1188aa93-6e03-435f-9e9d-7ae83b37db44"],
 " first. This tells you how to set up\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[Integral]", 
    RowBox[{
     SubscriptBox["\[Integral]", "R"], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}], "=", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "3"], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["\[Integral]", 
        RowBox[{"low", "[", "x", "]"}], 
        RowBox[{"high", "[", "x", "]"}]], 
       RowBox[{
        RowBox[{"f", "[", 
         RowBox[{"x", ",", "y"}], "]"}], 
        RowBox[{"\[DifferentialD]", "y"}]}]}], ")"}], 
     RowBox[{"\[DifferentialD]", "x"}]}]}]}]],ExpressionUUID->
  "82d460a7-3505-41de-9233-94799ddfd078"],
 " \nfor calculation: "
}], "SmallText",ExpressionUUID->"1c6d86fe-66fc-4bd6-b5b0-e81bde859285"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "first", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"first", "[", "x_", "]"}], "=", 
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"low", "[", "x", "]"}], 
    RowBox[{"high", "[", "x", "]"}]], 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], 
    RowBox[{"\[DifferentialD]", "y"}]}]}]}]}], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"02cc4070-f5aa-45d2-8f87-e9bc9d1b12f8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"3.1`", " ", 
   SuperscriptBox["x", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "2"]}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "3"}], "+", "x"}], ")"}], " ", "x"}], "+", 
     RowBox[{"2", " ", 
      RowBox[{"Sin", "[", 
       FractionBox[
        RowBox[{"\[Pi]", " ", "x"}], "3"], "]"}]}]}], ")"}]}], "+", 
  RowBox[{"2.3`", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "24"]}], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "3"}], "+", "x"}], ")"}], "3"], " ", 
      SuperscriptBox["x", "3"]}], "+", 
     RowBox[{
      FractionBox["8", "3"], " ", 
      SuperscriptBox[
       RowBox[{"Sin", "[", 
        FractionBox[
         RowBox[{"\[Pi]", " ", "x"}], "3"], "]"}], "3"]}]}], 
    ")"}]}]}]], "Output",
 CellChangeTimes->{
  3.7615735873549643`*^9},ExpressionUUID->"66a66381-8a0a-4db4-b98f-\
58dd0f2fd57e"]
}, Open  ]],

Cell[TextData[{
 "You can't use ",
 Cell[BoxData[
 "NIntegrate"],ExpressionUUID->"a94d9bd6-a2fb-4f5a-a7a8-2e685b160d6c"],
 " on the first integral \nbecause the formula for the first integral \
includes an ",
 Cell[BoxData["x"],ExpressionUUID->"4745bcb7-91d4-4486-ba86-849a2c494fa3"],
 ".\nYou can use ",
 Cell[BoxData[
 "NIntegrate"],ExpressionUUID->"a77f981d-2e97-443b-bf2a-a700729e86b5"],
 " on the second integral."
}], "Special2",ExpressionUUID->"c8e66e55-dff8-44d1-998a-413ba21cc231"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"second", "=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"first", "[", "x", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "3"}], "}"}]}], "]"}]}]], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"7a1ccefc-60bb-440f-ba78-bfa91289f038"],

Cell[BoxData["59.82820360316713`"], "Output",
 CellChangeTimes->{
  3.7615735912300463`*^9},ExpressionUUID->"c2b9a9da-693a-4b6d-b453-\
f167a84dc0ae"]
}, Open  ]],

Cell[TextData[{
 "Here's how to get ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to calculate the double integral\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[Integral]", 
    RowBox[{
     SubscriptBox["\[Integral]", "R"], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}], "=", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", "0", "3"], 
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"low", "[", "x", "]"}], 
      RowBox[{"high", "[", "x", "]"}]], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "y"}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}]}]}]],ExpressionUUID->
  "90e61764-4104-438e-975e-fba9ea75abe6"],
 "\nin one sweet instruction with ",
 Cell[BoxData[
 "NIntegrate"],ExpressionUUID->"5bf014f9-8c7d-401c-a2e8-6d9d9905c18c"],
 ": "
}], "SmallText",ExpressionUUID->"1886ed6f-f29d-4f1d-8b4c-f642994de602"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NIntegrate", "[", 
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"low", "[", "x", "]"}], ",", 
     RowBox[{"high", "[", "x", "]"}]}], "}"}]}], "]"}]], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"369b902f-4bc9-48a4-981f-8335de002b90"],

Cell[BoxData["59.82820360259737`"], "Output",
 CellChangeTimes->{
  3.7615735949168587`*^9},ExpressionUUID->"eebfa035-6002-4a2a-aee9-\
469d6337d425"]
}, Open  ]],

Cell["Done.", "SmallText",ExpressionUUID->"8fd4acf4-e460-4bf8-ba2a-6eba3e2e5c8a"],

Cell[TextData[{
 "Here is another little region on the ",
 Cell[BoxData["xy"],ExpressionUUID->"5801c09c-d48e-44b3-b66d-f544d1f15102"],
 "-plane."
}], "Text",ExpressionUUID->"d99293a2-1a51-44c1-ba2f-27ae2f8f45fb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"left", ",", "right", ",", "y"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"left", "[", "y_", "]"}], "=", "y"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"right", "[", "y_", "]"}], "=", 
    RowBox[{"2", "-", 
     SuperscriptBox["y", "2"]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"regionplot", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"left", "[", "y", "]"}], ",", "y"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"right", "[", "y", "]"}], ",", "y"}], "}"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "2"}], ",", "1"}], "}"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"Thickness", "[", "0.01", "]"}]}], "}"}], "}"}]}], ",", 
    RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
    RowBox[{"Epilog", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Text", "[", 
        RowBox[{"\"\<x = left[y]\>\"", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           RowBox[{"-", "0.6"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<x = right[y]\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"1.5", ",", 
           RowBox[{"-", "1"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<R\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", 
           RowBox[{"-", "0.5"}]}], "}"}]}], "]"}]}], "}"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{3.761573664919557*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"8db801d9-b156-4e18-b77b-72d3f201fd8f"],

