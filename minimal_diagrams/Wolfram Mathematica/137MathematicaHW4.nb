Cell[TextData[{
 "Go with \n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{
    RowBox[{"4", "x"}], "-", "y"}]}]],ExpressionUUID->
  "4e78afec-6fc2-4e62-9215-8c96d09b4187"],
 " \nand calculate\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "295a6d1a-bc7c-446c-ae3c-580cb4a9cb31"],
 "\nby the method of least labor on your part."
}], "Text",ExpressionUUID->"24868c25-70db-40e3-8b77-c177ce928630"],

Cell[TextData[{
 "(v) Given that the region ",
 Cell[BoxData["R"],ExpressionUUID->"164e9bb8-23f5-4edf-9262-69fbf0d4de66"],
 " consists of everything inside the ellipse\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      StyleBox[
       FractionBox[
        RowBox[{"x", "+", "3"}], "7"],
       FontSize->16], ")"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      StyleBox[
       FractionBox[
        RowBox[{"y", "-", "1"}], "2"],
       FontSize->16], ")"}], "2"]}], "=", "1"}]],ExpressionUUID->
  "b5104b8f-c875-4d88-a007-089534c0c534"],
 ",\ngo with\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{
    SuperscriptBox["x", "2"], "-", 
    RowBox[{"3", 
     SuperscriptBox["y", "2"]}]}]}]],ExpressionUUID->
  "6fef46e1-c2d2-4fb1-96eb-00ec02e3f4e3"],
 " \nand calculate\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "17bb51b0-a0bf-4b3e-9b48-725824d570f3"],
 "\nby the method of least labor on your part. "
}], "Text",
 CellChangeTimes->{{3.761576972049274*^9, 
  3.7615769735124893`*^9}},ExpressionUUID->"181e738c-f479-4d8d-a258-\
904cebd385a2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Part II A. Getting Started", "Subsubsection",
 CellChangeTimes->{{3.523805691084187*^9, 3.523805710258966*^9}, {
   3.523901445889201*^9, 3.52390144628507*^9}, {3.525010712629616*^9, 
   3.525010740428034*^9}, 3.525011399127145*^9, {3.525544370741808*^9, 
   3.525544385515518*^9}, {3.526222693611931*^9, 3.526222696994268*^9}, {
   3.761577035101907*^9, 
   3.761577069645163*^9}},ExpressionUUID->"1659c639-5945-4787-aecc-\
ad10b2ddf68d"],

Cell[TextData[{
 "Pick a function, that involves a transcendental (trig functions, hyp. trig \
functions, logartihms, or exponentials).\nPick a number ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "06db9abd-2f35-479c-aa89-dd69e40d044a"],
 "\nCompute the following:\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], "=", 
    RowBox[{
     RowBox[{"f", "(", "a", ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "+", "x"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"9c57395e-43a1-403d-b3fc-32dd59040e51"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "2"], "=", 
    RowBox[{
     RowBox[{"f", "(", "a", ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "+", "x"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "2"], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"70604990-9670-45c4-ab98-638733b9f4a2"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "3"], "=", 
    RowBox[{
     RowBox[{"f", "(", "a", ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "+", "x"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "2"], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "6"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "3"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "3", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"ff76b2b1-0841-4b58-b2c4-0fec66b373e9"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "4"], "=", 
    RowBox[{
     RowBox[{"f", "(", "a", ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "+", "x"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "2"], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "6"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "3"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "3", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "24"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "4"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "4", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"a4ec1d4d-d1c1-4f53-a13f-eb047c8b7e38"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "5"], "=", 
    RowBox[{
     RowBox[{"f", "(", "a", ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "+", "x"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "2"], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "6"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "3"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "3", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "24"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "4"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "4", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "120"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "5"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "5", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"38fa8cb2-8084-4d19-84e0-d6e3121c3a17"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "6"], "=", 
    RowBox[{
     RowBox[{"f", "(", "a", ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "+", "x"}], ")"}], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "2"], " ", 
      RowBox[{
       SuperscriptBox["f", "\[Prime]\[Prime]",
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "6"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "3"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "3", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "24"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "4"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "4", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "120"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "5"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "5", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}], "+", 
     RowBox[{
      FractionBox["1", "720"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "a"}], "+", "x"}], ")"}], "6"], " ", 
      RowBox[{
       SuperscriptBox["f", 
        TagBox[
         RowBox[{"(", "6", ")"}],
         Derivative],
        MultilineFunction->None], "(", "a", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"4485c780-0a09-4fd0-a6b4-bb271a9f3fac"],
 "\nPlot the original function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"f", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "834544d7-dd73-4f77-bca6-e5252b8fb03c"],
 " together with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "1"], ",", 
    SubscriptBox["y", "2"], ",", 
    RowBox[{"...", ".."}], ",", 
    SubscriptBox["y", "6"]}], TraditionalForm]],ExpressionUUID->
  "cc5f1342-8a2d-49d2-866b-9aef5f4caeb7"],
 " in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"a", "-", "5"}], ",", 
     RowBox[{"a", "+", "5"}]}], "]"}], TraditionalForm]],ExpressionUUID->
