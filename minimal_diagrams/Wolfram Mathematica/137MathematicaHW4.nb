Cell[TextData[{
 "The region ",
 Cell[BoxData["R"],ExpressionUUID->"30e4eafc-2c3b-4c27-9525-38682eb191ad"],
 " consists of all points between and on the plotted curves. Calculate\n      \
 ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "60ccd2f2-1e61-4557-a019-9ef9df91cf3f"],
 "\nfor\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   SuperscriptBox["E", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "0.4"}], "x"}], " ", "-", " ", 
     RowBox[{"0.3", "y"}]}]]}]],ExpressionUUID->
  "dbb48a60-17c3-48a1-b51e-36437766b45e"],
