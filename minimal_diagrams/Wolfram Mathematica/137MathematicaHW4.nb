  3.761573683682654*^9},ExpressionUUID->"d57be067-5e77-4631-8beb-\
7a7269b95786"]
}, Open  ]],

Cell[TextData[{
 "You slice from left to right, and this means that you integrate with \
respect to ",
 Cell[BoxData["x"],ExpressionUUID->"fb725a93-5113-4833-bc4b-5bc8fb70cf9a"],
 " first. This tells you how to set up\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[Integral]", 
    RowBox[{
     SubscriptBox["\[Integral]", "R"], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}], "=", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", 
     RowBox[{"-", "2"}], "1"], 
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"left", "[", "y", "]"}], 
      RowBox[{"right", "[", "y", "]"}]], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}]}]],ExpressionUUID->
  "a20996cf-9862-4994-bff9-e8c54c4fa510"],
 " \nfor calculation: "
}], "SmallText",ExpressionUUID->"f739ec82-0757-48ec-9ff5-c6743a5923e8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "first", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"first", "[", "y_", "]"}], "=", 
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"left", "[", "y", "]"}], 
    RowBox[{"right", "[", "y", "]"}]], 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], 
    RowBox[{"\[DifferentialD]", "x"}]}]}]}]}], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"a379e05d-001e-488d-8346-79a02cedd819"],

Cell[BoxData[
 RowBox[{
  RowBox[{"2.3`", " ", 
   SuperscriptBox["y", "2"], " ", 
   RowBox[{"(", 
    RowBox[{"2", "-", "y", "-", 
     SuperscriptBox["y", "2"]}], ")"}]}], "+", 
  RowBox[{"3.1`", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       SuperscriptBox["y", "3"], "3"]}], "+", 
     RowBox[{
      FractionBox["1", "3"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"2", "-", 
         SuperscriptBox["y", "2"]}], ")"}], "3"]}]}], ")"}]}]}]], "Output",
 CellChangeTimes->{
  3.7615736891932287`*^9},ExpressionUUID->"c886c1be-1d36-48aa-83c3-\
38010ddd664e"]
}, Open  ]],

Cell[TextData[{
 "You can't use ",
 Cell[BoxData[
 "NIntegrate"],ExpressionUUID->"eaa934db-e82e-4050-984a-89d8305cf43d"],
 " on the first integral \nbecause the formula for the first integral \
includes an ",
 Cell[BoxData["x"],ExpressionUUID->"f8b4d680-bd0f-4c65-a07f-7ad283c4c23a"],
 ".\nYou can use ",
 Cell[BoxData[
 "NIntegrate"],ExpressionUUID->"20d35229-448f-4efb-b447-8e636e455bf7"],
 " on the second integral."
}], "Special2",ExpressionUUID->"c672397b-5ab7-4ca0-be83-da26e3391eab"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"second", "=", 
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"-", "2"}], "1"], 
   RowBox[{
    RowBox[{"first", "[", "x", "]"}], 
    RowBox[{"\[DifferentialD]", "x"}]}]}]}]], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"c5700632-dae5-4423-8820-8d8547e3eabf"],

Cell[BoxData["20.597142857142856`"], "Output",
 CellChangeTimes->{
  3.761573694451952*^9},ExpressionUUID->"26796e1b-3cb5-4fc0-85e4-\
e4bd5ed189ae"]
}, Open  ]],

Cell[TextData[{
 "Here's how to get ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " to calculate the double integral\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[Integral]", 
    RowBox[{
     SubscriptBox["\[Integral]", "R"], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}], "=", 
   RowBox[{
    SubsuperscriptBox["\[Integral]", 
     RowBox[{"-", "2"}], "1"], 
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"left", "[", "y", "]"}], 
      RowBox[{"right", "[", "y", "]"}]], 
     RowBox[{
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}], 
      RowBox[{"\[DifferentialD]", "x"}], 
      RowBox[{"\[DifferentialD]", "y"}]}]}]}]}]],ExpressionUUID->
  "18bd1ada-e92a-4fac-bc51-0180214d7e54"],
 " \nin one sweet instruction: "
}], "SmallText",ExpressionUUID->"a2323875-7076-4a6c-bd4f-de68d45f5a66"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", 
   RowBox[{"-", "2"}], "1"], 
  RowBox[{
   SubsuperscriptBox["\[Integral]", 
    RowBox[{"left", "[", "y", "]"}], 
    RowBox[{"right", "[", "y", "]"}]], 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}], 
    RowBox[{"\[DifferentialD]", "x"}], 
    RowBox[{"\[DifferentialD]", "y"}]}]}]}]], "Input",
 AspectRatioFixed->
  True,ExpressionUUID->"d074acdd-cff6-451f-87d7-a441f9f05640"],

Cell[BoxData["20.597142857142856`"], "Output",
 CellChangeTimes->{
  3.7615736983243513`*^9},ExpressionUUID->"b5635f29-bacd-4125-a273-\
889b2847ab76"]
}, Open  ]],

Cell["Done.", "SmallText",ExpressionUUID->"3b133293-2c99-4306-8faa-7d11db433e85"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Part I Your Calculation of double integrals", "Subsubsection",
 CellChangeTimes->{{3.761576827991027*^9, 3.761576840365375*^9}, {
  3.761577017447875*^9, 3.761577021150867*^9}},
 CellTags->"2.05.G2",ExpressionUUID->"66f01c90-e7fe-4cc9-8581-e36d34ff5113"],

Cell[TextData[{
 "(i) Here's a region ",
 Cell[BoxData["R"],ExpressionUUID->"a08e02f8-1037-48a3-9e75-f5ca291dac21"],
 " plotted in the ",
 Cell[BoxData["xy"],ExpressionUUID->"6adb67dc-ff9b-4bb9-8db0-a5cc68a46666"],
 "-plane."
}], "Text",
 CellChangeTimes->{{3.761576864533227*^9, 
  3.7615768652287493`*^9}},ExpressionUUID->"3c6f8011-00bc-4173-9f16-\
68d8a8de1a40"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "y", "]"}], ";"}], "\n", 
 RowBox[{"Rplot", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"y", " ", 
          RowBox[{"(", 
           RowBox[{"y", "-", "6"}], ")"}]}], "+", "1"}], ",", "y"}], "}"}], 
      ",", 
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"Cos", "[", 
          FractionBox[
           RowBox[{"\[Pi]", " ", "y"}], "6"], "]"}], "2"], ",", "y"}], 
       "}"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "0", ",", "6"}], "}"}], ",", "\n", "\t\t", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Thickness", "[", "0.01", "]"}]}], "}"}], "}"}]}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
    RowBox[{"Epilog", "\[Rule]", 
     RowBox[{"Text", "[", 
      RowBox[{"\"\<R\>\"", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "4"}], ",", "3"}], "}"}]}], "]"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{3.7615768493668528`*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"5de83664-8806-4935-9e6d-1f851fb59f6c"],

Cell[TextData[{
 "Go with \n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x", ",", "y"}], "]"}], "=", 
   RowBox[{"y", "-", "x", "+", "3"}]}]],ExpressionUUID->
  "cb9c536e-7e74-49d3-8fcb-e62da0131c05"],
 " \nand calculate\n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "5d8f681e-fb96-4bd0-ad0e-5622d3d29dbf"],
 "\nby the method of least labor on your part."
}], "Text",ExpressionUUID->"0b57fdc7-83fb-48cb-a4bf-4763f91e0960"],

Cell[TextData[{
 "(ii) Here's another region ",
 Cell[BoxData["R"],ExpressionUUID->"01dd9196-e8cd-4c38-8dd3-512d305294e9"],
 " plotted in the ",
 Cell[BoxData["xy"],ExpressionUUID->"80931731-700b-4a8f-acc8-e1817242e7ab"],
 "-plane."
}], "Text",
 CellChangeTimes->{{3.761576881644638*^9, 
  3.761576884067561*^9}},ExpressionUUID->"9f0273ff-3784-4276-bcec-\
149182f445e1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"x", ",", "y", ",", "t"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"x", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Cos", "[", "t", "]"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"Cos", "[", "t", "]"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"y", "[", "t_", "]"}], "=", 
    RowBox[{
     RowBox[{"Sin", "[", "t", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"Cos", "[", "t", "]"}]}], ")"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Rplot", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], ",", 
      RowBox[{"y", "[", "t", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", 
      RowBox[{"2", " ", "\[Pi]"}]}], "}"}], ",", "\n", "\t\t", 
    RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Thickness", "[", "0.01", "]"}]}], "}"}], "}"}]}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
    RowBox[{"Epilog", "\[Rule]", 
     RowBox[{"Text", "[", 
      RowBox[{"\"\<R\>\"", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "0.5"}], "}"}]}], "]"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{3.7615768748534946`*^9},
 AspectRatioFixed->True,
 CellLabel->"In[82]:=",ExpressionUUID->"abe16556-c7d8-4b95-88dc-de91c09bbf4c"],

