Cell["Answer:", "Special1",ExpressionUUID->"b9bf764c-836a-4d51-ac04-c2f8990707dd"],

Cell[TextData[{
 "Enter the function ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y"}], "]"}]],ExpressionUUID->
  "7a80c6de-c6ec-4ddf-b929-931c328b576f"],
 ":"
}], "SmallText",ExpressionUUID->"af79f866-39ae-4a09-8958-201519cc6cc2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"f", ",", "x", ",", "y"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], "=", 
  SuperscriptBox["E", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "0.4"}], " ", "x"}], "-", 
    RowBox[{"0.3", " ", "y"}]}]]}]}], "Input",
 CellChangeTimes->{3.761573556339094*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"1fa02558-2c31-471d-b176-e1999d001de1"],

Cell[TextData[{
 "To set up \n       ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SubscriptBox["\[Integral]", "R"], 
    RowBox[{
     RowBox[{"f", "[", 
      RowBox[{"x", ",", "y"}], "]"}], 
     RowBox[{"\[DifferentialD]", "x"}], 
     RowBox[{"\[DifferentialD]", "y"}]}]}]}]],ExpressionUUID->
  "8a013574-3d52-417c-84d8-9ec8a3a9e18a"],
 "\nfor calculation, you need a convenient way of slicing ",
 Cell[BoxData["R"],ExpressionUUID->"9b843d7c-8c84-48d8-8913-3d6a8034ea10"],
 ".\nHere's one:"
}], "SmallText",ExpressionUUID->"96db0d63-0ddd-4c08-91b3-ff5a21b8cd2a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"slice", ",", "sliceplot", ",", "x"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"slice", "[", "x_", "]"}], ":=", 
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{"Red", ",", 
      RowBox[{"Thickness", "[", "0.01", "]"}], ",", 
      RowBox[{"Line", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"low", "[", "x", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"high", "[", "x", "]"}]}], "}"}]}], "}"}], "]"}]}], "}"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"sliceplot", "[", "x_", "]"}], ":=", 
    RowBox[{"Show", "[", 
     RowBox[{"regionplot", ",", 
      RowBox[{"slice", "[", "x", "]"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Show", "[", 
  RowBox[{"sliceplot", "[", "1", "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.761573563474041*^9, 3.761573572953566*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"fa6476d4-008c-4f0c-8f96-abd1209c670a"],

