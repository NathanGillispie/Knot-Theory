Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"high", ",", "low", ",", "x"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"high", "[", "x_", "]"}], "=", 
   RowBox[{"2", " ", 
    RowBox[{"Sin", "[", 
     FractionBox[
      RowBox[{"\[Pi]", " ", "x"}], "3"], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"low", "[", "x_", "]"}], "=", 
    RowBox[{
     FractionBox["1", "2"], " ", "x", " ", 
     RowBox[{"(", 
      RowBox[{"x", "-", "3"}], ")"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"regionplot", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"high", "[", "x", "]"}], ",", 
      RowBox[{"low", "[", "x", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "3"}], "}"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", 
        RowBox[{"Thickness", "[", "0.01", "]"}]}], "}"}], "}"}]}], ",", 
    RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
    RowBox[{"Epilog", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Text", "[", 
        RowBox[{"\"\<y = high[x]\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"0.7", ",", "1.5"}], "}"}]}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<y = low[x]\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"2.0", ",", 
           RowBox[{"-", "0.8"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"Text", "[", 
        RowBox[{"\"\<R\>\"", ",", 
         RowBox[{"{", 
          RowBox[{"1.5", ",", "1"}], "}"}]}], "]"}]}], "}"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{3.761573543363645*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"1263005d-414b-416a-9dbc-5cce8dc331c9"],

