Cell[CellGroupData[{

Cell[TextData[StyleBox["II.Sum of Primes", "Subsection"]], "Section",
 CellChangeTimes->{{3.75821546488114*^9, 3.758215506933623*^9}, {
  3.7582156775222816`*^9, 
  3.7582156920866885`*^9}},ExpressionUUID->"c43d3981-09c5-4cbf-a5cb-\
19364f04bbf8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"primeSum", "[", 
    RowBox[{"strt_", ",", "upperbound_"}], "]"}], ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"sum", "=", "0"}], ",", 
       RowBox[{"cnt", " ", "=", " ", "strt"}], ",", 
       RowBox[{"ansList", "=", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"ans", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}], "}"}]}], ",", 
       RowBox[{"i", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"sum", " ", "<", "upperbound"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"sum", "+=", " ", 
          RowBox[{"Prime", "[", "cnt", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"sum", ">", "upperbound"}], ",", 
           RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"PrimeQ", "[", "sum", "]"}], ",", " ", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"AppendTo", "[", 
             RowBox[{"ansList", ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"cnt", "-", "strt", "+", "1"}], ",", "sum"}], "}"}]}],
              "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"cnt", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"i", " ", "\[LessEqual]", " ", 
         RowBox[{"Length", "[", "ansList", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ans", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}], "<", " ", 
            RowBox[{"ansList", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"ans", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "=", " ", 
            RowBox[{"ansList", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"i", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "ans", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.758215695116315*^9, 3.7582157503111944`*^9}, {
   3.75821608742305*^9, 3.7582160880284*^9}, {3.7582166180790415`*^9, 
