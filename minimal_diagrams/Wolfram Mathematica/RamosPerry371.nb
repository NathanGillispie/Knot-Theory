Cell[BoxData["a"], "Input",
 CellChangeTimes->{
  3.758239328456893*^9},ExpressionUUID->"ab73f9f3-1229-4479-bc5b-\
035ce9cb69cf"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
   "creates", " ", "points", " ", "at", " ", "regular", " ", "x", " ", 
    "intervals"}], ",", " ", 
   RowBox[{
   "approximating", " ", "the", " ", "function", " ", "that", " ", "the", " ",
     "points", " ", "are", " ", "plotted", " ", "on", " ", "as", " ", "the", 
    " ", "said", " ", "interval", " ", "decreases"}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.7584238253848753`*^9, 
  3.758423937378793*^9}},ExpressionUUID->"97576ebc-169f-4ae9-8793-\
7992a2d8d42b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"findPoints", "[", 
   RowBox[{"func_", ",", " ", "interval_", ",", " ", "pieces_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"cnt", " ", "=", " ", "0"}], ",", " ", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "distance", " ", "is", " ", "the", " ", "interval", " ", "between", 
        " ", "each", " ", "x", " ", "value"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"distance", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"interval", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "-", 
          RowBox[{"interval", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
        RowBox[{"(", "pieces", ")"}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"list", " ", "=", 
       RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"cnt", "<=", "pieces"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "add", " ", "points", " ", "that", " ", "lie", " ", "on", " ", "the", 
         " ", "function", " ", "to", " ", "a", " ", "list"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"list", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"interval", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "+", 
             RowBox[{"distance", "*", "cnt"}]}], ",", " ", 
            RowBox[{"func", "[", 
             RowBox[{
              RowBox[{"interval", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "+", 
              RowBox[{"distance", "*", "cnt"}]}], "]"}]}], "}"}]}], "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"cnt", "++"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", "list"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.7582384484156065`*^9, 3.758238472706664*^9}, {
  3.758238584813963*^9, 3.7582386046838517`*^9}, {3.7582386588879333`*^9, 
  3.7582387880976806`*^9}, {3.7582388526788607`*^9, 3.7582388940811777`*^9}, {
