Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "returns", " ", "sum", " ", "of", " ", "length", " ", "of", " ", "line", 
    " ", "segments", " ", "between", " ", "points", " ", "from", " ", 
    "findPoints"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"lengthOfCurve", "[", 
    RowBox[{"func_", ",", " ", "interval_", ",", " ", "pieces_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"list", ",", " ", 
       RowBox[{"sum", "=", "0"}], ",", " ", 
       RowBox[{"cnt", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"list", "=", 
       RowBox[{"findPoints", "[", 
        RowBox[{"func", ",", " ", "interval", ",", " ", "pieces"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"cnt", "<", 
         RowBox[{"Length", "[", "list", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "adding", " ", "sum", " ", "from", " ", "each", " ", "distance", " ",
           "to", " ", "total", " ", "sum"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"sum", "=", 
          RowBox[{"sum", "+", 
           RowBox[{"N", "@", 
            RowBox[{"EuclideanDistance", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"list", "[", 
                RowBox[{"[", "cnt", "]"}], "]"}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"list", "[", 
                RowBox[{"[", 
                 RowBox[{"cnt", "+", "1"}], "]"}], "]"}], "}"}]}], 
             "]"}]}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"cnt", "++"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", "sum"}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.7582404019364085`*^9, 3.758240418461914*^9}, {
