Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
  "finding", " ", "the", " ", "length", " ", "of", " ", "the", " ", "arc", 
   " ", "to", " ", "some", " ", "degree", " ", "of", " ", "precision"}], 
  "*)"}]], "Input",
 CellChangeTimes->{{3.7584243207452183`*^9, 3.7584244113877726`*^9}, {
  3.758424481480487*^9, 
  3.758424530476708*^9}},ExpressionUUID->"cbd21393-2d2c-4007-afa6-\
fcbf9e041ac7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"preciselengthOfCurve", "[", 
   RowBox[{"func_", ",", " ", "interval_", ",", " ", "precision_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", "=", "1"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "iterating", " ", "lengthOfCurve", " ", "until", " ", "doubling", " ", 
        "the", " ", "pieces", " ", "changes", " ", "the", " ", "result", " ", 
        "by", " ", "less", " ", "than", " ", 
        SuperscriptBox["10", 
         RowBox[{"-", "precision"}]]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"lengthOfCurve", "[", 
           RowBox[{"func", ",", " ", "interval", ",", " ", 
            SuperscriptBox["2", "k"]}], "]"}], "-", 
          RowBox[{"lengthOfCurve", "[", 
           RowBox[{"func", ",", " ", "interval", ",", " ", 
            SuperscriptBox["2", 
             RowBox[{"k", "+", "1"}]]}], "]"}]}], "]"}], "<", 
        SuperscriptBox["10", 
         RowBox[{"-", "precision"}]]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"k", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"lengthOfCurve", "[", 
       RowBox[{"func", ",", " ", "interval", ",", " ", 
        SuperscriptBox["2", 
         RowBox[{"k", "+", "1"}]]}], "]"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.758311479895655*^9, 3.7583115102423925`*^9}, {
   3.7583130516057777`*^9, 3.7583130546268597`*^9}, {3.7583131602733135`*^9, 
