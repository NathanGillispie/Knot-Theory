Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "plots", " ", "the", " ", "function", " ", "compared", " ", "to", " ", 
    "the", " ", "list", " ", "generated", " ", "by", " ", "findPoints"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"showLinesegments", "[", 
    RowBox[{"func_", ",", " ", "interval_", ",", " ", "pieces_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "set", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"set", "=", 
       RowBox[{"findPoints", "[", 
        RowBox[{"func", ",", " ", "interval", ",", " ", "pieces"}], "]"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"Show", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Plot", "[", 
         RowBox[{
          RowBox[{"func", "[", "x", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", 
            RowBox[{"interval", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
            RowBox[{"interval", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", " ", 
          RowBox[{"PlotStyle", "\[Rule]", "Blue"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"plot", " ", "points", " ", "in", " ", "black"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"ListPlot", "[", 
         RowBox[{"set", ",", " ", 
          RowBox[{"PlotStyle", "\[Rule]", "Black"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "plot", " ", "line", " ", "segments", " ", "connecting", " ", 
          "points", " ", "in", " ", "findPoints"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"ListLinePlot", "[", 
         RowBox[{"set", ",", " ", 
          RowBox[{"PlotStyle", "\[Rule]", "Red"}]}], "]"}]}], 
       "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
