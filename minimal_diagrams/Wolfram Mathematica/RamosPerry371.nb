Cell[TextData[{
 "This graph shows the slant asymptote at y = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "x"}], "-", 
    FractionBox["59", "3"]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "ee50895f-8875-475d-b42a-0fb2aa373310"],
 ", the vertical asymptote at x = 20, and the end behavior. (Slant asymptote \
was graphed because it is less obvious at other scales.)"
}], "Text",
