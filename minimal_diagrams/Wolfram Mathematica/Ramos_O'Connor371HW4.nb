Cell[CellGroupData[{

Cell["\<\
Can You predict the average length of random walk when you increment both \
lower and upper bounds?\
\>", "Section",
 CellChangeTimes->{{3.759730808296848*^9, 
  3.759730880043996*^9}},ExpressionUUID->"76c079bb-b3ea-469a-8623-\
cdb1a758bb5d"],

Cell[CellGroupData[{

Cell["Context/preliminary observation:", "Subsection",
 CellChangeTimes->{{3.759649937424754*^9, 
  3.759649950318709*^9}},ExpressionUUID->"a2a0df17-a616-48e1-826c-\
99071f1dd149"],

Cell["this time i don\[CloseCurlyQuote]t believe the line will be linear", \
"Text",
 CellChangeTimes->{{3.7596499560979805`*^9, 
  3.7596499710186634`*^9}},ExpressionUUID->"5f99bc4b-8728-4697-b6e3-\
95cc5ca98022"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1.Data Collection", "Subsection",
 CellChangeTimes->{{3.759647340335268*^9, 3.7596473467763243`*^9}, {
  3.759647389862994*^9, 3.759647394391805*^9}, {3.759649925759671*^9, 
  3.7596499292221394`*^9}},ExpressionUUID->"6b8c0b00-8da7-43f8-8aae-\
e7e526484b00"],

Cell[BoxData[
 RowBox[{
  RowBox[{"avgLengthRandomWalk", "[", 
   RowBox[{"lower_", ",", "upper_", ",", "start_", ",", "iterations_"}], 
   "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sum", "=", "0"}], ",", 
      RowBox[{"i", "=", "1"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"i", "\[LessEqual]", "iterations"}], ",", 
       RowBox[{
        RowBox[{"sum", "+=", 
         RowBox[{"lengthRandomWalk", "[", 
          RowBox[{"lower", ",", "upper", ",", "start"}], "]"}]}], ";", 
        RowBox[{"i", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"N", "[", 
       RowBox[{"sum", "/", "iterations"}], "]"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.7597264402682137`*^9, 3.75972645066342*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"b9451b8d-e0e3-4aaa-98ad-c5a21dc41647"],

Cell[BoxData[
 StyleBox[
  RowBox[{
   RowBox[{"lengthRandomWalk", "[", 
    RowBox[{"lower_", ",", " ", "upper_", ",", " ", "start_"}], "]"}], ":=", 
   " ", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"y", " ", "=", " ", "start"}], ",", 
       RowBox[{"counter", " ", "=", " ", "0"}], ",", " ", 
       RowBox[{"ListOfPoints", " ", "=", " ", 
        RowBox[{"List", "[", "]"}]}], ",", " ", 
       RowBox[{"x", "=", " ", "0"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "<", " ", "upper"}], " ", "&&", " ", 
         RowBox[{"y", " ", ">", " ", "lower"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Append", " ", "points", " ", "to", " ", "the", " ", "list", " ", 
          "until", " ", "one", " ", "of", " ", "the", " ", "bounds", " ", 
          "is", " ", 
          RowBox[{"reached", "."}]}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{"ListOfPoints", ",", " ", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"x", "++"}], ";", "\[IndentingNewLine]", 
         RowBox[{"y", "=", " ", 
          RowBox[{"y", "+", 
           RowBox[{"RandomChoice", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Append", " ", "the", " ", "final", " ", "point"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"ListOfPoints", ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Return", " ", "length", " ", "of", " ", "walk"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"Length", "[", "ListOfPoints", "]"}], "-", "1"}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}],
  FontWeight->"Bold"]], "Input",
 FontSize->12,
 CellLabel->"In[64]:=",ExpressionUUID->"8c06f471-9465-4e06-a753-a639397a3a9f"],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.7597265335846186`*^9, 
  3.75972653532001*^9}},ExpressionUUID->"6ab72f8c-a4a3-4034-8383-\
3f06ab41bf53"],

