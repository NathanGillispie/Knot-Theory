Cell[CellGroupData[{

Cell["3. Conjectures/observation", "Subsection",
 CellChangeTimes->{{3.759644986784017*^9, 3.7596450049466825`*^9}, {
  3.759645044754163*^9, 
  3.7596450461826153`*^9}},ExpressionUUID->"2c532640-da4c-423b-bb49-\
0b661a2a23b1"],

Cell["\<\
(i) the data looks like the line y = -x
(ii) it does not look as linear when the upper is close to start that is due \
to less iterations of the random function when they are closer.
(iii) In ListLinePlot you can see that as lower is higher the line gets \
closer to touching 0 when upper = 15\
\>", "Text",
 CellChangeTimes->{{3.7596450512915893`*^9, 3.7596450958929405`*^9}, {
   3.7596451607826085`*^9, 3.7596452221906443`*^9}, 3.7596452558837323`*^9, {
   3.759645286316142*^9, 
   3.759645430420905*^9}},ExpressionUUID->"e30f700b-0740-4d4c-99bf-\
da0f491c0529"]
}, Open  ]],

