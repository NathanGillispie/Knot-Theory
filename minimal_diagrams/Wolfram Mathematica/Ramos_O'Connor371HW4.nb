Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "prints", " ", "text", " ", "after", " ", "offset", " ", "characters"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"offsetPrint", "[", 
    RowBox[{"offset_", ",", "character_", ",", "text_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"str", "=", "\"\<\>\""}], ",", " ", 
       RowBox[{"i", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"i", "\[LessEqual]", "offset"}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"concatenates", " ", "character"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"str", "=", 
          RowBox[{"str", "<>", "character"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"i", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"concatenates", " ", "text"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"str", "=", 
       RowBox[{"str", "<>", "text"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "str", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
