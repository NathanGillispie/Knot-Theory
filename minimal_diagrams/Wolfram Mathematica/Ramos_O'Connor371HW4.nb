   RowBox[{"AppendTo", "[", 
    RowBox[{"data", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"avgLengthRandomWalk", "[", 
        RowBox[{
         RowBox[{"-", "i"}], ",", "i", ",", "0", ",", "10000"}], "]"}]}], 
      "}"}]}], "]"}]}], "]"}]], "Input",
