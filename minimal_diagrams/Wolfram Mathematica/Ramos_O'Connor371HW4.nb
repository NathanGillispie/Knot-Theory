4ae875f13ec0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   StyleBox[
    RowBox[{"stopPointRandomWalk3D", "[", 
     RowBox[{"lower_", ",", " ", "upper_", ",", " ", "start_"}], "]"}],
    FontWeight->"Bold"], 
   StyleBox[":=",
    FontWeight->"Bold"], 
   StyleBox[" ",
    FontWeight->"Bold"], 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", " ", "=", " ", "0"}], ",", " ", "y", ",", " ", "z", ",", 
       " ", 
       RowBox[{"lowerY", " ", "=", 
        RowBox[{"lower", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{"lowerZ", "=", " ", 
        RowBox[{"lower", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ",", 
       RowBox[{"upperY", " ", "=", " ", 
        RowBox[{"upper", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", " ", 
       RowBox[{"upperZ", " ", "=", " ", 
        RowBox[{"upper", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ",", "  ", 
       RowBox[{"ListOfPoints", "=", 
        RowBox[{"List", "[", "]"}]}], ",", " ", "startPoint3D"}], "}"}], ",", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"y", " ", "=", " ", 
       RowBox[{"start", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"z", " ", "=", " ", 
       RowBox[{"start", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"startPoint3D", " ", "=", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "y", ",", " ", "z"}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"y", "\[NotEqual]", "  ", "upperY"}], " ", "&&", 
          RowBox[{"y", "\[NotEqual]", " ", "lowerY"}], " ", "&&", " ", 
          RowBox[{"z", " ", "\[NotEqual]", "  ", "upperZ"}], "&&", " ", 
          RowBox[{"z", " ", "\[NotEqual]", "  ", "lowerZ"}]}], ")"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "we", " ", "append", " ", "here", " ", "so", " ", "that", " ", "we", 
          " ", "start", " ", "by", " ", "appending", " ", "the", " ", 
          "starting", " ", "point", " ", "to", " ", "the", " ", "list"}], 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{"ListOfPoints", ",", " ", 
           RowBox[{"{", 
            RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"x", "++"}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"y", "=", " ", 
          RowBox[{"y", "+", 
           RowBox[{"RandomChoice", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"z", "=", " ", 
          RowBox[{"z", "+", 
           RowBox[{"RandomChoice", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"ListOfPoints", ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y", ",", "z"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       StyleBox[
        RowBox[{
        "fix", " ", "the", " ", "parameters", " ", "of", " ", "the", " ", 
         "Show", " ", "function"}],
        FontWeight->"Plain"], "*)"}], 
      StyleBox["\[IndentingNewLine]",
       FontWeight->"Plain"], 
      StyleBox[
       RowBox[{"Return", "[", 
        RowBox[{"Last", "[", "ListOfPoints", "]"}], "]"}],
       FontWeight->"Plain"], 
      StyleBox[";",
       FontWeight->"Plain"]}]}], 
    StyleBox["\[IndentingNewLine]",
     FontWeight->"Plain"], 
    StyleBox["\[IndentingNewLine]",
     FontWeight->"Plain"], 
    StyleBox["]",
     FontWeight->"Plain"]}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}]], "Input",
 FontSize->10,
 CellLabel->
  "In[246]:=",ExpressionUUID->"6726b173-67d6-46c2-a979-56096401df4e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"lowerUpper3D", "[", 
   RowBox[{
   "lower_", ",", " ", "upper_", ",", " ", "start_", ",", " ", "repeat_"}], 
   "]"}], ":=", " ", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"iterations", " ", "=", " ", "1"}], ",", " ", 
      RowBox[{"upperY", " ", "=", " ", "0"}], ",", " ", 
      RowBox[{"lowerY", " ", "=", " ", "0"}], ",", " ", 
      RowBox[{"upperZ", " ", "=", " ", "0"}], ",", " ", 
      RowBox[{"lowerZ", " ", "=", " ", "0"}], ",", 
      RowBox[{"corner", " ", "=", " ", "0"}], ",", " ", 
      RowBox[{"res", " ", "=", " ", 
       RowBox[{"{", "}"}]}], ",", " ", "a", ",", " ", 
      RowBox[{"cornerCheck", " ", "=", " ", "0"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"iterations", " ", "\[LessEqual]", " ", "repeat"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"a", "=", 
         RowBox[{"stopPointRandomWalk3D", "[", 
          RowBox[{"lower", ",", " ", "upper", ",", " ", "start"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"cornerCheck", " ", "=", " ", "0"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"[", "2", "]"}], "]"}], " ", "\[Equal]", " ", 
           RowBox[{"lower", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"lowerY", "++"}], ";", "\[IndentingNewLine]", 
           RowBox[{"cornerCheck", "++"}], ";"}]}], "\[IndentingNewLine]", 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"[", "2", "]"}], "]"}], " ", "\[Equal]", " ", 
           RowBox[{"upper", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"upperY", "++"}], ";", "\[IndentingNewLine]", 
           RowBox[{"cornerCheck", "++"}], ";"}]}], "\[IndentingNewLine]", 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"[", "3", "]"}], "]"}], " ", "\[Equal]", " ", 
           RowBox[{"lower", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"lowerZ", "++"}], ";", "\[IndentingNewLine]", 
           RowBox[{"cornerCheck", "++"}], ";"}]}], "\[IndentingNewLine]", 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"a", "[", 
            RowBox[{"[", "3", "]"}], "]"}], " ", "\[Equal]", " ", 
           RowBox[{"upper", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"upperZ", "++"}], ";", "\[IndentingNewLine]", 
           RowBox[{"cornerCheck", "++"}], ";"}]}], "\[IndentingNewLine]", 
         "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"cornerCheck", " ", "\[Equal]", " ", "2"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"corner", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"iterations", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"res", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
       "lowerY", ",", " ", "upperY", ",", " ", "lowerZ", ",", " ", "upperZ", 
        ",", " ", "corner"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "res", "]"}]}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 FontSize->10,ExpressionUUID->"cdde33a3-6da1-4d17-bf48-52b028525f4b"],

