Cell[CellGroupData[{

Cell["\<\
Given start, lower and upper. What is the probability that the walk hits \
upper before it hits lower?\
\>", "Section",
 CellChangeTimes->{{3.759650478790764*^9, 3.7596504885981627`*^9}, 
   3.7597312552926836`*^9},ExpressionUUID->"5a25bc10-6ad4-4b79-8b6e-\
2aba8f5a5011"],

Cell[CellGroupData[{

Cell["1. Data collection", "Subsection",
 CellChangeTimes->{{3.759647374759415*^9, 3.7596473821107206`*^9}, {
  3.759648684391182*^9, 
  3.7596487038083873`*^9}},ExpressionUUID->"97f64c45-98b7-46d1-a3c0-\
1974a83e0f0c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Returns", " ", "the", " ", "final", " ", "point", " ", "of", " ", "a", 
    " ", "random", " ", "walk", " ", "which", " ", "starts", " ", "at", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", "start"}], ")"}], " ", "and", " ", "stops", " ", 
    "when", " ", "the", " ", "y", " ", "coordinate", " ", "of", " ", "a", " ",
     "point", " ", "reaches", " ", "one", " ", "of", " ", "the", " ", "inpu", 
    " ", "bounds"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"stopPointRandomWalk", "[", 
    RowBox[{"lower_", ",", " ", "upper_", ",", " ", "start_"}], "]"}], ":=", 
   " ", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"y", " ", "=", " ", "start"}], ",", 
       RowBox[{"counter", " ", "=", " ", "0"}], ",", " ", 
       RowBox[{"ListOfPoints", " ", "=", " ", 
        RowBox[{"List", "[", "]"}]}], ",", " ", 
       RowBox[{"x", "=", " ", "0"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "\[NotEqual]", " ", "upper"}], " ", "&&", " ", 
         RowBox[{"y", " ", "\[NotEqual]", "  ", "lower"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Add", " ", "a", " ", "point", " ", "to", " ", "the", " ", "walk", 
          " ", "as", " ", "long", " ", "as", " ", "y", " ", "is", " ", 
          "within", " ", "bounds"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{"ListOfPoints", ",", " ", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"x", "++"}], ";", "\[IndentingNewLine]", 
         RowBox[{"y", "=", " ", 
          RowBox[{"y", "+", 
           RowBox[{"RandomChoice", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"ListOfPoints", ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Return", " ", "last", " ", "point", " ", "in", " ", "the", " ", 
        "walk"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"Last", "[", "ListOfPoints", "]"}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellChangeTimes->{3.7596192599043865`*^9},
 FontSize->12,
 CellLabel->"In[26]:=",ExpressionUUID->"ab59f6b4-9237-4bc2-a642-d35b420b268f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"countStopOfStopRandomWalk", "[", 
   RowBox[{"lower_", ",", "upper_", ",", "start_", ",", "iterations_"}], 
   "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sum", "=", 
       RowBox[{"List", "[", "]"}]}], ",", 
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"lowerCount", "=", "0"}], ",", 
      RowBox[{"upperCount", "=", "0"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"i", "\[LessEqual]", "iterations"}], ",", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"sum", ",", 
          RowBox[{"stopPointRandomWalk", "[", 
           RowBox[{"lower", ",", "upper", ",", "start"}], "]"}]}], "]"}], ";", 
        RowBox[{"i", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"sum", " ", "=", " ", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Take", "[", 
        RowBox[{"sum", ",", "All", ",", 
         RowBox[{"{", "2", "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lowerCount", "=", " ", 
      RowBox[{"Count", "[", 
       RowBox[{"sum", ",", "lower"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"upperCount", "=", " ", 
      RowBox[{"Count", "[", 
       RowBox[{"sum", ",", "upper"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"lowerCount", ",", "upperCount"}], "}"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.7596193130185547`*^9, 3.7596193192007174`*^9}, {
  3.759619527854169*^9, 3.7596195289006104`*^9}, {3.75961956945543*^9, 
  3.759619616226525*^9}, {3.7596197238376083`*^9, 3.7596197275999823`*^9}, {
  3.759619795959748*^9, 3.759619852324888*^9}, {3.7596202454721994`*^9, 
  3.7596202485317497`*^9}, {3.759620310852365*^9, 3.7596204263494396`*^9}, {
  3.759620541107952*^9, 3.7596205894091225`*^9}, {3.7596206303762627`*^9, 
  3.7596206668746696`*^9}, {3.7596210959961166`*^9, 3.7596211399952946`*^9}, {
  3.7596211825915112`*^9, 3.759621208089959*^9}, {3.75962125151291*^9, 
  3.759621351468701*^9}, {3.759621398709446*^9, 3.7596214028162527`*^9}, {
