Cell[BoxData[
 RowBox[{
  RowBox[{"countStopOfModStopRandomWalk", "[", 
   RowBox[{
   "lower_", ",", "upper_", ",", "probToStay_", ",", "start_", ",", 
    "iterations_"}], "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sum", "=", 
       RowBox[{"List", "[", "]"}]}], ",", 
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"lowerCount", "=", "0"}], ",", 
      RowBox[{"upperCount", "=", "0"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"i", "\[LessEqual]", "iterations"}], ",", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"sum", ",", 
          RowBox[{"modStopPointRandomWalk", "[", 
           RowBox[{"lower", ",", "upper", ",", "probToStay", ",", "start"}], 
           "]"}]}], "]"}], ";", 
        RowBox[{"i", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"sum", " ", "=", " ", 
      RowBox[{"Flatten", "[", 
       RowBox[{"Take", "[", 
        RowBox[{"sum", ",", "All", ",", 
         RowBox[{"{", "2", "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lowerCount", "=", " ", 
      RowBox[{"Count", "[", 
       RowBox[{"sum", ",", "lower"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"upperCount", "=", " ", 
      RowBox[{"Count", "[", 
       RowBox[{"sum", ",", "upper"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"lowerCount", ",", "upperCount"}], "}"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
