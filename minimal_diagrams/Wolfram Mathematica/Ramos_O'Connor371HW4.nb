Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "is", " ", "passed", " ", "a", " ", "list", " ", "of", " ", "spaces", " ", 
    "and", " ", "prints", " ", "the", " ", "text", " ", "out", " ", "after", 
    " ", "each", " ", "space", " ", "element"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"verticalTrace", "[", 
    RowBox[{
    "func_", ",", " ", "text_", ",", " ", "lines_", ",", " ", "lower_", ",", 
     " ", "upper_", ",", " ", "maxBlanks_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"yList", "=", 
        RowBox[{"createSpaceLst", "[", 
         RowBox[{
         "func", ",", " ", "lower", ",", " ", "upper", ",", " ", "lines", ",",
           " ", "maxBlanks"}], "]"}]}], ",", " ", 
       RowBox[{"cnt", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"cnt", "\[LessEqual]", "lines"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"offsetPrint", "[", 
         RowBox[{
          RowBox[{"yList", "[", 
           RowBox[{"[", "cnt", "]"}], "]"}], ",", " ", "\"\< \>\"", ",", " ", 
          "text"}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"cnt", "++"}]}]}], "\[IndentingNewLine]", "]"}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 InitializationCell->True,
