Cell[CellGroupData[{

Cell["Final Conjecture", "Subsection",
 CellChangeTimes->{{3.759647517834734*^9, 
  3.7596475211977997`*^9}},ExpressionUUID->"0d73da7a-e81c-405a-aa9c-\
6d7ca4aa7cd2"],

Cell[TextData[{
 "When you increment the bounds the length of random walk goes up \
exponentially. The equation for this is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    SuperscriptBox["x", "2"]}], TraditionalForm]],ExpressionUUID->
  "0727acd2-9c17-4882-814e-e5a86be86df7"]
}], "Text",
 CellChangeTimes->{{3.759728111347568*^9, 
  3.759728156858444*^9}},ExpressionUUID->"ada4ef09-560c-408c-9a4b-\
42748607613d"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
ModRandomWalk2D 
Report\
\>", "Title",
 CellChangeTimes->{{3.759731105854246*^9, 3.7597311245244637`*^9}, {
  3.759741987331004*^9, 
  3.7597419907086916`*^9}},ExpressionUUID->"10cb73d4-b39d-48c4-a0a4-\
6bc18343b669"],

Cell[TextData[StyleBox["Eamon O\[CloseCurlyQuote]Connor Alec Ramos", \
"Chapter"]], "Section",
 CellChangeTimes->{{3.7597307503749657`*^9, 
  3.75973076037049*^9}},ExpressionUUID->"166adfe1-42f4-41fc-934b-\
a70b9472bd99"],

Cell["\<\
Suppose we choose probability p for staying at the same location. How does \
the length differ when using different bounds?\
\>", "Section",
 CellChangeTimes->{{3.7597320040507517`*^9, 3.759732029668843*^9}, {
  3.7597329804548635`*^9, 3.759733011236026*^9}, {3.759742039620849*^9, 
  3.7597420408256345`*^9}},ExpressionUUID->"bc1fdac8-2776-4f03-839f-\
20e110533447"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["1.Data Collection", "Subsection"]], "Section",
 CellChangeTimes->{{3.75973094438066*^9, 
  3.7597309608349104`*^9}},ExpressionUUID->"01027985-116c-40f8-8525-\
4ea3e17e1ac2"],

Cell[BoxData[
 RowBox[{
  StyleBox[
   RowBox[{"(*", 
    RowBox[{
    "Outputs", " ", "the", " ", "final", " ", "point", " ", "of", " ", "a", 
     " ", "modStopRandomWalk"}], "*)"}],
   FontWeight->"Bold"], 
  StyleBox["\[IndentingNewLine]",
   FontWeight->"Bold"], 
  RowBox[{
   StyleBox[
    RowBox[{"modStopPointRandomWalk", "[", 
     RowBox[{
     "lower_", ",", " ", "upper_", ",", " ", "probToStay_", ",", " ", 
      "start_"}], "]"}],
    FontWeight->"Bold"], 
   StyleBox[":=",
    FontWeight->"Bold"], 
   StyleBox[" ",
    FontWeight->"Bold"], 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PointList", " ", "=", " ", 
        RowBox[{"List", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "start"}], "}"}], "]"}]}], ",", " ", 
       RowBox[{"count", " ", "=", " ", "1"}], ",", " ", 
       RowBox[{"y", " ", "=", " ", "start"}], ",", " ", 
       RowBox[{"x", " ", "=", " ", "0"}], ",", " ", "RealNum"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"1", ">", "0"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"RealNum", " ", "=", " ", 
          RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"first", ",", " ", 
           RowBox[{
           "check", " ", "if", " ", "the", " ", "point", " ", "is", " ", 
            "staying", " ", "at", " ", "the", " ", "same", " ", "y", " ", 
            "coordinate"}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
           "0", "\[LessEqual]", " ", "RealNum", " ", "<", " ", "probToStay"}],
            ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"x", "++"}], ";", "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"PointList", ",", " ", 
              RowBox[{"{", 
               RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{"now", ",", " ", 
             RowBox[{
             "check", " ", "if", " ", "the", " ", "point", " ", "is", " ", 
              "at", " ", "one", " ", "of", " ", "the", " ", "bounds"}]}], 
            "*)"}], "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Last", "[", 
                RowBox[{"Last", "[", "PointList", "]"}], "]"}], " ", 
               "\[Equal]", " ", "upper"}], " ", "||", " ", 
              RowBox[{
               RowBox[{"Last", "[", 
                RowBox[{"Last", "[", "PointList", "]"}], "]"}], " ", 
               "\[Equal]", " ", "lower"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
              "Return", " ", "the", " ", "final", " ", "point", " ", "if", 
               " ", "a", " ", "bound", " ", "is", " ", "reached"}], "*)"}], 
             "\[IndentingNewLine]", 
             RowBox[{"Return", "[", 
              RowBox[{"Last", "[", "PointList", "]"}], "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"x", "++"}], ";", "\[IndentingNewLine]", 
              RowBox[{"y", " ", "=", " ", 
               RowBox[{"y", "+", " ", 
                RowBox[{"RandomChoice", "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"PointList", ",", " ", 
                RowBox[{"{", 
                 RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}]}], 
            "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"count", "++"}]}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellChangeTimes->{3.7597325836118355`*^9},
 FontSize->10,
 CellLabel->"In[96]:=",ExpressionUUID->"946cefbc-71cf-49bd-b05a-d5c0e62ea8ca"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "For", " ", "a", " ", "modRandom", " ", "walk", " ", "starting", " ", 
     "at", " ", 
     RowBox[{"(", 
      RowBox[{"0", ",", "start"}], ")"}], " ", "whose", " ", "y", " ", 
     "coordinate", " ", "never", " ", "leaves", " ", "the", " ", 
     RowBox[{"interval", " ", "[", 
      RowBox[{"lower", ",", " ", "upper"}], "]"}]}], ",", " ", 
    RowBox[{
    "and", " ", "stops", " ", "when", " ", "the", " ", "bound", " ", "is", 
     " ", "reached"}], ",", " ", 
    RowBox[{"outputs", " ", "the", " ", "list", " ", "of", " ", "points"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"modStopRandomWalk", "[", 
    StyleBox[
     RowBox[{
     "lower_", ",", " ", "upper_", ",", " ", "probToStay_", ",", " ", 
      "start_"}],
     FontWeight->"Bold"], 
    StyleBox["]",
     FontWeight->"Bold"]}], 
   StyleBox[":=",
    FontWeight->"Bold"], 
   StyleBox[" ",
    FontWeight->"Bold"], 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PointList", " ", "=", " ", 
        RowBox[{"List", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "start"}], "}"}], "]"}]}], ",", " ", 
       RowBox[{"count", " ", "=", " ", "1"}], ",", " ", 
       RowBox[{"y", " ", "=", " ", "start"}], ",", " ", 
       RowBox[{"x", " ", "=", " ", "0"}], ",", " ", "RealNum"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"1", ">", "0"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"RealNum", " ", "=", " ", 
          RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"first", ",", " ", 
           RowBox[{
           "check", " ", "if", " ", "the", " ", "point", " ", "is", " ", 
            "staying", " ", "at", " ", "the", " ", "same", " ", "y", " ", 
            "coordinate"}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
           "0", "\[LessEqual]", " ", "RealNum", " ", "<", " ", "probToStay"}],
            ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"x", "++"}], ";", "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"PointList", ",", " ", 
              RowBox[{"{", 
               RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{"now", ",", " ", 
             RowBox[{
             "check", " ", "if", " ", "the", " ", "point", " ", "is", " ", 
              "at", " ", "one", " ", "of", " ", "the", " ", "bounds"}]}], 
            "*)"}], "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"Last", "[", 
              RowBox[{"Last", "[", "PointList", "]"}], "]"}], " ", "is", " ", 
             "probably", " ", "the", " ", "same", " ", "as", " ", 
             RowBox[{
              RowBox[{"Last", "[", "PointList", "]"}], "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "*)"}], "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Last", "[", 
                RowBox[{"Last", "[", "PointList", "]"}], "]"}], " ", 
               "\[Equal]", " ", "upper"}], " ", "||", " ", 
              RowBox[{
               RowBox[{"Last", "[", 
                RowBox[{"Last", "[", "PointList", "]"}], "]"}], " ", 
               "\[Equal]", " ", "lower"}]}], ",", "\[IndentingNewLine]", 
             "\[IndentingNewLine]", 
             RowBox[{"Return", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Show", "[", 
                 RowBox[{
                  RowBox[{"ListPlot", "[", 
                   RowBox[{"PointList", ",", " ", 
                    RowBox[{"PlotStyle", " ", "\[Rule]", " ", "Red"}]}], 
                   "]"}], ",", " ", 
                  RowBox[{"ListLinePlot", "[", "PointList", "]"}]}], "]"}], 
                ",", "PointList"}], "}"}], "]"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"x", "++"}], ";", "\[IndentingNewLine]", 
              RowBox[{"y", " ", "=", " ", 
               RowBox[{"y", "+", " ", 
                RowBox[{"RandomChoice", "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"(*", 
               RowBox[{
               "Append", " ", "the", " ", "new", " ", "point", " ", "to", " ",
                 "the", " ", "list"}], "*)"}], "\[IndentingNewLine]", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"PointList", ",", " ", 
                RowBox[{"{", 
                 RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}]}], 
            "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"count", "++"}]}]}], "\[IndentingNewLine]", "]"}], ";"}]}], 
    "\[IndentingNewLine]", "\[IndentingNewLine]", "]"}]}]}]], "Input",
