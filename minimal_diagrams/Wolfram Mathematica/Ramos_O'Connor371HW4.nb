Cell[CellGroupData[{

Cell[TextData[StyleBox["Final Conjecture", "Subsection"]], "Section",
 CellChangeTimes->{
  3.759731157711499*^9},ExpressionUUID->"d9af78c5-ea8b-4271-936b-\
1e6b853ca772"],

Cell["\<\
From this last graph we can more easily see what is going on. It appears to \
be Y=X but once inside of the cluster the equation for the points is 10000- \
x=Y\
\>", "Text",
 CellChangeTimes->{{3.7597357479127665`*^9, 
  3.759735867159529*^9}},ExpressionUUID->"e42231bc-3e85-4c68-a946-\
48a5df807469"]
}, Open  ]],

Cell["\<\
How does the probability of hiting upper differ when we increase upper and \
increase lower but also increase probability of staying?\
\>", "Section",
 CellChangeTimes->{{3.759735998475933*^9, 3.7597360558457427`*^9}, {
  3.7597380417182336`*^9, 
  3.7597380654726796`*^9}},ExpressionUUID->"32b35651-377d-44fc-8deb-\
fc4dfc1bb9cf"],

