 "8000 miles * 5280 feet/mile = 42240000 feet. 300000 feet / 42240000 feet = ",
 Cell[BoxData[
  FormBox[
   FractionBox["5", "704"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "1eb153ea-8ba0-4dfe-9b34-676eb3a2ed0a"],
 ". ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["5", "704"], "*", "10", " ", "inches"}], " ", "=", " ", 
    RowBox[{
     FractionBox["25", 
      RowBox[{"352", " "}]], "inches"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "458af110-4df7-419f-8118-141c88656e39"],
 "."
}], "Text",
 CellChangeTimes->{{3.757522304902958*^9, 
  3.7575224358369303`*^9}},ExpressionUUID->"0bdca762-8d8f-4c52-8358-\
67b2b26f48d7"],

