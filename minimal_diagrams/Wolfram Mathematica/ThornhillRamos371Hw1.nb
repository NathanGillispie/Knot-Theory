   RowBox[{"ArcTan", "[", 
    RowBox[{"1", "/", "x"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.7576409873496904`*^9, 3.7576409988708763`*^9}, {
  3.7577180691769114`*^9, 3.7577180785441008`*^9}},
