Cell[CellGroupData[{

Cell["II. Programming problems", "Subsection",
 CellChangeTimes->{{3.7570040211427364`*^9, 3.7570040315503316`*^9}, {
  3.7570085626504955`*^9, 3.757008563229529*^9}, {3.757122104394593*^9, 
  3.757122105535658*^9}},ExpressionUUID->"2358492f-f23e-4cd2-aaf2-\
360539d7ceb3"],

Cell["1)", "Input",
 CellChangeTimes->{{3.7577178742953224`*^9, 3.7577178806065903`*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"13303406-fb89-4d1f-98c0-4ae61ff9189e"],

Cell["\<\
Our approach to this problem was to first create a helper function, \
squaredDigits, which uses the IntegerDigits function to create a list of the \
digits in the input number. Then, a for loop is used to go through each \
element in the list and square it, adding the squared result of each element \
to a result variable. This result is returned. In the main numberChain \
function, a while loop is used. This while loop calls the squaredDigits \
function until the result of squaredDigits is 1 or 89. The result of each \
iteration of squaredDigits is added to a string, which is returned.\
\>", "Text",
 CellChangeTimes->{{3.7578044605265646`*^9, 
  3.7578046758374195`*^9}},ExpressionUUID->"2c82167f-90f9-4574-9224-\
669088df9354"],

Cell[BoxData[
 RowBox[{
  RowBox[{"numberChain", "[", "num_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"local", " ", "vars", " ", "list"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"squared", " ", "=", " ", "num"}], ",", "\[IndentingNewLine]", 
      RowBox[{"numlist", " ", "=", " ", 
       RowBox[{"ToString", "[", "num", "]"}]}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "while", " ", "loop", " ", "to", " ", "continue", " ", "until", " ", "1",
       " ", "or", " ", "89", " ", "is", " ", "reached"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", "condition", " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"squared", "\[NotEqual]", "89"}], "&&", 
        RowBox[{"squared", "\[NotEqual]", "1"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", "body", " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"squared", " ", "=", " ", 
         RowBox[{"squaredDigits", "[", "squared", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"numlist", " ", "=", " ", 
         RowBox[{"numlist", " ", "<>", "\"\< \>\"", " ", "<>", 
          RowBox[{"ToString", "[", "squared", "]"}]}]}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "numlist", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->"In[11]:=",ExpressionUUID->"88ee6465-8118-4fb2-9245-630db51c9f5e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"squaredDigits", "[", "num_", "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "creating", " ", "list", " ", "of", " ", "digits", " ", "in", " ", "num", 
    " ", "using", " ", "IntegerDigits", " ", "function"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"list", "=", 
     RowBox[{"IntegerDigits", "[", "num", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"result", " ", "variable"}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{"res", "=", "0"}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "using", " ", "for", " ", "loop", " ", "to", " ", "square", " ", "each", 
      " ", "digit", " ", "in", " ", "number"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"For", "[", "\[IndentingNewLine]", 
     RowBox[{"(*", "start", " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", "condition", " ", "*)"}], " ", "\[IndentingNewLine]", 
      RowBox[{"i", " ", "\[LessEqual]", " ", 
       RowBox[{"Length", "[", "list", "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", "update", " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"i", "++"}], ",", " ", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", "body", " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"res", "+=", 
       RowBox[{
        RowBox[{"list", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "^", "2"}]}]}], 
     "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"returning", " ", "new", " ", "number"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"Return", "[", "res", "]"}], ";"}], ")"}]}]], "Input",
 InitializationCell->True,
 CellLabel->"In[12]:=",ExpressionUUID->"50c7a9e4-b063-4ff9-bc71-41b56f50e45d"],

