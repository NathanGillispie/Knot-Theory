 FormatType->
  "TextForm",ExpressionUUID->"bb29209a-6144-46b9-b12f-7325238bccbf"],

Cell[TextData[{
 "This sequence is created by multiplying the previous term by the index of \
the term being created, then subtracting the index of the previous term, \
using the formula ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "n"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "489f581b-02d4-4ef0-bc57-bef9ccc81d7c"],
 "=t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "aa3bc2fd-d43e-49c5-bb14-7e6f3ef1eeb6"],
 "*n - (n-1). Using this formula, the next three terms are 362881, 3628801, \
39916801."
}], "Text",
 CellChangeTimes->{{3.7575187294772034`*^9, 3.757518826497486*^9}, {
  3.757804370675112*^9, 
