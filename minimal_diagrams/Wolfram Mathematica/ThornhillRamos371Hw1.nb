Cell[TextData[{
 "The factorization is in the form of (x-1)",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[Product]", 
     RowBox[{"i", "=", "0"}], 
     RowBox[{
      RowBox[{"2", "n"}], "-", "1"}]], 
    SuperscriptBox["x", 
     SuperscriptBox["2", "i"]]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "6d23d2c4-b2ad-4305-85b7-67d56acd85aa"],
 "."
}], "Text",
