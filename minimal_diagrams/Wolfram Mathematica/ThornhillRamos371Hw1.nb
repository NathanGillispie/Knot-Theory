 FormatType->
  "TextForm",ExpressionUUID->"6a5d92d0-6ded-4bed-b2f0-b6fb2edca26f"],

Cell[TextData[{
 "This sequence is created by doubling the previous term, using the formula t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["", "n"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "c3103313-d86a-43bd-ab7c-1fbc3c5b566f"],
 "=",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "65686a7e-5749-4f7b-ba77-0cf169a459f0"],
 "*2. Using this formula, the next three terms are 384, 768, 1536."
}], "Text",
 CellChangeTimes->{{3.7575181904247646`*^9, 3.757518269876953*^9}, {
  3.7578043293484707`*^9, 
  3.757804352909276*^9}},ExpressionUUID->"0cbb2306-6751-4048-bdc1-\
7844403e5056"],

Cell["ii).", "Input",
 CellChangeTimes->{{3.7575182737013655`*^9, 3.7575182805638046`*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"c5a7fbe0-3b4c-4f06-9618-6ed2056153d1"],

Cell[TextData[{
 "This sequence is created by subtracting 7 from the previous term, using the \
formula ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "n"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "406a15d8-58f5-460f-a361-1fbeb17ceab3"],
 "=",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "6e40d170-aa71-4ab1-bfea-8180152b093c"],
 "-7. Using this formula, the next three terms are -34, -41, -48."
}], "Text",
 CellChangeTimes->{{3.757518283637891*^9, 3.7575183549654307`*^9}, {
  3.7578042671264396`*^9, 
  3.7578043110991907`*^9}},ExpressionUUID->"712a87c1-77b3-4034-8797-\
995cd5c81697"],

Cell["iii).", "Input",
