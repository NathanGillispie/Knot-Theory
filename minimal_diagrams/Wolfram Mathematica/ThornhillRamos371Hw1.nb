  3.757518366076935*^9}},ExpressionUUID->"32f3731a-17a1-4ad7-858f-\
e0487ad38d42"],

Cell[TextData[{
 "This sequence is created by adding one more than was added previously, \
using the formula t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["", "n"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "c7232cac-cb7c-454a-ad59-e668a1c1e55c"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "66574627-1c3f-4fc4-935e-b5564fc552c0"],
 " + n. Using this formula, the next three terms are 57, 68, 79."
}], "Text",
 CellChangeTimes->{{3.757518373071927*^9, 3.7575183862203712`*^9}, {
  3.7575184384551325`*^9, 3.7575184602145414`*^9}, {3.75751849048938*^9, 
  3.757518525796174*^9}, {3.757518574351034*^9, 3.757518585641384*^9}, {
  3.7578041940678983`*^9, 
  3.757804246548808*^9}},ExpressionUUID->"96222ac7-a6f4-4e86-8ea3-\
bdb2829ffe20"],

Cell["iv).", "Input",
 CellChangeTimes->{{3.757518590286542*^9, 3.7575185962668166`*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"11e42ad8-76b8-41cd-821a-50436ed7024c"],

Cell[TextData[{
 "This sequence is created by raising the index of the term to the third \
power, then multiplying it by 2, using the formula ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "n"], "=", 
    RowBox[{"2", 
     SuperscriptBox["n", "3"]}]}], TraditionalForm]],ExpressionUUID->
  "0ea07681-4745-4344-9c66-f121a5c4e047"],
 ". Using this formula, the next three terms are 1024, 1458, 2000."
}], "Text",
 CellChangeTimes->{{3.7575187066274233`*^9, 3.7575187134146757`*^9}, {
  3.757641722526843*^9, 3.7576418310475893`*^9}, {3.75780417406717*^9, 
