Cell["\<\
The statement is true on the interval [-1000, \[Infinity]). 
This is so because as long as x + 1000 produces a positive output,
raising it to the 4th power and then taking the 4th root does not change the \
value.
However, once it becomes negative, raising it to the 4th power removes the \
negative, therefore altering the value.\
\>", "Input",
 CellChangeTimes->{{3.7575167891866302`*^9, 3.757516947387176*^9}, {
  3.7578835638036284`*^9, 
  3.7578835805578194`*^9}},ExpressionUUID->"8cc9f59b-f6a5-4867-95be-\
b9e5eb0c3a88"],

Cell["ii).", "Input",
 CellChangeTimes->{{3.7575170571892633`*^9, 3.757517069984275*^9}},
 FormatType->
  "TextForm",ExpressionUUID->"b0fe2453-c9c8-4890-9ba9-4bcea65086e8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"h", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"Sin", "[", "x", "]"}], "^", "5"}], "*", 
   RowBox[{
    RowBox[{"Cos", "[", "x", "]"}], "^", "5"}]}]}]], "Input",
 CellChangeTimes->{{3.7573676961544313`*^9, 3.7573677022341647`*^9}, {
  3.7573728950097322`*^9, 3.7573728979089785`*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"0a44ec03-495d-4435-905e-e6c10b444033"],

Cell[BoxData[
 RowBox[{
  RowBox[{"l", "[", "x_", "]"}], ":=", 
  FractionBox[
   RowBox[{
    RowBox[{"10", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", "x"}], "]"}]}], "-", 
    RowBox[{"5", 
     RowBox[{"Sin", "[", 
      RowBox[{"6", "x"}], "]"}]}], "+", 
    RowBox[{"Sin", "[", 
     RowBox[{"10", "x"}], "]"}]}], "512"]}]], "Input",
 CellChangeTimes->{{3.7573677060868826`*^9, 3.7573677165937366`*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"7b8796ce-8e16-434f-830b-e9e9f80d35b6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  RowBox[{"l", "[", "x", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.757517137615582*^9, 3.757517148099372*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"4e0f7c09-3b8a-4234-905c-74ba6da8a4c0"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox[
   RowBox[{"Cos", "[", "x", "]"}], "5"], " ", 
  SuperscriptBox[
   RowBox[{"Sin", "[", "x", "]"}], "5"]}]], "Output",
 CellChangeTimes->{{3.7575171445058203`*^9, 3.757517159011724*^9}},
 CellLabel->"Out[21]=",ExpressionUUID->"9773b27b-5a6d-4ea8-9344-0acaa3ee22a0"]
}, Open  ]],

Cell["\<\
The statement is true on the interval (-\[Infinity],\[Infinity]), because \
when simplify is used, it becomes clear that the two functions are \
equivalent. They are the same function.\
\>", "Text",
 CellChangeTimes->{{3.7575171725992975`*^9, 
  3.7575172343232555`*^9}},ExpressionUUID->"28ec9ef9-ae3d-47a2-85fc-\
8c157571da92"],

