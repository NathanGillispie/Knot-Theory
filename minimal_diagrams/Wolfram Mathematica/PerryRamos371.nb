Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "method", " ", "goes", " ", "through", " ", "each", " ", 
    "prime", " ", "sum", " ", "addition", " ", "and", " ", "returns", " ", 
    "the", " ", "longest", " ", "string", " ", "of", " ", "prime", " ", 
    "sums", " ", "that", " ", "are", " ", "lower", " ", "than", " ", "the", 
    " ", "upper", " ", 
    RowBox[{"bound", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"primeSum", "[", 
    RowBox[{"strt_", ",", "upperbound_"}], "]"}], ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"sum", "=", "0"}], ",", 
       RowBox[{"cnt", " ", "=", " ", "strt"}], ",", 
       RowBox[{"ansList", "=", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"ans", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}], "}"}]}], ",", 
       RowBox[{"cnt2", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"sum", " ", "<", "upperbound"}], ",", "            ", 
        RowBox[{"(*", 
         RowBox[{
         "This", " ", "loop", " ", "adds", " ", "all", " ", "the", " ", 
          "primes", " ", "from", " ", "a", " ", "starting", " ", "value", " ",
           "and", " ", "checks", " ", "to", " ", "see", " ", "if", " ", "the",
           " ", "sums", " ", "are", " ", "primes", " ", "and", " ", "if", " ",
           "they", " ", "are", " ", "puts", " ", "them", " ", "in", " ", "a", 
          " ", "list"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"sum", "+=", " ", 
          RowBox[{"Prime", "[", "cnt", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"sum", ">", "upperbound"}], ",", 
           RowBox[{"Break", "[", "]"}]}], "]"}], ";", "        ", 
         RowBox[{"(*", 
          RowBox[{
          "Kills", " ", "the", " ", "loop", " ", "after", " ", "it", " ", 
           "exceeds", " ", "the", " ", "upperbound"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"PrimeQ", "[", "sum", "]"}], ",", " ", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"AppendTo", "[", 
             RowBox[{"ansList", ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"cnt", "-", "strt", "+", "1"}], ",", "sum"}], "}"}]}],
              "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"cnt", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"cnt2", " ", "\[LessEqual]", " ", 
         RowBox[{"Length", "[", "ansList", "]"}]}], ",", "    ", 
        RowBox[{"(*", 
         RowBox[{
         "This", " ", "loop", " ", "checks", " ", "the", " ", "list", " ", 
          "of", " ", "sums", " ", "and", " ", "determines", " ", "which", " ",
           "is", " ", "the", " ", "longest"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ans", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}], "<", " ", 
            RowBox[{"ansList", "[", 
             RowBox[{"[", 
              RowBox[{"cnt2", ",", "1"}], "]"}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"ans", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "=", " ", 
            RowBox[{"ansList", "[", 
             RowBox[{"[", "cnt2", "]"}], "]"}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"cnt2", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "ans", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7584550019786625`*^9, 3.7584550020588565`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"13e5cc5c-e559-4cca-af7d-88c4990c7617"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "method", " ", "runs", " ", "through", " ", "each", " ", 
    "starting", " ", "prime", " ", "running", " ", "the", " ", "primeSum", 
    " ", "of", " ", "each", " ", "starting", " ", "value", " ", "and", " ", 
    "adding", " ", "it", " ", "to", " ", "a", " ", "lst", " ", "and", " ", 
    "returning", " ", "the", " ", "largest", " ", "Prime", " ", "Sum"}], 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{"longestPrimeSum", "[", "upperbound_", "]"}], ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"cnt", "=", " ", "1"}], ",", " ", 
       RowBox[{"ans", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "0"}], "}"}], "}"}]}], ",", " ", 
       RowBox[{"ansList", "=", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"cnt2", "=", "1"}], ",", " ", 
       RowBox[{"Primes", "=", 
        RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"cnt", "\[LessEqual]", " ", "upperbound"}], ",", "          ", 
        RowBox[{"(*", 
         RowBox[{
         "this", " ", "loop", " ", "changes", " ", "the", " ", "starting", 
          " ", "values", " ", "of", " ", "primeSum", " ", "and", " ", 
          "records", " ", "the", " ", "answers", " ", "it", " ", "gets", " ", 
          "back", " ", "into", " ", "a", " ", "list"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Primes", " ", "=", " ", 
          RowBox[{"primeSum", "[", 
           RowBox[{"cnt", ",", "upperbound"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Primes", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "2"}], "]"}], "]"}], "\[Equal]", "0"}], ",", 
           "          ", 
           RowBox[{"(*", 
            RowBox[{
            "Breaks", " ", "the", " ", "loop", " ", "after", " ", "the", " ", 
             "primes", " ", "get", " ", "too", " ", "large", " ", "to", " ", 
             "fit", " ", "in", " ", "the", " ", "upper", " ", "bound"}], 
            "*)"}], "\[IndentingNewLine]", 
           RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"ansList", ",", 
           RowBox[{"{", 
            RowBox[{"cnt", ",", 
             RowBox[{"Primes", "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
             RowBox[{"Primes", "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"cnt", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"cnt2", " ", "\[LessEqual]", " ", 
         RowBox[{"Length", "[", "ansList", "]"}]}], ",", "          ", 
        RowBox[{"(*", 
         RowBox[{
         "Goes", " ", "through", " ", "the", " ", "list", " ", "and", " ", 
          "determines", " ", "which", " ", "one", " ", "is", " ", "the", " ", 
          "longest", " ", "returning", " ", "the", " ", "starting", " ", 
          "position", " ", "the", " ", "amount", " ", "added", " ", 
          "together", " ", "and", " ", "the", " ", "sum"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"ans", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "2"}], "]"}], "]"}], "<", " ", 
            RowBox[{"ansList", "[", 
             RowBox[{"[", 
              RowBox[{"cnt2", ",", "2"}], "]"}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"ans", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "=", " ", 
            RowBox[{"ansList", "[", 
             RowBox[{"[", "cnt2", "]"}], "]"}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"cnt2", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"ans", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.758383352755782*^9, 3.75838336053734*^9}, {
   3.7583841272995725`*^9, 3.7583841831002374`*^9}, {3.7583842863861933`*^9, 
