Cell[CellGroupData[{

Cell["\<\
RandomWalk checking code: i) verify length of list, ii) x from 0 to length,  \
iii)  min and max y coordinates, iv) mod from node to node {1,1} or {1,-1}, \
or {1,0} v) prob for each type of direction\
\>", "Subsubsection",
 CellChangeTimes->{{3.758799159598874*^9, 3.7587992740024176`*^9}, {
  3.7587995725484934`*^9, 3.7587995731015253`*^9}, {3.7587998026616554`*^9, 
