Cell[BoxData[
 RowBox[{
  RowBox[{"verifyReturnTypeAndStructure", "[", 
   RowBox[{"result_", ",", " ", 
    RowBox[{"{", 
     RowBox[{"correctType_", ",", " ", "correctStructure_"}], "}"}]}], "]"}], 
  " ", ":=", " ", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"correctTypes", ",", " ", "errorMsg"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", " ", "[", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"SameQ", "[", 
         RowBox[{
          RowBox[{"Head", "[", "result", "]"}], ",", " ", "correctType"}], 
         "]"}]}], ",", "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{"errorMsg", " ", "=", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"StringJoin", "[", 
            RowBox[{
            "\"\<Error - incorrect type returned; should be a \>\"", ",", " ", 
             RowBox[{"ToString", "[", "correctType", "]"}]}], "]"}], ",", " ",
            "Red"}], "]"}]}], ";", "\[IndentingNewLine]", "\t", 
        RowBox[{"Print", "[", "errorMsg", "]"}], ";", "\[IndentingNewLine]", 
        "\t", 
        RowBox[{"Return", "[", "False", "]"}]}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"correctType", " ", "===", " ", "List"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "check", " ", "type", " ", "of", " ", "each", " ", "list", " ", 
         "element", " ", "in", " ", "result", " ", "against", " ", 
         "correctStructure", " ", "type"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"SameQ", "[", 
           RowBox[{
            RowBox[{"correctStructure", "[", 
             RowBox[{"[", "1", "]"}], "]"}], " ", ",", "\"\<individual\>\""}],
            "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "types", " ", "in", " ", "list", " ", "might", " ", "be", " ", 
            "different"}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"correctTypes", " ", "=", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"SameQ", "[", 
               RowBox[{
                RowBox[{"Head", "[", 
                 RowBox[{"result", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", " ", 
                RowBox[{"Head", "[", 
                 RowBox[{"correctStructure", "[", 
                  RowBox[{"[", 
                   RowBox[{"2", ",", "i"}], "]"}], "]"}], "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", " ", "1", ",", " ", 
                RowBox[{"Length", "[", 
                 RowBox[{"correctStructure", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}]}], "]"}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{
              "\"\<correctStructure \>\"", ",", " ", "correctStructure", ",", 
               " ", "\"\< correctypes \>\"", " ", ",", "correctTypes", ",", 
               " ", "\"\< \>\"", ",", " ", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"Head", "[", 
                  RowBox[{"result", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i", ",", " ", "1", ",", " ", 
                   RowBox[{"Length", "[", 
                    RowBox[{"correctStructure", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], 
               ",", " ", "\"\< \>\"", ",", "\[IndentingNewLine]", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{"Head", "[", 
                  RowBox[{"correctStructure", "[", 
                   RowBox[{"[", 
                    RowBox[{"2", ",", "i"}], "]"}], "]"}], "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i", ",", " ", "1", ",", " ", 
                   RowBox[{"Length", "[", 
                    RowBox[{"correctStructure", "[", 
                    RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}]}], "]"}]}],
               "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
           RowBox[{"If", " ", "[", 
            RowBox[{
             RowBox[{"!", " ", 
              RowBox[{"Apply", "[", 
               RowBox[{"And", ",", "correctTypes"}], "]"}]}], ",", 
             "\[IndentingNewLine]", "\t", 
             RowBox[{
              RowBox[{"errorMsg", "=", 
               RowBox[{"Style", "[", 
                RowBox[{
                "\"\<Error - incorrect types of list elements in result\>\"", 
                 ",", " ", "Red"}], "]"}]}], ";", "\[IndentingNewLine]", "\t", 
              RowBox[{"Print", "[", "errorMsg", "]"}], ";", 
              "\[IndentingNewLine]", "\t", 
              RowBox[{"Return", "[", "False", "]"}]}]}], 
            "\[IndentingNewLine]", " ", "]"}], ";"}], ",", 
          "\[IndentingNewLine]", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{"else", " ", "-", " ", 
            RowBox[{
            "not", " ", "individual", " ", "structure", " ", 
             "\[IndentingNewLine]", "all", " ", "elements", " ", "should", 
             " ", "have", " ", "the", " ", "same", " ", "structure", " ", 
             "as", " ", "the", " ", "one", " ", "given"}]}], " ", "*)"}], 
          "\[IndentingNewLine]", " ", 
          RowBox[{
           RowBox[{
           "Print", "[", 
            "\"\<repetitive structures are NOT INCLUDED SO FAR INTO TESTING \
HARNESS\>\"", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"Style", "[", 
          RowBox[{"\"\<Correct types\>\"", ",", " ", "Blue"}], "]"}], "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "True", "]"}], ";"}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<Correct types\>\"", ",", " ", "Blue"}], "]"}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "True", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7587478893885436`*^9, 3.7587480822425737`*^9}, {
   3.7587481144354153`*^9, 3.7587484540588408`*^9}, {3.7587486140779934`*^9, 
   3.7587486303069215`*^9}, {3.7587487655106544`*^9, 3.758748786774871*^9}, {
   3.7587489647140484`*^9, 3.7587490781745377`*^9}, {3.7587491222680597`*^9, 
   3.7587491278583803`*^9}, {3.758749684202201*^9, 3.758749791738352*^9}, {
   3.7587499006465807`*^9, 3.7587499229538565`*^9}, {3.7587499620760946`*^9, 
