Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "find", " ", "function", " ", "names", " ", "existing", " ", "in", " ", 
    "kernel", " ", "which", " ", "matches", " ", "the", " ", "given", " ", 
    "pattern"}], " ", "*)"}], 
  RowBox[{
   RowBox[{"findPossibleName", "[", 
    RowBox[{"functionName_", ",", "pattern_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "possibleNames", ",", "distances", " ", ",", "bestMatch", " ", ",", 
       "x"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"possibleNames", "=", " ", 
       RowBox[{"Names", "[", "pattern", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"distances", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"item", ",", " ", 
           RowBox[{"EditDistance", "[", 
            RowBox[{"item", ",", " ", "functionName"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"item", ",", " ", "possibleNames"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"bestMatch", "=", 
       RowBox[{"possibleNames", "[", 
        RowBox[{"[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Position", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"x", "=", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"Part", "[", 
                 RowBox[{"item", ",", "2"}], "]"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"item", ",", " ", "distances"}], "}"}]}], "]"}]}], 
             ";", "x"}], ",", " ", 
            RowBox[{"Min", "[", "x", "]"}]}], " ", "]"}], "]"}], "]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "bestMatch", "]"}], " ", "<", " ", "1"}], 
        "\[IndentingNewLine]", ",", " ", 
        RowBox[{"Return", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"bestMatch", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
