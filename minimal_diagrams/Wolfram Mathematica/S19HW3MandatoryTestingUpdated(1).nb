3a219a138048"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "check", " ", "basis", " ", "features", " ", "of", " ", "the", " ", 
    "random", " ", "walk", " ", "in", " ", "2", "D"}], " ", "*)"}], 
  RowBox[{
   RowBox[{"checkRandomWalkResult", "[", 
    RowBox[{"resultLst_", ",", " ", 
     RowBox[{"{", 
      RowBox[{
      "targetLength_", ",", " ", "targetMin_", ",", " ", "targetMax_"}], 
      "}"}], ",", " ", "straightProb_"}], "]"}], ":=", 
   RowBox[{"Module", " ", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"distances", ",", " ", "talliedDistances", ",", " ", 
       RowBox[{"allowedDistances", "=", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", "1"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ",", 
       "\[IndentingNewLine]", "result", ",", " ", 
       RowBox[{"probLst", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"0.5", ",", " ", "0.5"}], "}"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"check", " ", "length", " ", "and", " ", "range"}], " ", "*)"}],
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"checkRandomWalkLengthRange", "[", 
          RowBox[{"resultLst", ",", " ", "targetLength"}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "False", "]"}]}], "\[IndentingNewLine]", "]"}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"are", " ", "y"}], "-", 
        RowBox[{"values", " ", "between", " ", "min", " ", "and", " ", 
         RowBox[{"max", "?"}]}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", " ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Min", "[", 
           RowBox[{"resultLst", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], "<", " ", 
          "targetMin"}], " ", "||", " ", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"resultLst", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ">", " ", 
          "targetMax"}]}], " ", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"Style", "[", " ", 
           RowBox[{
           "\"\<Incorrect y-values: some too large or too small\>\"", ",", 
            "Red"}], "]"}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "False", "]"}]}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "are", " ", "differences", " ", "from", " ", "one", " ", "to", " ", 
        "next", " ", "of", " ", "the", " ", "allowed", " ", 
        RowBox[{"distances", "?"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"straightProb", "\[NotEqual]", " ", "0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{"allowedDistances", ",", " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", "0"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"probLst", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "straightProb"}], ")"}], "/", "2."}], ",", 
            " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "straightProb"}], ")"}], "/", "2."}], ",", 
            " ", "straightProb"}], "}"}]}], ";"}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"result", " ", "=", " ", 
       RowBox[{"tallyDistances", "[", 
        RowBox[{
        "resultLst", ",", " ", "allowedDistances", ",", " ", "False"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"if", " ", "tally", " ", "shows", " ", "problems"}], " ", "-",
         " ", "return"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", " ", 
         RowBox[{"result", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Return", "[", 
          RowBox[{"result", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"checkProbabilities", "[", 
        RowBox[{
         RowBox[{"result", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         RowBox[{"result", "[", 
          RowBox[{"[", "3", "]"}], "]"}], ",", "probLst"}], "]"}], "]"}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "False", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7587992961526847`*^9, 3.758799317562909*^9}, {
