Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"primeSum", "[", 
    RowBox[{"strt_", ",", "upperbound_"}], "]"}], ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"sum", "=", "0"}], ",", 
       RowBox[{"cnt", " ", "=", " ", "strt"}], ",", 
       RowBox[{"ansList", "=", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"ans", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}], "}"}]}], ",", 
