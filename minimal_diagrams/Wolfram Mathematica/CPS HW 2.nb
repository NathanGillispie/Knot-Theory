 RowBox[{
  RowBox[{"findPoints", "[", 
   RowBox[{"func_", ",", " ", "interval_", ",", " ", "pieces_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"cnt", " ", "=", " ", "0"}], ",", " ", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "distance", " ", "is", " ", "the", " ", "interval", " ", "between", 
        " ", "each", " ", "x", " ", "value"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"distance", " ", "=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"interval", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "-", 
          RowBox[{"interval", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "/", 
        RowBox[{"(", "pieces", ")"}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"list", " ", "=", 
       RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"cnt", "<=", "pieces"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "add", " ", "points", " ", "that", " ", "lie", " ", "on", " ", "the", 
         " ", "function", " ", "to", " ", "a", " ", "list"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"list", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"interval", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "+", 
             RowBox[{"distance", "*", "cnt"}]}], ",", " ", 
            RowBox[{"func", "[", 
             RowBox[{
              RowBox[{"interval", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "+", 
              RowBox[{"distance", "*", "cnt"}]}], "]"}]}], "}"}]}], "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"cnt", "++"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", "list"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
