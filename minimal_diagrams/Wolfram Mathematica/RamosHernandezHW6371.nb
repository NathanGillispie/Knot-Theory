Cell[BoxData[
 RowBox[{
  RowBox[{"multipleSteps1", "[", 
   RowBox[{
   "runnerCo_", ",", "runnerSpeed_", ",", "catcherCo_", ",", "catcherSpeed_", 
    ",", "rad_", ",", "timeStep_", ",", "stepNumb_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"i", ",", 
      RowBox[{"catcherLine", " ", "=", 
       RowBox[{"{", "catcherCo", "}"}]}], ",", 
      RowBox[{"runnerLine", "=", 
       RowBox[{"{", "runnerCo", "}"}]}], ",", 
      RowBox[{"currCat", "=", "catcherCo"}], ",", 
      RowBox[{"currRun", "=", "runnerCo"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", "stepNumb"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"catcherLine", ",", 
          RowBox[{"oneCatcherStep", "[", 
           RowBox[{
           "currRun", ",", "currCat", ",", "catcherSpeed", ",", "timeStep"}], 
           "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"runnerLine", ",", 
          RowBox[{"oneRunnerStep1", "[", 
           RowBox[{
           "currRun", ",", "currCat", ",", "runnerSpeed", ",", "rad", ",", 
            "timeStep"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"currCat", "=", 
         RowBox[{"Last", "[", "catcherLine", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"currRun", "=", 
         RowBox[{"Last", "[", "runnerLine", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"EuclideanDistance", "[", 
             RowBox[{"currCat", ",", "currRun"}], "]"}], "<", 
            RowBox[{"(", 
             RowBox[{"timeStep", "*", "catcherSpeed"}], ")"}]}], "||", 
           RowBox[{
            RowBox[{"RegionDistance", "[", 
             RowBox[{
              RowBox[{"Circle", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"0", ",", "0"}], "}"}], ",", " ", "rad"}], "]"}], 
              ",", " ", "currRun"}], "]"}], "<", 
            RowBox[{"timeStep", "*", "runnerSpeed"}]}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Break", "[", "]"}]}], "\[IndentingNewLine]", "]"}]}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"catcherLine", ",", "runnerLine"}], "}"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
