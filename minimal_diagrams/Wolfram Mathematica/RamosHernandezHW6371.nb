  RowBox[{
   RowBox[{
    RowBox[{"oneRunnerStep", "[", 
     RowBox[{
     "runnerCo_", ",", " ", "catcherCo_", ",", " ", "runnerSpeed_", ",", " ", 
      "rad_", ",", " ", "timeStep_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "resultSet", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"resultSet", "=", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"newx", ",", " ", "newy"}], "}"}], "/.", 
         RowBox[{"NSolve", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               SuperscriptBox["newx", "2"], "+", 
               SuperscriptBox["newy", "2"]}], "==", 
              SuperscriptBox["rad", "2"]}], ",", 
             RowBox[{
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"newx", "-", 
                  RowBox[{"runnerCo", "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "2"], "+", 
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{"newy", "-", 
                  RowBox[{"runnerCo", "[", 
                   RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "2"]}], 
              "\[Equal]", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{"runnerSpeed", "*", "timeStep"}], ")"}], "2"]}]}], 
            "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"newx", ",", " ", "newy"}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"EuclideanDistance", "[", 
           RowBox[{"catcherCo", ",", " ", 
            RowBox[{"resultSet", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "\[GreaterEqual]", 
          RowBox[{"EuclideanDistance", "[", 
           RowBox[{"catcherCo", ",", " ", 
            RowBox[{"resultSet", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], ",", 
