       RowBox[{"indexRow", " ", "=", " ", "1"}], ",", 
       RowBox[{"indexCol", " ", "=", " ", "1"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"indexRow", " ", "\[LessEqual]", " ", "4"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Start", " ", "at", " ", "the", " ", "first", " ", "element", " ", 
          "of", " ", "the", " ", "row"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
