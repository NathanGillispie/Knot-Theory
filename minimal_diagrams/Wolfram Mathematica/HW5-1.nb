    RowBox[{
    "Creates", " ", "a", " ", "list", " ", "of", " ", "16", " ", "elements"}],
     ",", " ", 
    RowBox[{
     RowBox[{"one", " ", "for", " ", "each", " ", "tile"}], ";", " ", 
     RowBox[{
     "each", " ", "element", " ", "contains", " ", "the", " ", "number", " ", 
