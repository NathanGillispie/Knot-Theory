         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{"indexCol", " ", "\[LessEqual]", " ", "4"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
            "Append", " ", "each", " ", "of", " ", "the", " ", "elements", 
             " ", "for", " ", "the", " ", "row", " ", "to", " ", "the", " ", 
             "list"}], "*)"}], "\[IndentingNewLine]", 
