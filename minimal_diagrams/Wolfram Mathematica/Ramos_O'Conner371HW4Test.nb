       StyleBox["[",
        FontWeight->"Bold"], 
       StyleBox["\[IndentingNewLine]",
        FontWeight->"Bold"], 
       RowBox[{
        RowBox[{
         RowBox[{"SeedRandom", "[", "201", "]"}], ";", 
         StyleBox["\[IndentingNewLine]",
          FontWeight->"Bold"], 
         RowBox[{
          StyleBox["func",
           FontWeight->"Bold"], 
          StyleBox["=",
           FontWeight->"Bold"], 
          RowBox[{"item", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], 
         StyleBox[";",
          FontWeight->"Bold"], 
