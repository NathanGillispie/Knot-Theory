    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"distanceLst", ",", "distanceDiff"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"are", " ", "x"}], "-", 
        RowBox[{"values", " ", "evenly", " ", 
         RowBox[{"spaced", "?"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"distanceLst", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"EuclideanDistance", "[", 
           RowBox[{
            RowBox[{"resultLst", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", " ", 
            RowBox[{"resultLst", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"i", "-", "1"}], ",", "1"}], "]"}], "]"}]}], "]"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", " ", "2", ",", " ", 
            RowBox[{"Length", "[", "resultLst", "]"}]}], "}"}]}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"distanceDiff", " ", "=", 
        RowBox[{"Chop", "[", " ", 
         RowBox[{"Abs", "[", 
          RowBox[{"distanceLst", " ", "-", " ", 
           RowBox[{"distanceLst", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", " ", "[", " ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Total", "[", "distanceDiff", "]"}], "/", 
           RowBox[{"Length", "[", "resultLst", "]"}]}], " ", ">", " ", 
          SuperscriptBox["10", 
           RowBox[{"-", "5"}]]}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{
            RowBox[{
            "Style", "[", " ", 
             "\"\<Incorrect x-values: not evenly spaced\>\"", "]"}], ",", 
            "Red"}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Return", "[", "False", "]"}]}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Return", "[", "True", "]"}]}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]"}]}]], "Input",
