Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"testfindPoints", "[", " ", 
    RowBox[{
    "correctAnswer_", ",", " ", "studentRes_", ",", " ", "precision_"}], 
    "]"}], ":=", " ", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", " ", "sum", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"now", " ", "check", " ", "actual", " ", "results"}], " ", 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Max", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"EuclideanDistance", "[", 
             RowBox[{
              RowBox[{"studentRes", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
              RowBox[{"correctAnswer", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", " ", "1", ",", " ", 
              RowBox[{"Length", "[", "studentRes", "]"}]}], "}"}]}], "]"}], 
          "]"}], " ", ">", " ", 
         SuperscriptBox["10", 
          RowBox[{"-", "precision"}]]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Print", " ", "[", 
          RowBox[{"Style", "[", 
           RowBox[{
            RowBox[{"\"\<Incorrect results; \>\"", " ", "<>", " ", 
             RowBox[{"ToString", "[", "studentRes", "]"}]}], ",", " ", 
            "Red"}], "]"}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "False", "]"}]}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "True", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
