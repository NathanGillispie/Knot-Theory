Cell[BoxData[
 RowBox[{
  RowBox[{"testCreatePointLst", "[", 
   RowBox[{"testCases_", ",", " ", "test_"}], "]"}], ":=", 
  RowBox[{"Module", " ", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "func", ",", " ", "low", ",", " ", "upp", ",", " ", "points", ",", "res",
       ",", "checkRes", ",", " ", 
