          FontWeight->"Bold"], 
         RowBox[{
          StyleBox["upp",
           FontWeight->"Bold"], 
          StyleBox["=",
           FontWeight->"Bold"], 
          RowBox[{"item", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}], 
         StyleBox[";",
          FontWeight->"Bold"], 
