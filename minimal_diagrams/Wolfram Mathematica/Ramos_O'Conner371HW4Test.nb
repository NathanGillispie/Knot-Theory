Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "checks", " ", "whether", " ", "result", " ", "lst", " ", "has", " ", "at",
     " ", "least", " ", "one", " ", "entry", " ", "with", " ", "maxBlanks", 
    " ", "leading", " ", "blanks", " ", "and", " ", "1", " ", "entry", " ", 
    "with", " ", "0", " ", "leading", " ", "blanks"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"checkVerticalTraceMinMaxBlanks", "[", 
    RowBox[{"resultLst_", ",", " ", "maxBlanks_", ",", " ", "text_"}], "]"}], 
   ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"leadingBlanksLst", "=", 
        RowBox[{"{", "}"}]}], ",", " ", 
       RowBox[{"textBlanks", " ", "=", " ", 
        RowBox[{"StringCount", "[", 
         RowBox[{"text", ",", " ", "\"\< \>\""}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"count", " ", "leading", " ", "blanks"}], " ", "-", " ", 
       RowBox[{"assumes", " ", "no", " ", "trailing", " ", "blanks"}]}], " ", 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"leadingBlanksLst", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"StringCount", "[", 
           RowBox[{"item", ",", " ", "\"\< \>\""}], "]"}], "-", " ", 
          "textBlanks"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"item", ",", " ", "resultLst"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{
        RowBox[{"!", " ", 
         RowBox[{"MemberQ", "[", 
          RowBox[{"leadingBlanksLst", ",", " ", "maxBlanks"}], "]"}]}], ",", 
        "   ", "\[IndentingNewLine]", "  ", 
        RowBox[{
         RowBox[{"Print", "[", " ", 
          RowBox[{"Style", "[", 
           RowBox[{
            RowBox[{"StringJoin", "[", " ", 
             RowBox[{"\"\<Incorrect - no line with \>\"", " ", ",", " ", 
              RowBox[{
               RowBox[{"ToString", "[", " ", "maxBlanks", "]"}], " ", "<>", 
               " ", "\"\< leading blanks \>\""}]}], "]"}], ",", "Red"}], 
           "]"}], "]"}], ";", "\[IndentingNewLine]", "  ", 
         RowBox[{"Return", " ", "[", "False", "]"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{
        RowBox[{"!", " ", 
         RowBox[{"MemberQ", "[", 
          RowBox[{"leadingBlanksLst", ",", " ", "0"}], "]"}]}], ",", 
        "\[IndentingNewLine]", "  ", 
        RowBox[{
         RowBox[{"Print", "[", " ", 
          RowBox[{"Style", "[", 
           RowBox[{
            RowBox[{
            "StringJoin", "[", " ", 
             "\"\<Incorrect - no line with 0 leading blanks \>\"", "]"}], ",",
             "Red"}], "]"}], "]"}], ";", "\[IndentingNewLine]", "  ", 
         RowBox[{"Return", " ", "[", "False", "]"}]}]}], 
