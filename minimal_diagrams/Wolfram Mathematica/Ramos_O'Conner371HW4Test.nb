          RowBox[{"item", "[", 
           RowBox[{"[", "4", "]"}], "]"}]}], 
         StyleBox[";",
          FontWeight->"Bold"], 
         StyleBox["\[IndentingNewLine]",
          FontWeight->"Bold"], 
         StyleBox[
          RowBox[{"res", " ", "=", " ", 
           RowBox[{"Check", "[", " ", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"TimeConstrained", "[", " ", 
              RowBox[{
               RowBox[{"createPointLst", "[", " ", 
                RowBox[{"func", ",", "low", ",", "upp", ",", "points"}], 
                "]"}], ",", " ", "10", ",", " ", 
               RowBox[{"Style", "[", 
                RowBox[{"\"\<EXECUTION TOOK TOO LONG \>\"", ",", " ", "Red"}],
                 "]"}]}], "]"}], " ", ",", " ", "\[IndentingNewLine]", 
             RowBox[{"Style", "[", 
              RowBox[{"\"\< EXECUTION CAUSED AN EXCEPTION \>\"", ",", "Red"}],
               "]"}]}], "]"}]}],
          FontWeight->"Bold"], 
         StyleBox[";",
          FontWeight->"Bold"], 
         StyleBox["\[IndentingNewLine]",
          FontWeight->"Bold"], 
         StyleBox["\[IndentingNewLine]",
          FontWeight->"Bold"], 
         StyleBox["  ",
          FontWeight->"Bold"], 
         RowBox[{
          StyleBox["If",
           FontWeight->"Bold"], 
          StyleBox["[",
           FontWeight->"Bold"], 
          RowBox[{
           RowBox[{
            RowBox[{"SameQ", "[", 
             RowBox[{"res", ",", " ", "\"\<EXECUTION TOOK TOO LONG \>\""}], 
             "]"}], " ", "||", " ", 
            RowBox[{"SameQ", "[", 
             RowBox[{
             "res", ",", " ", "\"\< EXECUTION CAUSED AN EXCEPTION \>\""}], 
             "]"}]}], ",", "\[IndentingNewLine]", "            ", 
           RowBox[{"checkRes", "=", 
            RowBox[{"{", 
             RowBox[{"createPointLst", ",", " ", 
              RowBox[{"{", 
               RowBox[{"func", ",", "low", ",", "upp", ",", "points"}], "}"}],
               ",", " ", "res"}], "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{"(*", " ", "else", " ", "*)"}], 
           StyleBox["\[IndentingNewLine]",
            FontWeight->"Bold"], "\t   ", 
           RowBox[{"checkRes", "=", 
            RowBox[{"{", 
