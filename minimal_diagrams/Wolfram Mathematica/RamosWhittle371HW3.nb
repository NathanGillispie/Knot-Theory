         RowBox[{"[", "2", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
       "checkParameters", ",", "letters"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"checkParameters", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"row", "+", 
          RowBox[{
