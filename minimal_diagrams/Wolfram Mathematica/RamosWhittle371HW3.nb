Cell[BoxData[
 RowBox[{
  RowBox[{"randomWalk", "[", 
   RowBox[{"lower_", ",", "upper_", ",", "start_", ",", "steps_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"track", "=", "start"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0", ">", "lower"}], "||", 
        RowBox[{"lower", "\[GreaterEqual]", "upper"}]}], ",", 
       RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"track", "<", "lower"}], "||", 
        RowBox[{"track", ">", "upper"}]}], ",", 
       RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"begin", ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"begin", "\[Equal]", "0"}], ",", "track", ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"track", "+=", 
                 RowBox[{"RandomChoice", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ")"}], 
               ">", "upper"}], ",", 
              RowBox[{"track", "-=", "2"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"track", "<", "lower"}], ",", 
              RowBox[{"track", "+=", "2"}]}], "]"}], ";", 
            "\[IndentingNewLine]", "track"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"begin", ",", "0", ",", "steps"}], "}"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.758583667924097*^9, 3.7585836998976316`*^9}, {
   3.7585837579195437`*^9, 3.758583773789129*^9}, {3.7585839998818097`*^9, 
