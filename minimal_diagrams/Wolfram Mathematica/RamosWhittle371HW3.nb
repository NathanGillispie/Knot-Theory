Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "return", " ", "only", " ", "the", " ", "last", " ", "point", " ", "from", 
    " ", "modStopRandomWalk"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"modStopPointRandomWalk", "[", 
    RowBox[{"lower_", ",", "upper_", ",", "probToStay_", ",", "start_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"track", "=", "start"}], ",", 
       RowBox[{"cnt", "=", "0"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"0", ">", "lower"}], "||", 
         RowBox[{"lower", "\[GreaterEqual]", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "checks", " ", "for", " ", "valid", " ", "bounds", " ", "and", " ", 
        "start"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"track", "<", "lower"}], "||", 
         RowBox[{"track", ">", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"probToStay", "\[Equal]", "1"}], "&&", 
         RowBox[{"start", "\[NotEqual]", "upper"}], "&&", 
         RowBox[{"start", "\[NotEqual]", "lower"}]}], ",", " ", 
        RowBox[{"Return", "[", "\"\<Will never reach boundaries\>\"", "]"}]}],
        "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"isn", "'"}], "t", " ", "necessary", " ", "to", " ", "keep", 
        " ", "track", " ", "of", " ", "list"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"track", "\[NotEqual]", "upper"}], "&&", 
         RowBox[{"track", "\[NotEqual]", "lower"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"cnt", "++"}], ";", "\[IndentingNewLine]", 
         RowBox[{"track", "+=", 
          RowBox[{"RandomChoice", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"1", "-", "probToStay"}], ")"}], "/", "2"}], ")"}], 
              ",", " ", "probToStay", ",", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"1", "-", "probToStay"}], ")"}], "/", "2"}], ")"}]}],
              "}"}], "\[Rule]", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "0", ",", "1"}], "}"}]}], 
           "\[IndentingNewLine]", "]"}]}]}]}], "\[IndentingNewLine]", "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"cnt", ",", "track"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
