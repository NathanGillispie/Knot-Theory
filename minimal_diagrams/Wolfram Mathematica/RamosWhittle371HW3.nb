Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "end", " ", "a", " ", "modRandomWalk", " ", "when", " ", "the", " ", 
    "point", " ", "reaches", " ", "a", " ", "boundary"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"modstopRandomWalk", "[", 
    RowBox[{"lower_", ",", "upper_", ",", "probToStay_", ",", "start_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"track", "=", "start"}], ",", 
       RowBox[{"list", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0", ",", "start"}], "}"}], "}"}]}], ",", 
       RowBox[{"cnt", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"0", ">", "lower"}], "||", 
         RowBox[{"lower", "\[GreaterEqual]", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"track", "<", "lower"}], "||", 
         RowBox[{"track", ">", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "condition", " ", "makes", " ", "function", " ", "stop", " ", "at", 
        " ", "boundary"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"track", "\[NotEqual]", "upper"}], "&&", 
         RowBox[{"track", "\[NotEqual]", "lower"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"list", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"cnt", "++"}], ",", 
            RowBox[{"track", "+=", 
             RowBox[{"RandomChoice", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"1", "-", "probToStay"}], ")"}], "/", "2"}], 
                  ")"}], ",", " ", "probToStay", ",", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"1", "-", "probToStay"}], ")"}], "/", "2"}], 
                  ")"}]}], "}"}], "\[Rule]", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1"}], ",", "0", ",", "1"}], "}"}]}], "]"}]}]}],
            "}"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Show", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"ListLinePlot", "[", "list", "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Graphics", "[", 
            RowBox[{"{", 
             RowBox[{"Red", ",", 
              RowBox[{"PointSize", "[", ".03", "]"}], ",", 
              RowBox[{"Point", "[", "list", "]"}]}], "}"}], "]"}]}], "}"}], 
         "]"}], ",", "\[IndentingNewLine]", "list"}], "}"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 InitializationCell->True,
