Cell[BoxData[
 RowBox[{
  RowBox[{"lowerUpper", "[", 
   RowBox[{"lower_", ",", "upper_", ",", "start_", ",", "repeat_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"countUpper", "=", "0"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"inc", "=", "1"}], ",", 
       RowBox[{"inc", "\[LessEqual]", "repeat"}], ",", 
       RowBox[{"inc", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"stopPointRandomWalk", "[", 
            RowBox[{"lower", ",", "upper", ",", "start"}], "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}], "\[Equal]", "upper"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"countUpper", "++"}]}], "]"}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"repeat", "-", "countUpper"}], ")"}], ",", "countUpper"}], 
      "}"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
