Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "creates", " ", "a", " ", "list", " ", "of", " ", "points", " ", "from", 
     " ", "a", " ", "random", " ", "walk", " ", "in", " ", "3", "D", " ", 
     "space", " ", "where", " ", "the", " ", "y", " ", "and", " ", "z", " ", 
     "coordinates", " ", "go", " ", "one", " ", "unit", " ", "up", " ", "or", 
     " ", "down", " ", "at", " ", "random"}], ",", " ", 
    RowBox[{
    "the", " ", "x", " ", "coordinate", " ", "always", " ", "increments", " ",
      "by", " ", "1"}], ",", " ", 
    RowBox[{
    "and", " ", "this", " ", "process", " ", "is", " ", "repeated", " ", 
     "steps", " ", "times"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"randomWalk3D", "[", 
    RowBox[{"lower_", ",", "upper_", ",", "start_", ",", "steps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ytrack", "=", 
        RowBox[{"start", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", " ", 
       RowBox[{"ztrack", "=", 
        RowBox[{"start", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "cehcks", " ", "for", " ", "valid", " ", "bound", " ", "and", " ", 
       "start"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"0", ">", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"0", ">", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "||", 
         RowBox[{
          RowBox[{
           RowBox[{"lower", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "1"}], "\[GreaterEqual]", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "\[GreaterEqual]", " ", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
        RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ytrack", "<", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"ztrack", "<", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "||", 
         RowBox[{"ytrack", ">", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"ztrack", ">", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
        RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"perform", " ", "repetition", " ", "steps", " ", "times"}], 
       "*)"}], "\[IndentingNewLine]", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"begin", ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"begin", "\[Equal]", "0"}], ",", "ytrack", ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"ytrack", "+=", 
                  RowBox[{"RandomChoice", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ")"}], 
                ">", 
                RowBox[{"upper", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], ",", 
               RowBox[{"ytrack", "-=", "2"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"ytrack", "<", 
                RowBox[{"lower", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], ",", 
               RowBox[{"ytrack", "+=", "2"}]}], "]"}], ";", 
             "\[IndentingNewLine]", "ytrack"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"begin", "\[Equal]", "0"}], ",", "ztrack", ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"ztrack", "+=", 
                  RowBox[{"RandomChoice", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ")"}], 
                ">", 
                RowBox[{"upper", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], ",", 
               RowBox[{"ztrack", "-=", "2"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"ztrack", "<", 
                RowBox[{"lower", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], ",", 
               RowBox[{"ztrack", "+=", "2"}]}], "]"}], ";", 
             "\[IndentingNewLine]", "ztrack"}]}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"begin", ",", "0", ",", "steps"}], "}"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 InitializationCell->True,
