Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "plot", " ", "a", " ", "modRandomWalk", " ", "with", " ", "the", " ", 
    "connecting", " ", "line", " ", "and", " ", "a", " ", "green", " ", 
