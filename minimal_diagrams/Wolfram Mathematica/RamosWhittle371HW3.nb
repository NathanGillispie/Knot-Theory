Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "make", " ", "a", " ", "random", " ", "walk", " ", "where", " ", "there", 
    " ", "is", " ", "an", " ", "option", " ", "to", " ", "stay", " ", "on", 
    " ", "the", " ", "same", " ", "y", " ", "value", " ", "with", " ", 
    "probablity", " ", "probToStay"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"modrandomWalk", "[", 
    RowBox[{
    "lower_", ",", "upper_", ",", "start_", ",", "probToStay_", ",", 
     "steps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"track", "=", "start"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"0", ">", "lower"}], "||", 
         RowBox[{"lower", "\[GreaterEqual]", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"track", "<", "lower"}], "||", 
         RowBox[{"track", ">", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"begin", ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"begin", "\[Equal]", "0"}], ",", "track", ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"track", "+=", 
                  RowBox[{"RandomChoice", "[", "\[IndentingNewLine]", 
                   RowBox[{"(*", 
                    RowBox[{
                    RowBox[{
                    "because", " ", "the", " ", "probability", " ", "of", " ",
                     "y", " ", "going", " ", "up", " ", "or", " ", "down", 
                    " ", "is", " ", "equal"}], ",", " ", 
                    RowBox[{
                    RowBox[{
                    "the", " ", "combined", " ", "probability", " ", "of", 
                    " ", "those", " ", "is", " ", "1"}], " ", "-", " ", 
                    "probToStay"}]}], "*)"}], "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"1", "-", "probToStay"}], ")"}], "/", "2"}], 
                    ")"}], ",", " ", "probToStay", ",", " ", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"1", "-", "probToStay"}], ")"}], "/", "2"}], 
                    ")"}]}], "}"}], "\[Rule]", " ", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", "0", ",", "1"}], "}"}]}], 
                   "\[IndentingNewLine]", "]"}]}], ")"}], ">", "upper"}], ",", 
               RowBox[{"track", "-=", "2"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"track", "<", "lower"}], ",", 
               RowBox[{"track", "+=", "2"}]}], "]"}], ";", 
             "\[IndentingNewLine]", "track"}]}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"begin", ",", "0", ",", "steps"}], "}"}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.758657903160465*^9, {3.758657938228136*^9, 3.758657981726493*^9}, {
