     "True", " ", "if", " ", "word", " ", "is", " ", "found", " ", "at", " ", 
     RowBox[{"{", 
      RowBox[{"row", ",", " ", "column"}], "}"}], " ", "and", " ", "False", 
     " ", "otherwise"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"checkStartDirection", "[", 
    RowBox[{
    "letterRect_", ",", "word_", ",", "startLocation_", ",", "direction_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"row", "=", 
