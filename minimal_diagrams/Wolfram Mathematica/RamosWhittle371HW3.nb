Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "inheritance", " ", "would", " ", "be", " ", "great", " ", "right", " ", 
    "about", " ", "now"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"stopPointRandomWalk", "[", 
    RowBox[{"lower_", ",", "upper_", ",", "start_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"track", "=", "start"}], ",", 
       RowBox[{"cnt", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"0", ">", "lower"}], "||", 
         RowBox[{"lower", "\[GreaterEqual]", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"track", "<", "lower"}], "||", 
         RowBox[{"track", ">", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"track", "\[NotEqual]", "upper"}], "&&", 
         RowBox[{"track", "\[NotEqual]", "lower"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"cnt", "++"}], ";", "\[IndentingNewLine]", 
         RowBox[{"track", "+=", 
          RowBox[{"RandomChoice", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"cnt", ",", "track"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 InitializationCell->True,
