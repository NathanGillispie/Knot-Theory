Cell[CellGroupData[{

Cell["c)", "Subsubsection",
 CellChangeTimes->{{3.7590603316048155`*^9, 
  3.759060332198105*^9}},ExpressionUUID->"23850c98-677f-402e-b6e7-\
6e938fc1180e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "ends", " ", "randomWalk3D", " ", "when", " ", "the", " ", "poinr", " ", 
    "reaches", " ", "a", " ", "boundary"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"stopRandomWalk3D", "[", 
    RowBox[{"lower_", ",", "upper_", ",", "start_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ytrack", "=", 
        RowBox[{"start", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", " ", 
       RowBox[{"ztrack", "=", 
        RowBox[{"start", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ",", "list", ",", " ", 
       RowBox[{"cnt", "=", "1"}], ",", " ", "line"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"list", "=", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "ytrack", ",", " ", "ztrack"}], "}"}], 
        "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "checks", " ", "for", " ", "valid", " ", "boundaries", " ", "and", " ",
         "start"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"0", ">", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"0", ">", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "||", 
         RowBox[{
          RowBox[{
           RowBox[{"lower", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "1"}], "\[GreaterEqual]", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "\[GreaterEqual]", " ", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
        RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ytrack", "<", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"ztrack", "<", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "||", 
         RowBox[{"ytrack", ">", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"ztrack", ">", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
        RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"lower", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", "1"}], "\[LessEqual]", 
          "ytrack", "\[LessEqual]", " ", 
          RowBox[{
           RowBox[{"upper", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", "1"}]}], "&&", 
         RowBox[{
          RowBox[{
           RowBox[{"lower", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "+", "1"}], "\[LessEqual]", " ", 
          "ztrack", "\[LessEqual]", 
          RowBox[{
           RowBox[{"upper", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "-", "1"}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"list", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"cnt", "++"}], ",", 
            RowBox[{"ytrack", "+=", 
             RowBox[{"RandomChoice", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ",", " ", 
            "\[IndentingNewLine]", 
            RowBox[{"ztrack", "+=", 
             RowBox[{"RandomChoice", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], "]"}]}]}], 
           "}"}]}], "]"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"line", "=", 
       RowBox[{"Line", "[", "list", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "plots", " ", "point", " ", "set", " ", "and", " ", "connecting", " ", 
        "line"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Show", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"ListPointPlot3D", "[", 
            RowBox[{"list", ",", " ", 
             RowBox[{"PlotStyle", "\[Rule]", "Red"}]}], "]"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Graphics3D", "[", "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"Green", ",", " ", 
               RowBox[{"PointSize", "[", ".03", "]"}], ",", " ", 
               RowBox[{"Point", "[", 
                RowBox[{"{", 
                 RowBox[{"0", ",", " ", 
                  RowBox[{"start", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
                  RowBox[{"start", "[", 
                   RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], "}"}], 
             ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"Blue", ",", " ", "line"}], "}"}]}], "}"}], 
           "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
        "\[IndentingNewLine]", "list"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.758986993358225*^9, 3.7589870157666006`*^9}, 
