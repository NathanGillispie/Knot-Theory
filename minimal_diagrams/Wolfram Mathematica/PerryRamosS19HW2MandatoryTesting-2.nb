Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"testfindPoints", "[", 
    RowBox[{
    "fgh_", ",", " ", "int_", ",", " ", "pcs_", ",", " ", "answer_", ",", " ",
      "precision_", ",", " ", "res_"}], "]"}], ":=", " ", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", " ", 
      RowBox[{
       RowBox[{"checkMore", " ", "=", " ", "True"}], ",", " ", "sum"}], "}"}],
      ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Print", "[", "\"\<Testing findPoints\>\"", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"res", "=", 
         RowBox[{"findPoints", "[", 
          RowBox[{"fgh", ",", "int", ",", " ", "pcs"}], "]"}]}], " ", ";"}], 
       "\[IndentingNewLine]", "*)"}], 
      RowBox[{"If", "[", "  ", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"SameQ", "[", 
          RowBox[{
           RowBox[{"Head", "[", "res", "]"}], ",", " ", "List"}], "]"}]}], 
        ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{
         "printError", "[", "\"\<ERROR - function does not return a list\>\"",
           "]"}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", "  ", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "res", "]"}], " ", "\[NotEqual]", " ", 
            RowBox[{"pcs", "+", "1"}]}], " ", "||", " ", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"Select", "[", 
              RowBox[{
               RowBox[{"Flatten", "[", "res", "]"}], ",", " ", "NumericQ"}], 
              "]"}], "]"}], "\[NotEqual]", " ", 
            RowBox[{"2", " ", 
             RowBox[{"(", 
              RowBox[{"pcs", "+", "1"}], ")"}]}]}]}], ")"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "printError", "[", 
          "\"\<ERROR - function does not return correct number or type of \
elements in the list\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"now", " ", "check", " ", "actual", " ", "results"}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", " ", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", " ", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"EuclideanDistance", "[", 
              RowBox[{
               RowBox[{"res", "[", 
                RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
               RowBox[{"answer", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", " ", "1", ",", " ", 
               RowBox[{"Length", "[", "res", "]"}]}], "}"}]}], "]"}], "]"}], 
          " ", ">", " ", 
          SuperscriptBox["10", 
           RowBox[{"-", "precision"}]]}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"printError", " ", "[", 
          RowBox[{
          "\"\<Incorrect results; correct result is \>\"", " ", "<>", " ", 
           RowBox[{"ToString", "[", "answer", "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{"checkMore", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Print", "[", "\"\<Answer correct\>\"", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "0", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "1", "]"}]}], "\[IndentingNewLine]", "]"}], 
      ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
