Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"testlongestPrimeSum", "[", 
    RowBox[{"upper_", ",", "  ", "answer_", ",", " ", "res_"}], "]"}], ":=", 
   " ", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", " ", 
      RowBox[{
       RowBox[{"checkMore", " ", "=", " ", "True"}], ",", " ", "sum"}], "}"}],
      ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", "  ", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"SameQ", "[", 
          RowBox[{
           RowBox[{"Head", "[", "res", "]"}], ",", " ", "List"}], "]"}]}], 
        ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{
         "printError", "[", "\"\<ERROR - function does not return a list\>\"",
           "]"}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", "  ", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "res", "]"}], " ", "\[NotEqual]", " ", 
            "3"}], " ", "||", " ", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"Select", "[", 
              RowBox[{"res", ",", " ", "NumericQ"}], "]"}], "]"}], 
            "\[NotEqual]", " ", "3"}]}], ")"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "printError", "[", 
          "\"\<ERROR - function does not return correct number or type of \
elements in the list\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"now", " ", "check", " ", "actual", " ", "results"}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", " ", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"res", "[", 
            RowBox[{"[", "2", "]"}], "]"}], " ", "\[NotEqual]", "  ", 
           "answer"}], ")"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"printError", " ", "[", 
          RowBox[{
          "\"\<Number of terms to add up is incorrect should be \>\"", " ", "<>",
            " ", 
           RowBox[{"ToString", "[", "answer", "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{"checkMore", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"sum", " ", "=", " ", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{"Prime", "[", "i", "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"i", ",", " ", 
              RowBox[{"res", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"res", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "+", 
               RowBox[{"res", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "-", "1"}]}], "}"}]}], 
           "]"}]}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", "  ", 
         RowBox[{"!", " ", 
          RowBox[{"SameQ", "[", 
           RowBox[{"sum", ",", " ", 
            RowBox[{"res", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "]"}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "printError", " ", "[", 
          "\"\<The sum is not correct for your starting value and number of \
terms\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", " ", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"!", " ", 
            RowBox[{"PrimeQ", "[", 
             RowBox[{"res", "[", 
              RowBox[{"[", "3", "]"}], "]"}], "]"}]}], " ", "||", " ", 
           RowBox[{
            RowBox[{"res", "[", 
             RowBox[{"[", "3", "]"}], "]"}], " ", "\[GreaterEqual]", " ", 
            "upper"}]}], ")"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "printError", " ", "[", 
          "\"\<The sum is not prime or it is not less than upper\>\"", "]"}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{"checkMore", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Print", "[", "\"\<Answer correct\>\"", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "0", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "1", "]"}]}], "\[IndentingNewLine]", "]"}], 
      ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
