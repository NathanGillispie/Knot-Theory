  RowBox[{"interval", "=", 
   RowBox[{"{", 
    RowBox[{"1.", ",", "2"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pieces", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"precision", "=", "5"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"compute", " ", "your", " ", "answer"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"points", "=", " ", 
  RowBox[{"findPoints", "[", 
   RowBox[{"testfun", ",", " ", "interval", ",", " ", "pieces"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"pic", "=", 
  RowBox[{"showLinesegments", "[", 
   RowBox[{"testfun", ",", " ", "interval", ",", " ", "pieces"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"length", "=", 
  RowBox[{"lengthOfCurve", "[", 
   RowBox[{"testfun", ",", " ", "interval", ",", " ", "pieces"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"preclength", "=", 
  RowBox[{"preciselengthOfCurve", "[", 
