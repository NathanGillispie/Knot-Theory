Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"testfun", "[", "z_", "]"}], ":=", " ", 
   SuperscriptBox[
    RowBox[{"Cos", "[", 
     RowBox[{"4", "z"}], "]"}], "2"]}], ";"}], "\[IndentingNewLine]", 
