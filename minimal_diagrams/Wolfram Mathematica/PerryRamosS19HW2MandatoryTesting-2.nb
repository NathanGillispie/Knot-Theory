Cell[CellGroupData[{

Cell["code needed for testing - execute this cell!!!", "Subsubsection",
 CellGroupingRules->{"GroupTogetherGrouping", 10000.},
 CellChangeTimes->{{3.7576047903577576`*^9, 3.757604791787839*^9}, {
   3.7583009540369616`*^9, 3.7583009606982956`*^9}, 3.7583105786179295`*^9, {
   3.75831596531821*^9, 
   3.7583159893065825`*^9}},ExpressionUUID->"0aaf282f-2ebd-4af2-a2f6-\
a93559cbce24"],

Cell[BoxData[
 RowBox[{
  RowBox[{"errorMsgHW2", "=", " ", 
   RowBox[{"{", "     ", 
    RowBox[{
    "\"\< 1) make sure you RETURN the answer - it should not be printed with \
Print [..] \\n\>\"", ",", "\n", "     \t ", 
     "\"\< 2) check  that the order (and structure) of the parameters is \
correct \\n\>\"", " ", ",", "\[IndentingNewLine]", " ", 
     "\"\< 3) check  that the order (and structure) of the returned values is \
correct\\n\>\""}], " ", "}"}]}], ";"}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 10000.},
 CellChangeTimes->{{3.7583016006949854`*^9, 3.7583016442889853`*^9}, {
   3.7583087374570646`*^9, 3.7583087748548045`*^9}, 3.75831057861893*^9},
 CellLabel->
  "In[149]:=",ExpressionUUID->"24b8a67b-f5d2-48b8-a47c-32f8c35902ac"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"printError", "[", "msg_", "]"}], ":=", " ", 
   RowBox[{"Print", " ", "@@", " ", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"msg", " ", "<>", " ", "\"\<\\n\>\""}], "}"}], ",", " ", 
      "errorMsgHW2"}], "]"}]}]}], "\[IndentingNewLine]"}]], "Input",
 CellGroupingRules->{"GroupTogetherGrouping", 10000.},
 CellChangeTimes->{
  3.7583058747215767`*^9, {3.7583087827965984`*^9, 3.758308841298448*^9}, {
   3.7583089130886264`*^9, 3.7583089516444817`*^9}, {3.7583090122855453`*^9, 
   3.7583090153128476`*^9}, 3.75831057861893*^9},
 CellLabel->
  "In[150]:=",ExpressionUUID->"a61dac9d-fd6e-41b0-b8a5-1a368d4a9ba8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"testlongestPrimeSum", "[", 
    RowBox[{"upper_", ",", "  ", "answer_"}], "]"}], ":=", " ", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"res", ",", " ", 
       RowBox[{"checkMore", " ", "=", " ", "True"}], ",", " ", "sum"}], "}"}],
      ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"res", "=", 
       RowBox[{"longestPrimeSum", "[", "upper", "]"}]}], " ", ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", "  ", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"SameQ", "[", 
          RowBox[{
           RowBox[{"Head", "[", "res", "]"}], ",", " ", "List"}], "]"}]}], 
        ",", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{
         "printError", "[", "\"\<ERROR - function does not return a list\>\"",
           "]"}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", "  ", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "res", "]"}], " ", "\[NotEqual]", " ", 
            "3"}], " ", "||", " ", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"Select", "[", 
              RowBox[{"res", ",", " ", "NumericQ"}], "]"}], "]"}], 
            "\[NotEqual]", " ", "3"}]}], ")"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "printError", "[", 
          "\"\<ERROR - function does not return correct number or type of \
elements in the list\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{"now", " ", "check", " ", "actual", " ", "results"}], " ", 
       "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", " ", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"res", "[", 
            RowBox[{"[", "2", "]"}], "]"}], " ", "\[NotEqual]", "  ", 
           "answer"}], ")"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"printError", " ", "[", 
          RowBox[{
          "\"\<Number of terms to add up is incorrect should be \>\"", " ", "<>",
            " ", 
           RowBox[{"ToString", "[", "answer", "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{"checkMore", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"sum", " ", "=", " ", 
          RowBox[{"Sum", "[", 
           RowBox[{
            RowBox[{"Prime", "[", "i", "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"i", ",", " ", 
              RowBox[{"res", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"res", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "+", 
               RowBox[{"res", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "-", "1"}]}], "}"}]}], 
           "]"}]}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", "  ", 
         RowBox[{"!", " ", 
          RowBox[{"SameQ", "[", 
           RowBox[{"sum", ",", " ", 
            RowBox[{"res", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "]"}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "printError", " ", "[", 
          "\"\<The sum is not correct for your starting value and number of \
terms\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"checkMore", " ", "=", " ", "False"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", " ", 
       RowBox[{
        RowBox[{"checkMore", " ", "&&", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"!", " ", 
            RowBox[{"PrimeQ", "[", 
             RowBox[{"res", "[", 
              RowBox[{"[", "3", "]"}], "]"}], "]"}]}], " ", "||", " ", 
           RowBox[{
            RowBox[{"res", "[", 
             RowBox[{"[", "3", "]"}], "]"}], " ", "\[GreaterEqual]", " ", 
            "upper"}]}], ")"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
         "printError", " ", "[", 
          "\"\<The sum is not prime or it is not less than upper\>\"", "]"}], 
         ";", "\[IndentingNewLine]", 
