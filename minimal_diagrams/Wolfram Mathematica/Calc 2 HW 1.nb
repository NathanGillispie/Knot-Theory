Cell[BoxData["iii"], "Input",
 CellChangeTimes->{{3.758539910928543*^9, 
  3.758539911159814*^9}},ExpressionUUID->"8d9939ee-29fb-4117-ab4d-\
8cf535cca3fb"],

Cell["\<\
Most folks say that alcohol concentration decays linearly up until a point \
because the graph of the decay (graph 1) behaves in a practically linear way \
until x \[TildeTilde] .2 . Furthermore, the graph of a linear function (graph \
2) is positive until x \[TildeTilde] .2. You can see that at some small \
alcohol level (\[OpenCurlyDoubleQuote]at which no one cares\
\[CloseCurlyDoubleQuote]), the graphs diverge\
\>", "Text",
 CellChangeTimes->{{3.7585399159370565`*^9, 3.7585399989551153`*^9}, {
  3.758540030601508*^9, 3.7585400856852446`*^9}, {3.75854016828443*^9, 
  3.7585402493119125`*^9}, {3.7585424325136323`*^9, 
  3.7585425118585835`*^9}},ExpressionUUID->"0f89ef10-b519-4d77-973d-\
fc849f0b00bc"],

Cell[CellGroupData[{

Cell["Epidemics", "Subsubsection",
 CellChangeTimes->{{3.758565407594653*^9, 
  3.7585654119699225`*^9}},ExpressionUUID->"541e0472-6c83-43da-8df2-\
c624d94f70cc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", ".00218"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", ".44036"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"start", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"stop", "=", "14"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"susstart", " ", "=", " ", "10000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"infstart", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"recovstart", " ", "=", " ", "20"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Sus", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"-", "a"}], "*", 
           RowBox[{"Inf", "[", "t", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Inf", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"a", "*", 
            RowBox[{"Sus", "[", "t", "]"}], "*", 
            RowBox[{"Inf", "[", "t", "]"}]}], "-", 
           RowBox[{"b", " ", 
            RowBox[{"Inf", "[", "t", "]"}]}]}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Recov", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{"b", "*", 
           RowBox[{"Inf", "[", "t", "]"}]}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Sus", "[", "start", "]"}], "\[Equal]", "susstart"}], ",", 
         RowBox[{
          RowBox[{"Inf", "[", "start", "]"}], "\[Equal]", "infstart"}], ",", 
         " ", 
         RowBox[{
          RowBox[{"Recov", "[", "start", "]"}], "\[Equal]", "recovstart"}]}], 
        "}"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Sus", "[", "t", "]"}], ",", 
       RowBox[{"Inf", "[", "t", "]"}], ",", " ", 
       RowBox[{"Recov", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "start", ",", "stop"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Sus2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Sus", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Inf2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Inf", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Recov2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Recov", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"plotsus", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Sus2", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "start", ",", "stop"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<susceptible \>\"", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<x\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"plotinf", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Inf2", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "start", ",", "stop"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<infected \>\"", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<y\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"plotrecov", " ", "=", " ", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Recov2", "[", "t", "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"t", ",", " ", "start", ",", " ", "stop"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<recovered/immune \>\"", ",", " ", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<z\>\"", ",", " ", "Italic"}], "]"}]}], "}"}], "]"}]}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{"PlotStyle", "\[Rule]", "Green"}], ",", " ", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.758574295970091*^9, 3.758574300051298*^9}, {
   3.758574439811519*^9, 3.758574491333773*^9}, {3.758576132420887*^9, 
