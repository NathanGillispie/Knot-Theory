       "            ", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], " ", "==", " ", "starter"}]}], "}"}], 
     ",", 
     RowBox[{"y", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "endtime"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"coke", "[", "t_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"y", "[", "t", "]"}], "/.", 
     RowBox[{"solution", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"cokeplot", " ", "=", " ", 
