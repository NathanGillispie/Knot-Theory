Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", ".00218"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", ".44036"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"start", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"stop", "=", "14"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"susstart", " ", "=", " ", "200"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"infstart", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"recovstart", " ", "=", " ", "20"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Sus", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"-", "a"}], "*", 
           RowBox[{"Inf", "[", "t", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Inf", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"a", "*", 
            RowBox[{"Sus", "[", "t", "]"}], "*", 
            RowBox[{"Inf", "[", "t", "]"}]}], "-", 
           RowBox[{"b", " ", 
            RowBox[{"Inf", "[", "t", "]"}]}]}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Recov", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{"b", "*", 
           RowBox[{"Inf", "[", "t", "]"}]}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Sus", "[", "start", "]"}], "\[Equal]", "susstart"}], ",", 
         RowBox[{
          RowBox[{"Inf", "[", "start", "]"}], "\[Equal]", "infstart"}], ",", 
         " ", 
         RowBox[{
          RowBox[{"Recov", "[", "start", "]"}], "\[Equal]", "recovstart"}]}], 
        "}"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Sus", "[", "t", "]"}], ",", 
       RowBox[{"Inf", "[", "t", "]"}], ",", " ", 
       RowBox[{"Recov", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "start", ",", "stop"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Sus2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Sus", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Inf2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Inf", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Recov2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Recov", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"plotsus", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Sus2", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "start", ",", "stop"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<susceptible \>\"", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<x\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"plotinf", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Inf2", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "start", ",", "stop"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<infected \>\"", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<y\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"plotrecov", " ", "=", " ", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Recov2", "[", "t", "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"t", ",", " ", "start", ",", " ", "stop"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<recovered/immune \>\"", ",", " ", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<z\>\"", ",", " ", "Italic"}], "]"}]}], "}"}], "]"}]}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{"PlotStyle", "\[Rule]", "Green"}], ",", " ", 
    RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.7585886371751385`*^9, 3.758588639295474*^9}, {
