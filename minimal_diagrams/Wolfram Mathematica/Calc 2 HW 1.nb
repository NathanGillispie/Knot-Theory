  RowBox[{"endtime", " ", "=", " ", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"A", " ", "=", " ", "3"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"k", " ", "=", " ", "2.5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"starter", " ", "=", " ", "0.00125"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"t", ",", "y", ",", "Derivative"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"solution", " ", "=", " ", "\n", " ", 
