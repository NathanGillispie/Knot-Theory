Cell[BoxData[{
 RowBox[{
  RowBox[{"endtime", " ", "=", " ", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"A", " ", "=", " ", "0.001"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"k", " ", "=", " ", "0.02"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"starter", " ", "=", " ", "0.0037"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"solution", " ", "=", " ", "\n", " ", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"-", 
         FractionBox[
          RowBox[{"k", " ", 
           RowBox[{"y", "[", "t", "]"}]}], 
          RowBox[{"A", "+", 
           RowBox[{"y", "[", "t", "]"}]}]]}]}], ",", " ", "\n", 
       "            ", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], " ", "==", " ", "starter"}]}], "}"}], 
     ",", 
     RowBox[{"y", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "endtime"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"alcohol", "[", "t_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"y", "[", "t", "]"}], "/.", 
     RowBox[{"solution", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"sloshplot", " ", "=", " ", 
   RowBox[{"Plot", "[", 
