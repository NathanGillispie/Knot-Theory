     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<t\>\"", ",", "\"\<alcohol\>\""}], "}"}]}], ",", "\n", 
     "       ", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";"}]}], "Input",
