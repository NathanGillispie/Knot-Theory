Cell["\<\
The previous graphs show the effect of a relatively small intial value for \
Sus(0) (where Sus(0) is less than b/a). Because there are so few susceptible \
people relative to what is usually seen in epidemics, the rate at which \
infected people recover is actually significant in reducing the number of \
infected people relative to the number of people to become infected. Thus, as \
usual, Sus(t) decreases with time, but Inf(t) also does and Recov\
\[CloseCurlyQuote](t) > 0 for all t seen.
When Sus(0) is greater than b/a, the rate at which people become infected is \
more significant than the rate at which infected people recover, hence Inf\
\[CloseCurlyQuote](t) > 0 for all t until Sus(t) becomes sufficiently small \
in which case the logic in the previous paragraph applies.\
\>", "Text",
 CellChangeTimes->{{3.758591387458829*^9, 3.7585913936244183`*^9}, {
  3.7585915413595357`*^9, 3.7585916389027987`*^9}, {3.758591675574602*^9, 
  3.7585919934098682`*^9}},ExpressionUUID->"882b9581-8496-48f2-9d1b-\
6c30ce4ab39b"],

Cell[BoxData["iv"], "Input",
 CellChangeTimes->{{3.7585889457230997`*^9, 
  3.7585889459423866`*^9}},ExpressionUUID->"ac97c782-20b5-43c9-850b-\
f9581eb9d2b7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", ".00218"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", ".44036"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"start", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"stop", "=", "14"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"susstart", " ", "=", " ", "10000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"infstart", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"recovstart", " ", "=", " ", "20"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Sus", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"-", "a"}], "*", 
           RowBox[{"Inf", "[", "t", "]"}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Inf", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"a", "*", 
            RowBox[{"Sus", "[", "t", "]"}], "*", 
            RowBox[{"Inf", "[", "t", "]"}]}], "-", 
           RowBox[{"b", " ", 
            RowBox[{"Inf", "[", "t", "]"}]}]}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Recov", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{"b", "*", 
           RowBox[{"Inf", "[", "t", "]"}]}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Sus", "[", "start", "]"}], "\[Equal]", "susstart"}], ",", 
         RowBox[{
          RowBox[{"Inf", "[", "start", "]"}], "\[Equal]", "infstart"}], ",", 
         " ", 
         RowBox[{
          RowBox[{"Recov", "[", "start", "]"}], "\[Equal]", "recovstart"}]}], 
        "}"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Sus", "[", "t", "]"}], ",", 
       RowBox[{"Inf", "[", "t", "]"}], ",", " ", 
       RowBox[{"Recov", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "start", ",", "stop"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Sus2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Sus", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Inf2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Inf", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Recov2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"Recov", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"plotall", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Sus2", "[", "t", "]"}], ",", " ", 
      RowBox[{"Inf2", "[", "t", "]"}], ",", " ", 
      RowBox[{"b", "/", "a"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "2"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"{", "\"\<susceptible red infected blue\>\"", "}"}]}], ",", " ", 
    RowBox[{"PlotStyle", "\[Rule]", " ", 
     RowBox[{"{", 
      RowBox[{"Red", ",", " ", "Blue", ",", " ", "Green"}], "}"}]}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "10000"}], "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.758590109050521*^9, 3.758590284797966*^9}, {
  3.7585903616572137`*^9, 3.758590374408122*^9}},
 CellLabel->
  "In[798]:=",ExpressionUUID->"f85d7251-edd7-4327-9890-4276a78603cc"],

