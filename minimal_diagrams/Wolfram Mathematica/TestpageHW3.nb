  RowBox[{"findAllWords", "[", 
   RowBox[{"letterRect_", ",", "wordLst_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"list", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"pos", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"pos", "\[LessEqual]", 
        RowBox[{"Length", "[", "wordLst", "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", 
            RowBox[{"Flatten", "[", 
             RowBox[{"findWord", "[", 
              RowBox[{"letterRect", ",", 
               RowBox[{"wordLst", "[", 
                RowBox[{"[", "pos", "]"}], "]"}]}], "]"}], "]"}], "]"}], 
           "\[Equal]", "4"}], ",", "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"list", ",", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"wordLst", "[", 
               RowBox[{"[", "pos", "]"}], "]"}], ",", 
              RowBox[{"findWord", "[", 
               RowBox[{"letterRect", ",", 
                RowBox[{"wordLst", "[", 
                 RowBox[{"[", "pos", "]"}], "]"}]}], "]"}]}], "}"}]}], "]"}], 
          ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", 
              RowBox[{"Flatten", "[", 
               RowBox[{"findWord", "[", 
                RowBox[{"letterRect", ",", 
                 RowBox[{"wordLst", "[", 
                  RowBox[{"[", "pos", "]"}], "]"}]}], "]"}], "]"}], "]"}], 
             ">", "4"}], ",", "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"list", ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"wordLst", "[", 
                 RowBox[{"[", "pos", "]"}], "]"}], ",", 
                "\"\<multiple matches\>\""}], "}"}]}], "]"}]}], "]"}]}], 
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"pos", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", "list"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
