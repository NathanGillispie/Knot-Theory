Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"effectively", " ", "same", " ", "as", " ", "stopRandomWalk3D"}], 
    ",", " ", 
    RowBox[{"just", " ", 
     RowBox[{"doesn", "'"}], "t", " ", "keep", " ", "track", " ", "of", " ", 
     "the", " ", "list"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"stopPointRandomWalk3D", "[", 
    RowBox[{"lower_", ",", " ", "upper_", ",", " ", "start_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"ytrack", "=", 
        RowBox[{"start", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", " ", 
       RowBox[{"ztrack", "=", 
        RowBox[{"start", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ",", "list", ",", " ", 
       RowBox[{"cnt", "=", "0"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"0", ">", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"0", ">", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "||", 
         RowBox[{
          RowBox[{
           RowBox[{"lower", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "1"}], "\[GreaterEqual]", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "\[GreaterEqual]", " ", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
        RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ytrack", "<", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"ztrack", "<", 
          RowBox[{"lower", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "||", 
         RowBox[{"ytrack", ">", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "||", 
         RowBox[{"ztrack", ">", 
          RowBox[{"upper", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
        RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"lower", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "+", "1"}], "\[LessEqual]", 
          "ytrack", "\[LessEqual]", " ", 
          RowBox[{
           RowBox[{"upper", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", "1"}]}], "&&", 
         RowBox[{
          RowBox[{
           RowBox[{"lower", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "+", "1"}], "\[LessEqual]", " ", 
          "ztrack", "\[LessEqual]", 
          RowBox[{
           RowBox[{"upper", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "-", "1"}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"cnt", "++"}], ";", "\[IndentingNewLine]", 
         RowBox[{"ytrack", "+=", 
          RowBox[{"RandomChoice", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"ztrack", "+=", 
          RowBox[{"RandomChoice", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], "]"}]}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"cnt", ",", " ", "ytrack", ",", " ", "ztrack"}], "}"}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
