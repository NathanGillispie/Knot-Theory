Cell[BoxData[
 RowBox[{
  RowBox[{"stopRandomWalk", "[", 
   RowBox[{"lower_", ",", "upper_", ",", "start_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"track", "=", "start"}], ",", 
      RowBox[{"list", "=", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", "start"}], "}"}], "}"}]}], ",", 
      RowBox[{"cnt", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0", ">", "lower"}], "||", 
        RowBox[{"lower", "\[GreaterEqual]", "upper"}]}], ",", 
       RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"track", "<", "lower"}], "||", 
        RowBox[{"track", ">", "upper"}]}], ",", 
       RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"track", "\[NotEqual]", "upper"}], "&&", 
        RowBox[{"track", "\[NotEqual]", "lower"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"list", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"cnt", "++"}], ",", 
           RowBox[{"track", "+=", 
            RowBox[{"RandomChoice", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}]}], "}"}]}], 
        "]"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
