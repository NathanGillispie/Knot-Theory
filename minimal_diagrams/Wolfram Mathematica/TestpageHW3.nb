Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", "works", " ", "with", " ", "While"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"modrandomWalk", "[", 
    RowBox[{
    "lower_", ",", "upper_", ",", "start_", ",", "probToStay_", ",", 
     "steps_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"track", "=", "start"}], ",", 
       RowBox[{"list", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"0", ",", "start"}], "}"}], "}"}]}], ",", 
       RowBox[{"cnt", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"0", ">", "lower"}], "||", 
         RowBox[{"lower", "\[GreaterEqual]", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Invalid boundaries\>\"", "]"}]}], "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"track", "<", "lower"}], "||", 
         RowBox[{"track", ">", "upper"}]}], ",", 
        RowBox[{"Return", "[", "\"\<Start is out of range\>\"", "]"}]}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"cnt", " ", "\[LessEqual]", " ", "steps"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"list", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"cnt", "++"}], ",", 
            RowBox[{"track", "+=", 
             RowBox[{"RandomChoice", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"1", "-", "probToStay"}], ")"}], "/", "2"}], 
                  ")"}], ",", " ", "probToStay", ",", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"1", "-", "probToStay"}], ")"}], "/", "2"}], 
                  ")"}]}], "}"}], "\[Rule]", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1"}], ",", "0", ",", "1"}], "}"}]}], 
              "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
           "}"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", "list"}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
