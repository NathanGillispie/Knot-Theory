8edd8abe8d99"],

Cell[BoxData[
 RowBox[{
  RowBox[{"oneCatcherStep", "[", 
   RowBox[{
   "runnerCo_", ",", "catcherCo_", ",", "catcherSpeed_", ",", "timestep_"}], 
   "]"}], ":=", "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"N", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"catcherCo", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"runnerCo", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"catcherCo", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ")"}], 
         RowBox[{"(", 
          RowBox[{"catcherSpeed", "*", "timestep"}], ")"}]}], ")"}], "/", 
       RowBox[{"EuclideanDistance", "[", 
        RowBox[{"runnerCo", ",", "catcherCo"}], "]"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"catcherCo", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"runnerCo", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "-", 
           RowBox[{"catcherCo", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ")"}], 
         RowBox[{"(", 
          RowBox[{"catcherSpeed", "*", "timestep"}], ")"}]}], ")"}], "/", 
       RowBox[{"EuclideanDistance", "[", 
        RowBox[{"runnerCo", ",", "catcherCo"}], "]"}]}]}]}], "}"}], 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.7607436056216965`*^9, 3.760743606880395*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"cadd6880-0ff2-41f2-a734-f6766116a8fe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"multipleSteps4", "[", 
   RowBox[{
   "runnerCo_", ",", " ", "runnerSpeed_", ",", " ", "catcherCo1_", ",", " ", 
    "catcherCo2_", ",", " ", "catcherSpeed_", ",", " ", "rad_", ",", " ", 
    "timeStep_", ",", " ", "stepNumb_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "runnerList", ",", "catcherList1", ",", "catcherList2", ",", "stepList1",
       ",", "stepList2", ",", "stepsLeft", ",", "stepListNext1", ",", " ", 
      "stepListNext2", ",", "item", ",", " ", "newRunner"}], "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "stepList", " ", "1", " ", "is", " ", "the", " ", "steps", " ", "taken", 
      " ", "by", " ", "the", " ", "first", " ", "catchers", " ", "when", " ", 
      "both", " ", "it", " ", "and", " ", "the", " ", "runner", " ", "are", 
      " ", "still", " ", "moving", " ", "in", " ", "a", " ", "straight", " ", 
      "line"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "stepList", " ", "2", " ", "just", " ", "chases", " ", "the", " ", 
      "runner", " ", "using", " ", "the", " ", 
      RowBox[{"runner", "'"}], "s", " ", "current", " ", "position", " ", 
      "at", " ", "this", " ", "stage"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"stepList1", "=", 
      RowBox[{"multipleSteps1", "[", 
       RowBox[{
       "runnerCo", ",", "runnerSpeed", ",", "catcherCo1", ",", "catcherSpeed",
         ",", "rad", ",", "timeStep", ",", "stepNumb"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"stepList2", "=", 
