Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "plots", " ", "function", " ", "with", " ", "the", " ", "letters", " ", 
    "from", " ", "the", " ", "function"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"horizontalTrace", "[", 
     RowBox[{
     "func_", ",", " ", "text_", ",", " ", "lower_", ",", " ", "upper_", ",", 
      " ", "color_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "pointlist", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"pointlist", "=", 
        RowBox[{"createPointLst", "[", 
         RowBox[{"func", ",", " ", "lower", ",", " ", "upper", ",", " ", 
          RowBox[{"StringLength", "[", "text", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"func", "[", "x", "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"x", ",", " ", "lower", ",", " ", "upper"}], "}"}], ",", 
           " ", 
           RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}], ",", " ", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"display", " ", "letter", " ", "list"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"displayText", "[", 
          RowBox[{"prepareTextDisplay", "[", 
           RowBox[{"text", ",", " ", "pointlist", ",", " ", "color"}], "]"}], 
          "]"}], ",", " ", 
         RowBox[{"PlotRange", "\[Rule]", "All"}]}], " ", 
        "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]"}]}]], "Input",
