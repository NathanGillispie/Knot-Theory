Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "finds", " ", "number", " ", "of", " ", "spaces", " ", "each", " ", "line",
     " ", "needs", " ", "to", " ", "reflect", " ", "the", " ", "y", " ", 
    "value", " ", "of", " ", "a", " ", "func"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"createSpaceLst", "[", 
    RowBox[{
    "func_", ",", "lower_", ",", " ", "upper_", ",", "lines_", ",", " ", 
     "maxBlanks_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "gets", " ", "points", " ", "from", " ", "creatPointList", " ", 
      "funtion"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"pointList", "=", 
        RowBox[{"createPointLst", "[", 
         RowBox[{
         "func", ",", " ", "lower", ",", " ", "upper", ",", " ", "lines"}], 
         "]"}]}], ",", "yList"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"yList", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"pointList", "[", 
           RowBox[{"[", 
            RowBox[{"cnt", ",", " ", "2"}], "]"}], "]"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"cnt", ",", " ", 
           RowBox[{"Length", "@", "pointList"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "the", " ", "equation", " ", "is", " ", "a", " ", "proportion", " ", 
         "of", " ", "the", " ", "y", " ", "corrdinate", " ", "to", " ", "the",
          " ", "maxBlanks"}], ",", " ", 
        RowBox[{
        "and", " ", "scales", " ", "accordingly", " ", "such", " ", "that", 
         " ", "the", " ", "maximum", " ", "number", " ", "of", " ", "spaces", 
         " ", "is", " ", "maxBlanks"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Flatten", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{
           FractionBox[
            RowBox[{
             RowBox[{"yList", "[", 
              RowBox[{"[", "pt", "]"}], "]"}], "-", 
             RowBox[{"Min", "[", "yList", "]"}]}], 
            RowBox[{
             RowBox[{"Max", "[", "yList", "]"}], "-", 
             RowBox[{"Min", "[", "yList", "]"}]}]], "*", "maxBlanks"}], "]"}],
          ",", " ", 
         RowBox[{"{", 
          RowBox[{"pt", ",", " ", 
           RowBox[{"Length", "@", "yList"}]}], "}"}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 InitializationCell->True,
