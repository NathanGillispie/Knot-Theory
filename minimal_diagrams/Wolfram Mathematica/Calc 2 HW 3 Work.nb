  RowBox[{"NIntegrate", "[", 
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", "dx", ")"}], "2"], "+", 
      SuperscriptBox[
       RowBox[{"(", "dy", ")"}], "2"], "+", 
      SuperscriptBox[
       RowBox[{"(", "dz", ")"}], "2"]}]], ",", " ", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"t", ",", " ", "0", ",", " ", 
      RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.760467791971218*^9, 3.7604678813761816`*^9}, {
  3.760467979898531*^9, 3.7604680646975102`*^9}, {3.7604687097502937`*^9, 
  3.7604687211337967`*^9}, {3.760468767111827*^9, 3.760468775707833*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"e162429b-3f22-47fa-a640-7581e4feea6b"],

Cell[BoxData["141.65928388478375`"], "Output",
