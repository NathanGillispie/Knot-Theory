Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Integral]", 
  RowBox[{
   SqrtBox[
    RowBox[{"3", 
     SuperscriptBox["x", "\[ExponentialE]"], 
     RowBox[{"Log", "[", 
      RowBox[{"e", ",", " ", 
       SuperscriptBox["5", 
        RowBox[{"-", 
         SuperscriptBox["x", "e"]}]]}], "]"}]}]], 
   RowBox[{"\[DifferentialD]", "x"}]}]}]], "Input",
 CellChangeTimes->{{3.7598351153815665`*^9, 3.7598351165953064`*^9}, {
  3.7598351949482365`*^9, 3.7598352525010767`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"98df1b25-7b98-49cb-b801-b7128d04eca4"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   SqrtBox["3"], " ", "x", " ", 
   RowBox[{"(", 
    RowBox[{"2", "+", "\[ExponentialE]", "+", 
     FractionBox[
      RowBox[{"e", " ", 
       RowBox[{"Hypergeometric2F1", "[", 
        RowBox[{
         FractionBox["1", "2"], ",", 
         FractionBox[
          RowBox[{"2", "+", "\[ExponentialE]"}], 
          RowBox[{"2", " ", "e"}]], ",", 
         RowBox[{"1", "+", 
          FractionBox[
           RowBox[{"2", "+", "\[ExponentialE]"}], 
           RowBox[{"2", " ", "e"}]]}], ",", 
         FractionBox[
          RowBox[{
           SuperscriptBox["x", "e"], " ", 
           RowBox[{"Log", "[", "5", "]"}]}], 
          RowBox[{
           RowBox[{
            SuperscriptBox["x", "e"], " ", 
            RowBox[{"Log", "[", "5", "]"}]}], "+", 
           RowBox[{"Log", "[", 
            SuperscriptBox["5", 
             RowBox[{"-", 
              SuperscriptBox["x", "e"]}]], "]"}]}]]}], "]"}]}], 
      SqrtBox[
       FractionBox[
        RowBox[{"Log", "[", 
         SuperscriptBox["5", 
          RowBox[{"-", 
           SuperscriptBox["x", "e"]}]], "]"}], 
        RowBox[{
         RowBox[{
          SuperscriptBox["x", "e"], " ", 
          RowBox[{"Log", "[", "5", "]"}]}], "+", 
         RowBox[{"Log", "[", 
          SuperscriptBox["5", 
           RowBox[{"-", 
            SuperscriptBox["x", "e"]}]], "]"}]}]]]]}], ")"}], " ", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["x", "\[ExponentialE]"], " ", 
      RowBox[{"Log", "[", 
       SuperscriptBox["5", 
        RowBox[{"-", 
         SuperscriptBox["x", "e"]}]], "]"}]}], 
     RowBox[{"Log", "[", "e", "]"}]]]}], 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"2", "+", "\[ExponentialE]"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{"2", "+", "e", "+", "\[ExponentialE]"}], ")"}]}]]], "Output",
 CellChangeTimes->{{3.7598352264716597`*^9, 3.7598352534989443`*^9}, 
   3.76129773245613*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"efa28c61-bb61-4998-9ad3-bf22856aaad6"]
}, Open  ]],

