Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "[", 
   RowBox[{"t_", ",", "p_", ",", " ", "q_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Cos", "[", 
    RowBox[{"q", "*", "t"}], "]"}], 
   RowBox[{"(", 
    RowBox[{"3", "+", 
     RowBox[{"Cos", "[", 
