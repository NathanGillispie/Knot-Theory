  RowBox[{"dy", "=", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"y", "[", 
      RowBox[{"t", ",", "8", ",", "5"}], "]"}], ",", "t"}], "]"}]}], 
