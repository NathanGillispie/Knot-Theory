    RowBox[{
     RowBox[{"z", "[", 
      RowBox[{"t", ",", "8", ",", "5"}], "]"}], ",", "t"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"arclength85", "=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", "dx", ")"}], "2"], "+", 
