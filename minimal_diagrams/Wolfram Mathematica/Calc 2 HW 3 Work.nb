 CellLabel->"Out[71]=",ExpressionUUID->"28bd7735-11b8-4839-aa8e-12a8462bf471"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NumericalSort", "[", 
  RowBox[{"{", 
   RowBox[{
   "arclength32", ",", "arclength43", ",", " ", "arclength52", ",", " ", 
    "arclength53", ",", " ", "arclength54", ",", " ", "arclength65", ",", " ",
     "arclength72", ",", "arclength73", ",", " ", "arclength74", ",", " ", 
    "arclength75", ",", " ", "arclength76", ",", "arclength83", ",", " ", 
    "arclength85", ",", " ", "arclength87"}], "}"}], "]"}]], "Input",
