Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "42.34596379552032`", ",", "49.4108568646159`", ",", "58.324769053969206`", 
   ",", "62.132695718746604`", ",", "65.02821202030714`", ",", 
