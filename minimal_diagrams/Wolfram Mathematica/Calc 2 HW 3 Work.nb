Cell[BoxData[{
 RowBox[{
  RowBox[{"dx", "=", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"x", "[", 
      RowBox[{"t", ",", "8", ",", "5"}], "]"}], ",", "t"}], "]"}]}], 
