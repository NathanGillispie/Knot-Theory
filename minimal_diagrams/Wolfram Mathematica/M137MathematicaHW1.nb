Cell["\<\
The command below produces the slope field of the differential equation.\
\>", "Text",
 CellChangeTimes->{{3.528108947773638*^9, 3.5281089955751953`*^9}, 
   3.6316214755258284`*^9},ExpressionUUID->"ed723f9b-08d6-4815-93bc-\
9b394cfe61b4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"a", ",", "b", ",", "\[Alpha]", ",", "\[Gamma]"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"a", ":=", ".6"}], "\[IndentingNewLine]", 
 RowBox[{"\[Alpha]", ":=", ".4"}], "\[IndentingNewLine]", 
 RowBox[{"c", ":=", ".5"}], "\[IndentingNewLine]", 
 RowBox[{"\[Gamma]", ":=", ".25"}], "\[IndentingNewLine]", 
 RowBox[{"slopefield", "=", 
  RowBox[{"VectorPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"a", "*", "x"}], "-", 
       RowBox[{"\[Alpha]", "*", "y", "*", "x"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "c"}], "*", "y"}], "+", 
       RowBox[{"\[Gamma]", "*", "y", "*", "x"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "7"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "0", ",", "5"}], "}"}], ",", 
    RowBox[{"VectorScale", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"Tiny", ",", "Automatic", ",", "None"}], "}"}]}], ",", 
    RowBox[{"FrameLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<rabbits \>\"", ",", 
          RowBox[{"Style", "[", 
           RowBox[{"\"\<x\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<foxes \>\"", ",", 
          RowBox[{"Style", "[", 
           RowBox[{"\"\<y\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], 
      "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{
  3.528110650748785*^9, {3.528110692829053*^9, 3.528110795135518*^9}, {
   3.528111770871592*^9, 3.528111776477483*^9}, {3.5281122115851927`*^9, 
