Cell[CellGroupData[{

Cell["Tutorial:  Fish in a Lake", "Subsection",
 CellChangeTimes->{{3.631536491044025*^9, 3.631536518994227*^9}, {
  3.6316220072742453`*^9, 3.6316220085066614`*^9}, {3.725727602889065*^9, 
  3.72572760752756*^9}, {3.725756708959071*^9, 
  3.72575670925351*^9}},ExpressionUUID->"dbfd5122-98ea-426e-a775-\
63e4e03f751a"],

Cell[TextData[{
 "Scientists use the differential equation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["dP", "dt"], "=", 
    RowBox[{"0.7", "P", " ", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       FractionBox["P", "9"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "299b7276-69ab-455a-9322-2b470a93d037"],
 " to predict future fish populations in Lake Minnetonka, where P represents \
the population in thousands of fish and t is in years.\n(i) Solve the \
differential equation\n(ii) Plot a slope field of the differential equation \
in a window that shows the important features.\n(iii) What happens if the \
initial fish population is twenty thousand? forty thousand, sixty thousand, \
eighty thousand and one hundred thousand?"
}], "Text",
 CellChangeTimes->{{3.725727614044794*^9, 3.7257276431420918`*^9}, {
  3.725728406536285*^9, 3.7257286487853317`*^9}, {3.7257564489401484`*^9, 
  3.725756455862876*^9}, {3.725756500536333*^9, 3.7257565392596607`*^9}, {
  3.72649551527349*^9, 
  3.726495515416389*^9}},ExpressionUUID->"78ec9ac0-2582-4215-ad3a-\
974b26700e8f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   FormBox[
    RowBox[{
     RowBox[{
      RowBox[{"P", "'"}], "[", "t", "]"}], "==", 
     RowBox[{"0.7", 
      RowBox[{"P", "[", "t", "]"}], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        FractionBox[
         RowBox[{"P", "[", "t", "]"}], "9"]}], ")"}]}]}],
    TraditionalForm], ",", 
   RowBox[{"P", "[", "t", "]"}], ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.725728852298689*^9, 3.725728875037951*^9}, {
  3.725728919011416*^9, 3.72572894945798*^9}, {3.725756462215271*^9, 
  3.725756464711425*^9}, {3.726495519653817*^9, 
  3.726495520941744*^9}},ExpressionUUID->"5b0e888e-2a96-4d1e-b733-\
15c863cabd62"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"P", "[", "t", "]"}], "\[Rule]", 
    FractionBox[
     RowBox[{"5.066549580791809`*^15", " ", 
      SuperscriptBox["2.718281828459045`", 
       RowBox[{"0.7000000000000001`", " ", "t"}]]}], 
     RowBox[{
      RowBox[{"5.62949953421312`*^14", " ", 
       SuperscriptBox["2.718281828459045`", 
        RowBox[{"0.7000000000000001`", " ", "t"}]]}], "+", 
      SuperscriptBox["2.718281828459045`", 
       RowBox[{"5.066549580791809`*^15", " ", 
        RowBox[{"C", "[", "1", "]"}]}]]}]]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{3.725728950395708*^9, 3.7257564675571957`*^9, 
  3.726495522326087*^9},ExpressionUUID->"f13e100a-ae39-449e-b2c2-\
28fb8ef83685"]
}, Open  ]],

