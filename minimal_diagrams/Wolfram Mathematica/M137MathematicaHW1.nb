Cell[CellGroupData[{

Cell["\<\
Tutorial: predator-prey model with two species, foxes and rabbits.\
\>", "Subsection",
 Evaluatable->False,
 CellChangeTimes->{{3.528050511344143*^9, 3.5280505308390923`*^9}, {
   3.528109993920311*^9, 3.52811000042187*^9}, 3.528112122089964*^9, {
   3.601819238222542*^9, 3.601819249915317*^9}},
 AspectRatioFixed->
  True,ExpressionUUID->"f6ae3c0d-2bc6-4132-a173-e59d45382627"],

Cell[TextData[{
 "This Demonstration illustrates the predator-prey model with two species, \
foxes and rabbits. Foxes prey on rabbits that live on vegetation. \n\nThe \
rabbit population is ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]], "InlineMath",ExpressionUUID->
  "033d6650-e905-4b55-9c5b-1f899ef6c5de"],
 " and the fox population is ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]], "InlineMath",ExpressionUUID->
  "48868c93-1ae6-4b41-8d82-b999c3240444"],
 "; both depend on time ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]], "InlineMath",ExpressionUUID->
  "174ffde1-cb8c-4805-9087-a4be4e1680c7"],
 "."
}], "Text",
 CellChangeTimes->{{3.528110525001738*^9, 
  3.5281105257191143`*^9}},ExpressionUUID->"0aaf22af-46bc-48fb-9b6a-\
aedf7ec64a8e"],

Cell[TextData[{
 "1. In the absence of foxes, the rabbit population grows at a rate \
proportional to its current population; thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"d", "\[InvisibleSpace]", 
     RowBox[{"x", "/", "d"}], "\[InvisibleSpace]", "t"}], "=", 
    RowBox[{"a", " ", "x"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"27efb810-5b6f-4940-b24d-283e3c47c95d"],
 " when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", "0"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "bab1e923-a4bf-49ea-9a31-b286a070b96c"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", ">", "0"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "600efa4d-f670-45a6-acf7-22794f142f48"],
 "."
}], "Text",ExpressionUUID->"121cc709-920d-48b3-9f85-7e29882327bc"],

Cell[TextData[{
 "2. In the absence of rabbits, the foxes die out; thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"d", "\[InvisibleSpace]", 
     RowBox[{"y", "/", "d"}], "\[InvisibleSpace]", "t"}], "=", 
    RowBox[{
     RowBox[{"-", "c"}], " ", "y"}]}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"c4c9c0e7-7578-4153-bc9a-fb725c77dc79"],
 " when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "0"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "2dfca1c5-fec1-4bd0-94c4-01abcce838d1"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", ">", "0"}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "c21ad639-3f83-46f7-9fb0-3ccbbcfca73f"],
 "."
}], "Text",ExpressionUUID->"2a80ffef-aac5-4f0a-9cfb-c1d2cb526629"],

Cell[TextData[{
 "3. The number of encounters between the species is proportional to the \
product of their populations. Each encounter tends to increase ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]], "InlineMath",ExpressionUUID->
  "969a25ec-8a99-418e-9981-6848c1eadf4a"],
 " and decrease ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]], "InlineMath",ExpressionUUID->
  "369d61c0-2dd1-4612-935b-a87d38e92fb3"],
 ". Thus the growth rate of ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]], "InlineMath",ExpressionUUID->
  "d0447629-5f74-40a5-9356-8269db8e76a0"],
 " includes a term of the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "\[Alpha]"}], " ", "x", " ", "y"}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"797b334a-1d4e-4fe9-96a5-1b174454a8a4"],
 " and that of ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]], "InlineMath",ExpressionUUID->
  "a028ba0b-2428-45e8-a4c1-e36b003f9c0e"],
 " includes a term of the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", " ", "x", " ", "y"}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"08a131f6-051c-40f7-bc61-baa685dc98f6"],
 ", where ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "67ee5d26-263e-4342-a68d-1c2edefe0fde"],
 " and ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "26eaa3ba-8105-4e4d-9973-e0f43b2cfa95"],
 " positive. The parameters ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]], "InlineMath",ExpressionUUID->
  "0257ce38-a022-4546-8c20-4768b68c6b49"],
 ", ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "393f8ab5-0584-464d-94ec-2228feb0fddd"],
 ", ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]], "InlineMath",ExpressionUUID->
  "12f37228-bd65-4fb3-92a3-e8c7f0b6acd0"],
 ", and ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]], "InlineMath",ExpressionUUID->
  "751a626a-fe35-4c2c-88ad-d9c3bf0aa003"],
 " are independent of ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]], "InlineMath",ExpressionUUID->
  "ae8b7174-ce0a-4024-b8a5-d1ef1ab6b607"],
 ". These assumptions lead to the equations:"
}], "Text",ExpressionUUID->"5b2c27ef-36dc-461e-82be-e88be67c805e"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"d", "\[InvisibleSpace]", "x"}], 
     RowBox[{"d", "\[InvisibleSpace]", "t"}]], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"a", " ", "x"}], "-", 
      RowBox[{"\[Alpha]", " ", "x", " ", "y"}]}], "=", 
     RowBox[{"x", "(", 
      RowBox[{"a", "-", 
       RowBox[{"\[Alpha]", " ", "y"}]}], ")"}]}]}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"7312895d-e9df-43ad-acab-c77eb94cce18"],
 ","
}], "Text",ExpressionUUID->"4b8e8b14-c049-4e77-a21d-f17d7a8cb344"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"d", "\[InvisibleSpace]", "y"}], 
     RowBox[{"d", "\[InvisibleSpace]", "t"}]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", "c"}], " ", "y"}], "+", 
      RowBox[{"\[Gamma]", " ", "x", " ", "y"}]}], "=", 
     RowBox[{"y", "(", 
      RowBox[{
       RowBox[{"-", "c"}], "+", 
       RowBox[{"\[Gamma]", " ", "x"}]}], ")"}]}]}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"f18ddad0-2ee2-4762-aaf8-db51f20e2b25"],
 "."
}], "Text",
 CellChangeTimes->{{3.726496049343717*^9, 
  3.726496051131537*^9}},ExpressionUUID->"e924775a-2e1c-42ea-8f95-\
6ce5b4a0bde6"],

Cell[TextData[{
 "Reference:\n[1] J. R. Brannan and W. E. Boyce, ",
 StyleBox["Differential Equations with Boundary Value Problems: An \
Introduction to Modern Methods and Applications",
  FontSlant->"Italic"],
 ", New York: John Wiley and Sons, 2010."
}], "Text",
 CellChangeTimes->{
  3.5281105766383266`*^9},ExpressionUUID->"81015453-f266-479c-9b83-\
69d4c334cd5f"],

Cell[TextData[{
 "Below we are solving the differential equations numerically. The starting \
conditions are chosen at random as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "1"}], "}"}], "."}], TraditionalForm]],ExpressionUUID->
  "62a26a97-77e6-4378-8422-06800b50ea6a"],
 " The time interval is chosen as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"start", ",", "stop"}], "]"}], TraditionalForm]],ExpressionUUID->
  "c56d43c8-8e8e-4cd2-885b-9b74a0e33909"],
 " at random."
}], "Text",
 CellChangeTimes->{{3.528110906261551*^9, 3.5281109205726357`*^9}, {
  3.528110968397628*^9, 3.5281110769439383`*^9}, {3.52811189470326*^9, 
  3.5281119044294987`*^9}},ExpressionUUID->"44b83a9f-7e4f-40e2-bb8c-\
42c314512e01"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"a", ",", "\[Alpha]", ",", "\[Gamma]", ",", "a", ",", "b"}], "]"}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "=", ".6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]", "=", ".4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "=", ".5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]", "=", ".25"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"start", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"stop", "=", "50"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"rabbitstart", ":=", "3.5"}], "\[IndentingNewLine]", 
 RowBox[{"foxstart", ":=", "1.5"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"x1", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"a", "*", 
            RowBox[{"x1", "[", "t", "]"}]}], "-", 
           RowBox[{"\[Alpha]", "*", 
            RowBox[{"y1", "[", "t", "]"}], "*", 
            RowBox[{"x1", "[", "t", "]"}]}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"y1", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "c"}], "*", 
            RowBox[{"y1", "[", "t", "]"}]}], "+", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y1", "[", "t", "]"}], "*", 
            RowBox[{"x1", "[", "t", "]"}]}]}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"x1", "[", "start", "]"}], "\[Equal]", "rabbitstart"}], ",", 
         RowBox[{
          RowBox[{"y1", "[", "start", "]"}], "\[Equal]", "foxstart"}]}], 
        "}"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x1", "[", "t", "]"}], ",", 
       RowBox[{"y1", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "start", ",", "stop"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"x2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"x1", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"y1", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"plotx", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"x2", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "start", ",", "stop"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<rabbits \>\"", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<x\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"0", ",", "10"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ploty", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"y2", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "start", ",", "stop"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<foxes \>\"", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<y\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"0", ",", "10"}], "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.528110959986334*^9, 3.5281109631220617`*^9}, 
   3.528111016932107*^9, {3.5281110809001703`*^9, 3.5281111889911833`*^9}, {
   3.5281112369444027`*^9, 3.528111261520083*^9}, {3.5281113214734983`*^9, 
   3.528111469253601*^9}, {3.5281115666958723`*^9, 3.5281115734212923`*^9}, {
   3.52811161651365*^9, 3.5281116267429247`*^9}, {3.5281118408825903`*^9, 
   3.52811185145851*^9}, {3.52811188294735*^9, 3.528111939421754*^9}, {
   3.631620828958016*^9, 
   3.631620829207619*^9}},ExpressionUUID->"dc5749ad-3de9-44b8-8bcc-\
26fa1e311d95"],

