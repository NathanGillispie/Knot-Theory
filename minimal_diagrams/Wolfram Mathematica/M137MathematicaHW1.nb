}, Open  ]],

Cell[TextData[{
 "Holding the same constants, look at  the differential equation  \n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"k", " ", 
      RowBox[{"y", "[", "t", "]"}]}], 
     RowBox[{"A", " ", "+", " ", 
      RowBox[{"y", "[", "t", "]"}]}]]}]}]],ExpressionUUID->
  "74e20a82-f256-4988-bba3-dfbe97247b24"],
 "\nagain.   Because ",
 Cell[BoxData[
  RowBox[{"y", "[", "t", "]"}]],ExpressionUUID->
  "0582d681-fa63-4042-ab78-241ce56105c3"],
 " is relatively large, you can expect  \n      ",
 Cell[BoxData[
  RowBox[{"-", 
   FractionBox[
    RowBox[{"k", " ", 
     RowBox[{"y", "[", "t", "]"}]}], 
    RowBox[{"A", " ", "+", " ", 
     RowBox[{"y", "[", "t", "]"}]}]]}]],ExpressionUUID->
  "7cf2c7ba-06b6-499c-92c3-fb6de86716c9"],
 "\nto be close to the global scale of  \n      ",
 Cell[BoxData[
  RowBox[{"-", 
   FractionBox[
    RowBox[{"k", " ", "y"}], 
    RowBox[{"A", "+", "y"}]]}]],ExpressionUUID->
  "a7bd334d-bf70-43e3-b945-d8fe96c1d7c1"],
 "\nwhich is      \n      ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     RowBox[{"k", " ", "y"}], "y"]}], "=", " ", 
   RowBox[{"-", "k"}]}]],ExpressionUUID->
  "cc9719fd-0893-483f-8b8a-1a4da52c79fb"],
 ".\nAs a result, you can expect the solution ",
 Cell[BoxData[
  RowBox[{"y", "[", "t", "]"}]],ExpressionUUID->
  "6d932db1-6a52-4bb6-a242-72f835c5c5c6"],
 " to plot out about the same as the line solution of\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"-", "k"}]}]],ExpressionUUID->
  "c4eceb46-0f6c-4a79-9fad-595d3cb4b8a3"],
 "\nuntil ",
 Cell[BoxData[
  RowBox[{"y", "[", "t", "]"}]],ExpressionUUID->
  "41c85d0a-b0e2-4ae0-a5f9-52d84266cf51"],
 " has decayed to the point at which it is very small.\nCheck this out."
}], "Text",ExpressionUUID->"f9b2166d-b81c-4a5c-ac85-a573ccc8be6f"],

Cell["Tip:", "Special1",ExpressionUUID->"cbcfdaa1-09df-4ff5-931b-e02c46b3770b"],

Cell[TextData[{
 "In case you've forgotten, the solution of  \n         ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"-", "k"}]}]],ExpressionUUID->
  "82a433da-5b68-46cc-af23-ebb129474e88"],
 " with a given ",
 Cell[BoxData[
  RowBox[{"y", "[", "0", "]"}]],ExpressionUUID->
  "3867a437-ecf2-496f-bd70-a1f5456a2ec6"],
 "\nhas a nice,easy formula. It is:\n         ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "k"}], " ", "t"}], " ", "+", " ", 
    RowBox[{"y", "[", "0", "]"}]}]}]],ExpressionUUID->
  "3d96ccac-e41f-453e-b111-9001f2360bc9"],
 " \nYou should know this formula cold. It's a matter of basic calculus \
literacy."
}], "SmallText",ExpressionUUID->"2a36d3c6-18b0-4811-9244-2837812bfdf4"],

Cell[TextData[{
 "(ii) Do a two more samples of your own choice with ",
 Cell[BoxData[
  RowBox[{"y", "[", "0", "]"}]],ExpressionUUID->
  "6a943b36-5bdf-4d13-bad3-be405d2c9149"],
 " large relative to ",
 Cell[BoxData["A"],ExpressionUUID->"7333d84f-4a50-4582-9936-f5313cf49e43"],
 " and then say why you think most pharmacokineticists are happy to replace \
the basic model   \n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"k", " ", 
      RowBox[{"y", "[", "t", "]"}]}], 
     RowBox[{"A", " ", "+", " ", 
      RowBox[{"y", "[", "t", "]"}]}]]}]}]],ExpressionUUID->
  "982bba36-b5e2-4664-b95c-509d4207494a"],
 "\n        with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "0", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"concentration", " ", "at", " ", "time", " ", "t"}], " ", "=", 
    " ", "0"}]}]],ExpressionUUID->"265b60bf-0a8c-405e-a5fa-5175cd742654"],
 "\nby the simpler linear model\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"-", "k"}]}]],ExpressionUUID->
  "30196bdb-a8e0-4b85-8084-c37d69b98b6c"],
 "\n        with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "0", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"concentration", " ", "at", " ", "time", " ", "t"}], " ", "=", 
    " ", "0"}]}]],ExpressionUUID->"7fa2997f-a1fd-45e2-9408-3a86dfac1d0f"],
 "."
}], "Text",
 CellChangeTimes->{{3.757204588129816*^9, 3.7572045892014236`*^9}, {
  3.757270624008245*^9, 
  3.757270625335896*^9}},ExpressionUUID->"619bb89f-49c4-400c-9c5a-\
1acebc74cce1"],

Cell["\<\
(iii) Explain why most folks say that alcohol concentration decays linearly \
until the alcohol concentration decays to the level at which no one cares.\
\>", "Text",
 CellChangeTimes->{{3.7572046043781023`*^9, 
  3.757204605849907*^9}},ExpressionUUID->"3a163ff1-d249-4e89-9b5c-\
e020956f84cb"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Epidemics", "Subsection",
 CellChangeTimes->{{3.7572047837219677`*^9, 3.757204785159812*^9}},
 CellTags->"1.08.G8",ExpressionUUID->"75ddad51-1b77-4ea0-b3c4-b2271975436f"],

Cell["\<\
This model was developed by W, O. Kermack and A. G. McKendrick and was \
studied in their papers titled
\"Contributions to the mathematical theory of epidemics\", Proceedings of the \
Royal Society A, 115, 700-721 (1927); 138, 55-83 (1932); 141,94-122 (1933). \
It forms the base for many epidemic models used today.\
\>", "Special2",ExpressionUUID->"e97d93b3-f6c1-4505-84d7-a7c712135fd3"],

Cell[TextData[{
 "The SIR model deals with disease in a closed population. This model is \
geared at diseases like certain strains of flu which confer immunity to those \
who contract the disease and recover. Put \n       ",
 Cell[BoxData[{
  RowBox[{
   RowBox[{"Sus", "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
   "the", " ", "number", " ", "of", " ", "susceptible", " ", "people", " ", 
    "at", " ", "time", " ", "t", " "}]}], "\n", 
  RowBox[{"\t\t\t\t\t\t\t\t\t\t\t\t", 
   RowBox[{
    RowBox[{"after", " ", "measurements", " ", "begin"}], ";"}]}]}],
  ExpressionUUID->"a2a7a51c-d5c3-4e6d-83b2-341b37d0e39d"],
 "\n       ",
 Cell[BoxData[
  RowBox[{"\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Inf", "[", "t", "]"}], " ", "=", " ", 
     RowBox[{
     "the", " ", "number", " ", "of", " ", "infected", " ", "people", " ", 
      "at", " ", "time", " ", "t", " "}]}], "\n", "\t\t\t\t\t\t\t\t\t\t\t\t", 
    
    RowBox[{
     RowBox[{"after", " ", "measurements", " ", "begin"}], ";"}]}]}]],
  ExpressionUUID->"76b4af76-20d6-4c56-a5f3-3a89c034ecf5"],
 "\n       ",
 Cell[BoxData[
  RowBox[{"\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Recov", "[", "t", "]"}], " ", "=", " ", 
     RowBox[{
     "the", " ", "number", " ", "of", " ", "recovered", " ", "people", " ", 
      "at", " ", "time", " ", "t", " "}]}], "\n", "\t\t\t\t\t\t\t\t\t\t\t\t", 
    
    RowBox[{"after", " ", "measurements", " ", 
     RowBox[{"begin", "."}]}]}]}]],ExpressionUUID->
  "f19001cd-1758-4a58-9bff-745adc801c5b"],
 "\n\nThe model says that there are positive constants ",
 Cell[BoxData["a"],ExpressionUUID->"c4e2efea-17a9-47f8-a819-66ebee5aac0b"],
 " and ",
 Cell[BoxData["b"],ExpressionUUID->"5d4cc086-adf7-45fe-aafe-87e93b0f6a75"],
 " such that\n      ",
 Cell[BoxData[
  RowBox[{" ", 
   RowBox[{
    RowBox[{
     RowBox[{"Sus", "'"}], "[", "t", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", "a"}], " ", 
     RowBox[{"Sus", "[", "t", "]"}], " ", 
     RowBox[{"Inf", "[", "t", "]"}]}]}]}]],ExpressionUUID->
  "e9e39547-3a82-4052-865e-a0ee1ca53605"],
 "\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Recov", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"b", " ", 
    RowBox[{
     RowBox[{"Inf", "[", "t", "]"}], "."}]}]}]],ExpressionUUID->
  "883ebbf2-6e0b-45f5-9d2f-ed8bf8db6205"],
 "\nThis says that the number of susceptible decreases at a rate jointly \
proportional to the number of susceptible and the number of infected. And \
this says that the recovery rate is proportional to the number of infected.\n\
\nYou also know that \n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Sus", "[", "t", "]"}], " ", "+", " ", 
    RowBox[{"Inf", "[", "t", "]"}], " ", "+", " ", 
    RowBox[{"Recov", "[", "t", "]"}]}], " ", "="}]],ExpressionUUID->
  "ebc18777-1318-4704-8933-c955f82d51e5"],
 "  ",
 Cell[BoxData[
  RowBox[{
  "total", " ", "size", " ", "of", " ", "the", " ", "population", " ", 
   "under", " ", 
   RowBox[{"study", "."}]}]],ExpressionUUID->
  "40a9be5e-d202-4aeb-859f-6b38e35053f7"],
 " \n\nFor the purposes of this problem, assume that the total population \
stays constant.  This tells you\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Sus", "'"}], "[", "t", "]"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Inf", "'"}], "[", "t", "]"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Recov", "'"}], "[", "t", "]"}]}], " ", "=", " ", "0"}], ";"}]],
  ExpressionUUID->"728fd243-df15-4bbf-a719-b7caf031ecc9"],
 "\nso \n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Inf", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{
      RowBox[{"Sus", "'"}], "[", "t", "]"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{"Recov", "'"}], "[", "t", "]"}]}]}]],ExpressionUUID->
  "fb319641-4ad7-41f3-be40-ff94d763afab"],
 " \n             ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"=", " ", 
    RowBox[{"a", " ", 
     RowBox[{"Sus", "[", "t", "]"}], " ", 
     RowBox[{"Inf", "[", "t", "]"}]}]}], " ", "-", " ", 
   RowBox[{"b", " ", 
    RowBox[{
     RowBox[{"Inf", "[", "t", "]"}], "."}]}]}]],ExpressionUUID->
  "1c00b98c-5e6c-4b0c-8232-c18820c94b86"],
 "\nThis gives you the full SIR epidemic model:\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Sus", "'"}], "[", "t", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", " ", "a"}], " ", 
     RowBox[{"Sus", "[", "t", "]"}], " ", 
     RowBox[{"Inf", "[", "t", "]"}]}]}], ","}]],ExpressionUUID->
  "70dd02e9-3e05-45aa-b681-117e734d4fc1"],
 "\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Inf", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"a", " ", 
     RowBox[{"Sus", "[", "t", "]"}], " ", 
     RowBox[{"Inf", "[", "t", "]"}]}], " ", "-", " ", 
    RowBox[{"b", " ", 
     RowBox[{"Inf", "[", "t", "]"}]}]}]}]],ExpressionUUID->
  "970947e0-0901-4f4c-b9f2-33de8cc6b8c0"],
 "\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Recov", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"b", " ", 
    RowBox[{
     RowBox[{"Inf", "[", "t", "]"}], "."}]}]}]],ExpressionUUID->
  "3228357e-e113-4276-85d5-e1012f361ce0"],
 "\n        with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Sus", "[", "0", "]"}], " ", "=", " ", 
   RowBox[{"number", " ", "of", " ", "susceptibles"}]}]],ExpressionUUID->
  "2d715c1f-6101-4101-a097-9c581221b703"],
 ", ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Inf", "[", "0", "]"}], " ", "=", " ", 
   RowBox[{"number", " ", "of", " ", "infecteds"}]}]],ExpressionUUID->
  "ca0a41da-b499-4da3-8dc5-01b7a1987aed"],
 ",\n        and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Recov", "[", "0", "]"}], " ", "=", " ", 
   RowBox[{
   "number", " ", "of", " ", "recovered", " ", "at", " ", "the", " ", "time", 
    " ", "the", " ", "measurements", " ", 
    RowBox[{"begin", "."}]}]}]],ExpressionUUID->
  "0217f088-3f52-403f-87ff-971e64cf6dea"],
 " "
}], "Text",
 CellChangeTimes->{{3.757204860531725*^9, 
  3.757204873181397*^9}},ExpressionUUID->"2334dd63-3601-42df-a3f5-\
60c5427d69d3"],

Cell[CellGroupData[{

Cell["British Flu", "Subsubsection",
 CellChangeTimes->{{3.757204955711928*^9, 
  3.757204960222439*^9}},ExpressionUUID->"97b27931-2394-4d5a-8e6b-\
bdca11752063"],

Cell["\<\
This information was secured from the book Mathematical Biology by J. D. \
Murray (Springer-Verlag, 1990). For a lot more on the modeling of epidemics, \
see this book.\
\>", "Special2",ExpressionUUID->"498dbca7-0a73-4790-887a-9d41ac2798b7"],

Cell[TextData[{
 "The March 4, 1978, issue of the British Medical Journal reported all the \
details about a flu epidemic that swept through a boarding school in early \
1978. Scientists were delighted that the actual data fell in line with those \
predicted by the SIR model.\nThe model for this epidemic is:\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Sus", "'"}], "[", "t", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", "a"}], " ", 
     RowBox[{"Sus", "[", "t", "]"}], " ", 
     RowBox[{"Inf", "[", "t", "]"}]}]}], ","}]],ExpressionUUID->
  "ef0639e4-b301-4b88-9c38-6fd73520f926"],
 "\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Inf", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"a", " ", 
     RowBox[{"Sus", "[", "t", "]"}], " ", 
     RowBox[{"Inf", "[", "t", "]"}]}], " ", "-", " ", 
    RowBox[{"b", " ", 
     RowBox[{
      RowBox[{"Inf", "[", "t", "]"}], "."}]}]}]}]],ExpressionUUID->
  "f3004e33-154c-4792-8bb0-5e2213a39e26"],
 "\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Recov", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"b", " ", 
    RowBox[{"Inf", "[", "t", "]"}]}]}]],ExpressionUUID->
  "66a38f87-20df-4a1b-b491-1022df50e92f"],
 " \n        with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Sus", "[", "0", "]"}], " ", "=", " ", "762"}]],ExpressionUUID->
  "a7258b12-43ab-4d24-85b9-8bed0d3a9bad"],
 ",  ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Inf", "[", "0", "]"}], " ", "=", " ", "1"}]],ExpressionUUID->
  "b13ed76e-da9a-4bae-bedf-5fdc7d731af5"],
 ", ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Recov", "[", "0", "]"}], " ", "=", " ", "0"}]],ExpressionUUID->
  "8cc9995f-1008-45ca-a260-a2e9a1eed229"],
 ", \n        ",
 Cell[BoxData[
  RowBox[{"a", " ", "=", " ", "0.00218"}]],ExpressionUUID->
  "e9dd7bfc-0fbd-4485-b050-34cf177d32b4"],
 " and ",
 Cell[BoxData[
  RowBox[{"b", " ", "=", "0.44036"}]],ExpressionUUID->
  "881b33d4-6848-4d68-810d-3333a9d57d4b"],
 "."
}], "Text",ExpressionUUID->"d401a824-7ee4-42f9-951e-ffbcaafa86d2"],

Cell["One runny-nosed brat caused all the trouble.", "Special2",ExpressionUUID->"5b039356-8c7f-41e8-86fa-d3204118e6ab"],

Cell[TextData[{
 "(i) Replay this epidemic by plotting ",
 Cell[BoxData[
  RowBox[{"Sus", "[", "t", "]"}]],ExpressionUUID->
  "8cf40fd3-e2bb-46bc-8725-5d9f11eeda6e"],
 " and ",
 Cell[BoxData[
  RowBox[{"Inf", "[", "t", "]"}]],ExpressionUUID->
  "c5f2399f-9c9b-4e4f-8c6f-23caa3c3b588"],
 " for ",
 Cell[BoxData[
  RowBox[{
  "0", " ", "\[LessEqual]", " ", "t", " ", "\[LessEqual]", " ", "14"}]],
  ExpressionUUID->"7fdf1a6d-7b82-4229-9208-9170bc276798"],
 " with ",
 Cell[BoxData["t"],ExpressionUUID->"e58fcc97-6829-4735-bd6a-2b9c67adc6c9"],
 " measured in days.\nComment on its severity."
}], "Text",
 CellChangeTimes->{{3.757205006975842*^9, 
  3.757205007911675*^9}},ExpressionUUID->"88429675-f14c-43ec-9686-\
24b456a4f825"],

Cell["Tip:", "Special1",ExpressionUUID->"910cc61d-f090-4f45-9aed-5f6fe641bb2e"],

Cell["Take the predator-prey code, edit it, and run it.", "SmallText",ExpressionUUID->"dad155e2-8c8a-421f-b464-7a7c3b51b2df"],

Cell[TextData[{
 "(ii)  Go back to the basic SIR model:\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Sus", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"-", " ", "a"}], " ", 
    RowBox[{"Sus", "[", "t", "]"}], " ", 
    RowBox[{"Inf", "[", "t", "]"}]}]}]],ExpressionUUID->
  "04fd633d-20ef-43d6-9cb6-1e7f2b4ca2e2"],
 ",\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Inf", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"a", " ", 
     RowBox[{"Sus", "[", "t", "]"}], " ", 
     RowBox[{"Inf", "[", "t", "]"}]}], " ", "-", " ", 
    RowBox[{"b", " ", 
     RowBox[{"Inf", "[", "t", "]"}]}]}]}]],ExpressionUUID->
  "199fa294-d656-4cae-9c1c-71e23a50ee55"],
 ",\n        ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Recov", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"b", " ", 
    RowBox[{"Inf", "[", "t", "]"}]}]}]],ExpressionUUID->
  "11fb12d7-2673-432f-bf47-7206a18e6bc2"],
 ".\nWhy is it common sense that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Sus", "'"}], "[", "t", "]"}], " ", "<", " ", "0"}]],
  ExpressionUUID->"fa8b5cd2-bd2b-4b4b-8fca-b6400d7ebc4f"],
 "; so that ",
 Cell[BoxData[
  RowBox[{"Sus", "[", "t", "]"}]],ExpressionUUID->
  "3fa6c6ce-023f-4168-ad5f-e0a8125fb187"],
 " goes down as time goes up?"
}], "Text",
 CellChangeTimes->{{3.757205010928084*^9, 
  3.7572050118960333`*^9}},ExpressionUUID->"67becfd9-eb32-43c1-bcee-\
99bf9d99f356"],

Cell["Tip:", "Special1",ExpressionUUID->"c1e7f5db-5391-479e-a18d-314ca8c721c8"],

Cell["Once someone recovers, that person is immune.", "SmallText",ExpressionUUID->"9fe0f80f-0843-473c-a4d8-e5d66cdb4aa6"],

Cell[TextData[{
 "(iii) On the basis of part (ii) above, you know that\n           ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Sus", "[", "0", "]"}], " ", "\[GreaterEqual]", " ", 
   RowBox[{"Sus", "[", "t", "]"}]}]],ExpressionUUID->
  "02670cd7-d998-4cdc-b09d-6ada1b19720b"],
 " for ",
 Cell[BoxData[
  RowBox[{"t", " ", "\[GreaterEqual]", " ", "0"}]],ExpressionUUID->
  "1f0a6cef-51be-46cc-8326-013c79124741"],
 ".\nNow look at the key ingredient of the model:\n ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"Inf", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"a", " ", 
     RowBox[{"Sus", "[", "t", "]"}], " ", 
     RowBox[{"Inf", "[", "t", "]"}]}], " ", "-", " ", 
    RowBox[{"b", " ", 
     RowBox[{"Inf", "[", "t", "]"}]}]}]}]],ExpressionUUID->
  "2dc3b31b-dff9-4ed6-8e8e-342ef5b17eb9"],
 "\n                ",
 Cell[BoxData[
  RowBox[{"=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       RowBox[{"Sus", "[", "t", "]"}]}], " ", "-", " ", "b"}], ")"}], " ", 
    RowBox[{"Inf", "[", "t", "]"}]}]}]],ExpressionUUID->
  "fc2eaa02-50f0-4067-956c-1cf00ee1d341"],
 ".\nExplain the statements:\n\[Rule] If ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Sus", "[", "0", "]"}], " ", "<", " ", 
   FractionBox["b", "a"]}]],ExpressionUUID->
  "51d90151-c95a-4fdf-a283-c035c86a2e2c"],
 ", then the model predicts no epidemic because in this case ",
 Cell[BoxData[
  RowBox[{"Inf", "[", "t", "]"}]],ExpressionUUID->
  "a11f2ebd-3fd9-4bb9-a405-94960aa55e26"],
 " goes down as ",
 Cell[BoxData["t"],ExpressionUUID->"7ad949c9-4602-4248-9849-0978fecf8432"],
 " goes up."
}], "Text",
 CellChangeTimes->{{3.757205036882904*^9, 
  3.7572050552820387`*^9}},ExpressionUUID->"340fcc3c-c172-45a0-8792-\
50af55fd9677"],

Cell[TextData[{
 "\[Rule] If ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Sus", "[", "0", "]"}], " ", ">", 
   FractionBox["b", "a"]}]],ExpressionUUID->
  "9a55a48a-3da0-41d7-8f56-db1fa9b8318b"],
 ", then the model predicts that the disease will spread and the infected \
population will increase until ",
 Cell[BoxData[
  RowBox[{"S", "[", "t", "]"}]],ExpressionUUID->
  "a4108a6f-6347-4b4e-b7c7-6b9b11046b17"],
 " gets small enough that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Sus", "[", "t", "]"}], " ", "<", 
   FractionBox["b", "a"]}]],ExpressionUUID->
  "b85764f9-32ac-466c-bcdd-fde52d8b043e"],
 ". \nIn other words, if ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Sus", "[", "0", "]"}], " ", ">", " ", 
   FractionBox["b", "a"]}]],ExpressionUUID->
  "74141861-355f-4e41-abc2-26f81f6a575a"],
 ", then an epidemic is in the cards. "
}], "Text",ExpressionUUID->"c618c37c-6493-4da7-8cc3-6f0e5985c051"],

Cell[TextData[{
 "(iv) Take the boarding school data and show the plots of ",
 Cell[BoxData[
  RowBox[{"Sus", "[", "t", "]"}]],ExpressionUUID->
  "1bde41be-e4c9-49c5-9b10-5f4573fad6aa"],
 " and ",
 Cell[BoxData[
  RowBox[{"Inf", "[", "t", "]"}]],ExpressionUUID->
  "246f4456-a3b0-43de-948a-b0973096d1cc"],
 " together with the horizontal line through ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"0", ",", 
    RowBox[{"b", "/", "a"}]}], "}"}]],ExpressionUUID->
  "3992bf86-44fc-465e-8ffb-45de1e63d085"],
 " on the vertical axis.\nDoes this plot confirm the second statement in part \
ii)?"
}], "Text",
 CellChangeTimes->{{3.757205132005929*^9, 
  3.757205133484427*^9}},ExpressionUUID->"4e7c0ed4-a136-43ca-881a-\
75727cb59ee0"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Prairie Dogs and Black-Footed Ferrets.", "Subsection",
 CellChangeTimes->{{3.631536491044025*^9, 3.631536518994227*^9}, {
  3.6316220072742453`*^9, 
  3.6316220085066614`*^9}},ExpressionUUID->"b93a1f8b-a6be-4596-833e-\
60e845c0f2ff"],

Cell[TextData[{
 "Consider a predator-prey relation shit between Prairie Dogs (prey) and \
Black-Footed Ferrets (predator).\nLet ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "(", "t", ")"}], "=", " "}], TraditionalForm]],
  ExpressionUUID->"ddc34914-0e77-451b-9192-4f8dfd953dc2"],
 "Prairie Dogs at time t,\nLet ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"y", "(", "t", ")"}], "=", " "}], TraditionalForm]],
  ExpressionUUID->"e7e6fc03-a131-43b8-adee-49137d571a2b"],
 "Black-Footed Ferrets at time t,\nwhere ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "3242847c-870f-4b8f-9bd6-8203fa145a5f"],
 " is measured in months.\nThe predator-prey model is\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["dx", "dt"], "=", 
    RowBox[{
     RowBox[{"0.1", "x"}], "-", 
     RowBox[{"0.00009", "x", " ", "y"}]}]}], TraditionalForm]],
  ExpressionUUID->"6afe8b63-548a-4fca-809a-858836b1e0ed"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["dy", "dt"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "0.4"}], "y"}], "+", 
     RowBox[{"0000.00004", "x", " ", "y"}]}]}], TraditionalForm]],
  ExpressionUUID->"faa71565-713c-44bc-ad67-2793d45c3243"],
 ",\nwhere at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "f5bc87f4-7fee-4e51-96c2-5b0e11bf8534"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "4000"}], TraditionalForm]],ExpressionUUID->
  "1d08a8d4-c16c-4d30-aa58-5bf64c81529f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", "1000"}], TraditionalForm]],ExpressionUUID->
  "6890f108-eaa5-4778-8843-57116f1b717c"],
 ".\na. Find the critical points of the model\nb. (i) Solve the system \
numerically for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", "t", "\[LessEqual]", "240"}], 
   TraditionalForm]],ExpressionUUID->"d7bf0451-517b-4eb6-bc73-11738635a816"],
 " and plot the curves for each species.\n(ii) Describe the populations \
maximum and minium for each species.\n(iii) How long does it take between two \
maxima for each species?\nc. Plot the slope field of the equation together \
with your solution curve in a prey-predator plane."
}], "Text",
 CellChangeTimes->{{3.631536548337001*^9, 3.631536884331526*^9}, {
  3.631536936489259*^9, 3.6315370029906588`*^9}, {3.6322243549030423`*^9, 
  3.6322243555738597`*^9}, {3.6322247181082745`*^9, 3.6322247192314887`*^9}, {
  3.725727024496422*^9, 
  3.725727047909251*^9}},ExpressionUUID->"9c3f8386-0eb7-4f5d-9a28-\
04f0ee9c5210"]
}, Closed]],

Cell[CellGroupData[{

Cell["Warfare.", "Subsection",
 CellChangeTimes->{{3.631536491044025*^9, 
  3.6315365417212753`*^9}},ExpressionUUID->"994f4a5f-a91e-4a54-9963-\
2c6418941bb2"],

Cell[TextData[{
 "A scientist who tried to apply calculus to warfare in the way you will see \
below was F. W. Lanchester, who worked in Britain during World War I. In his \
honor, fancy folks call all these models by the name Lanchesterian models. \
The Problem below is from Calculus and ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " by Davis, Porta and Uhl."
}], "Special2",
 CellChangeTimes->{
  3.5281121317377462`*^9, {3.631537409647559*^9, 3.631537429493279*^9}, {
   3.631537494714593*^9, 
   3.631537509673913*^9}},ExpressionUUID->"fb288656-0c10-4f81-a6db-\
60c365bc8b15"],

Cell["\<\
1. a) The good guys and the bad guys are engaged in combat. Agree that \
good[t] is the number of good guys still fighting t days after combat begins, \
and let bad[t] be the number of bad guys still fighting t days after combat \
begins.
If neither side receives reinforcing troops, then why is it natural to \
propose a model
         good'[t] = - a bad[t]
         bad'[t] = - b good[t]
where a and b are positive numbers?\
\>", "Text",
 CellChangeTimes->{
  3.6315370181116037`*^9},ExpressionUUID->"2798e8ad-bb55-4a3a-856b-\
062aa728cc26"],

Cell["\<\
2. b.i)If the good guys bring in new troops at a rate of f[t] new troops per \
day and the bad guys bring in new troops at a rate of g[t] new troops per \
day, then why is it natural to propose a model 
         good'[t] = - a bad[t] + f[t]
         bad'[t] = - b good[t] + g[t]
where a and b are positive numbers?\
\>", "Text",
 CellChangeTimes->{
  3.631537024807425*^9},ExpressionUUID->"18f9153e-93af-4165-8520-\
88719da4d140"],

Cell[TextData[{
 "b.ii)",
 "Agree that the good guys win if bad[t] becomes 0 before good[t] becomes 0 \
and that the bad guys win if good[t] becomes 0 before bad[t] becomes 0.\nThe \
model\n         good'[t] = - 0.5 bad[t] + ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Sin", "2"], TraditionalForm]],ExpressionUUID->
  "83b33429-02c1-4418-be00-cb7026dadcdd"],
 "[t]\n         bad'[t] = - 0.5 good[t] + ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Cos", "2"], TraditionalForm]],ExpressionUUID->
  "62fa287c-862f-458d-a97a-e6dcb1e79adf"],
 "[t]\nwith  good[0] = bad[0] = 2\nsuggests the situation in which the troops \
on both sides are equally effective and at the start (t = 0) they are of \
equal strength.  The main difference is that the reinforcement rates are out \
of phase with the bad guys holding the initial advantage because \n      ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Cos", "2"], TraditionalForm]],ExpressionUUID->
  "2ff1254f-f92f-4390-839b-a637a5bb6c01"],
 "[0]= 1 > 0 = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Sin", "2"], TraditionalForm]],ExpressionUUID->
  "6b4c6d56-bbb5-491c-91b0-8be006906387"],
 "[0].\nThis suggests that the good guys lose.\nCheck this out by plotting \
good[t] and bad[t] and showing both curves together in a plot.\nDetermine how \
many days pass before the good guys are gone."
}], "Text",
 CellChangeTimes->{{3.52811229590961*^9, 3.528112301555182*^9}, {
   3.631535501516336*^9, 3.631535504211289*^9}, 
   3.631537032055369*^9},ExpressionUUID->"d5a76429-633a-424d-850a-\
c51e3b4af957"],

Cell[TextData[{
 "b.iii) ",
 "The good guys find that they lose above, so they double their \
reinforcements.  This gives the model:\n      good'[t] = - 0.5 bad[t] + 2 ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Sin", "2"], TraditionalForm]],ExpressionUUID->
  "64cad959-6ca2-4a1c-9ef0-d9e69e6fc987"],
 "[t]\n      bad'[t] = - 0.5 good[t] + ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Cos", "2"], TraditionalForm]],ExpressionUUID->
  "c9730fb7-b542-4be5-9add-5e712646f9db"],
 "[t]\nwith good[0] = bad[0] = 2.\nWho wins and how long does the battle \
last?\nCheck this out by plotting good[t] and bad[t] and showing both curves \
together in a graph."
}], "Text",
 CellChangeTimes->{{3.528112396583046*^9, 3.528112397014799*^9}, 
   3.631535558950056*^9, {3.6315370444546833`*^9, 
   3.631537045205546*^9}},ExpressionUUID->"383255be-ef76-4c49-847b-\
11d9f3cd25d9"],

Cell[TextData[{
 "b.iv) ",
 "This time the good guys have antiquated ammunition and heavy bureaucratic \
problems.  As a result, their troops are only half as effective as the troops \
of the bad guys.  This suggests the model:\n      good'[t] = -0.5 bad[t] +  2 \
",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Sin", "2"], TraditionalForm]],ExpressionUUID->
  "63a9782e-0df7-41fe-b778-7e2f1e3d411f"],
 "[t]\n      bad'[t] = -0.25 good[t] + ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Cos", "2"], TraditionalForm]],ExpressionUUID->
  "8144169f-9278-4721-93c2-2f0e435efbdd"],
 "[t]\nwith good[0] = bad[0] = 2.   Who wins and how long does the battle \
last?\nCheck this out by plotting good[t] and bad[t] and showing both curves \
together in a graph."
}], "Text",
 CellChangeTimes->{{3.528112413551647*^9, 3.528112413887154*^9}, {
  3.631535542578513*^9, 3.631535545889566*^9}, {3.631537052414431*^9, 
  3.631537053237279*^9}},ExpressionUUID->"5526b4ab-d59c-43f4-87ef-\
a2a211aae13a"],

Cell[TextData[{
 "b.v) ",
 "Again the good guys have antiquated ammunition and heavy bureaucratic \
problems.  As a result, their troops are only half as effective as the troops \
of the bad guys, so they decide to find a positive number r as small as \
practical such that if \n      good'[t] = - 0.5 bad[t] +  r ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Sin", "2"], TraditionalForm]],ExpressionUUID->
  "c5fb340d-c92b-4954-8125-5b71024c9dbf"],
 "[t]\n      bad'[t] = - 0.25 good[t] + ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Cos", "2"], TraditionalForm]],ExpressionUUID->
  "e757ffda-6546-48ff-9870-1465a521232d"],
 "[t]\nwith good[0] = bad[0] = 2,\nthen the good guys do not lose during the \
first 15 days.    Estimate how small r can be."
}], "Text",
 CellChangeTimes->{{3.631537060126234*^9, 
  3.631537061013028*^9}},ExpressionUUID->"fe5eac0d-2149-480d-8f02-\
8d456c975397"],

Cell["Tip: Experiment with different r's.", "SmallText",
 CellChangeTimes->{{3.63153707276435*^9, 
  3.631537073995631*^9}},ExpressionUUID->"798516d6-6137-490d-8fd1-\
7ac1144c183c"],

Cell["3. c.i) Iwo Jima", "Text",
 CellChangeTimes->{{3.631535625878158*^9, 
  3.631535626270041*^9}},ExpressionUUID->"b85046ba-e3dc-45c6-a343-\
e9662322fae8"],

Cell["\<\
This problem originates in the book  Differential Equations and Their \
Applications 
by Martin Braun, Springer-Verlag, 1978.    If you like this stuff, you'll \
want to look at this book, 
paying special attention to section 4.3.\
\>", "Special2",ExpressionUUID->"524c18ba-7e72-4b9a-b824-e7d465c968bf"],

Cell["\<\
Iwo Jima is the largest of the volcano islands in the western Pacific Ocean.  \
During World War II, it was a big Japanese air base. During February and \
March, 1945, American marines took it at great cost in a bloody assault.  If \
you have been to Washington, D.C., you may have seen the Iwo Jima memorial \
statue which depicts U.S. Marines planting the Stars and Stripes on the beach \
during a very bloody stage of the battle.
The Americans kept careful records during their losses, and the records \
confirm that the Iwo Jima battle is correctly modeled by the ideas in the \
Lanchesterian model above.
Here comes the nitty-gritty:
Agree that usa[t] measures the number of active American troops and japan[t] \
measures the number of active Japanese troops engaged in the battle t days \
after the battle began.
For this battle, military scientists have arrived at the model 
       usa'[t] = -0.0544 japan[t] + f[t]
       japan'[t] = -0.0106 usa[t] + g[t]
where f[t] and g[t] are the reinforcement rates.\
\>", "Text",
 CellChangeTimes->{{3.631537087741173*^9, 
  3.631537106538559*^9}},ExpressionUUID->"758572fa-f862-4930-93af-\
f8922a2ed8c4"],

Cell["\<\
The individual Japanese troop was 5 times more effective than the individual \
American troop because the 
Japanese held a defensive position.\
\>", "Special2",ExpressionUUID->"6620b019-e8dd-4f10-98a3-ebe68e1c3c75"],

Cell["\<\
At the beginning of the battle, 
       usa[0] = 5.4 and japan[0] = 2.15 with units measured in tens of \
thousands.
The reinforcement rate for Japan was  g[t] = 0. There were no Japanese \
reinforcements.\
\>", "Text",ExpressionUUID->"cc07e423-87e4-4101-b911-6429a92e3344"],

Cell["\<\
The Americans piled in 5.4 (tens of thousands of) troops at the beginning of \
the battle (t = 0), 0 extra troops during the first and second day, 0.6 \
troops spread out over the third day, 0 troops during the fourth and fifth \
days, 1.3 troops spread out over the sixth day, and no other reinforcements.\
\>", "Text",ExpressionUUID->"cc65d19e-3dc3-4484-9938-de52289cc9ec"],

Cell["Remember that troops are measured in tens of thousands.", "Special2",ExpressionUUID->"a404564f-42aa-4601-b19a-39dbc1bd68f0"],

Cell["\<\
The Americans considered the island secure after 28 days of battle. Replay \
the battle of Iwo Jima by giving plots of usa[t] and japan[t] for the first \
28 days.\
\>", "Text",ExpressionUUID->"a65b151a-518e-4a73-a11e-3c0da0a75cb6"],

Cell["\<\
3.c.ii) In actuality, there were 5.28 (tens of thousands) American troops in \
the field on day 28. Compare this with the value predicted by the model.\
\>", "Text",
 CellChangeTimes->{{3.631537113795659*^9, 
  3.6315371144507236`*^9}},ExpressionUUID->"1e257882-94d7-422c-97d9-\
288fbf88d96b"],

Cell["\<\
Tip: Don't expect the model to be totally accurate. There is always a gap \
between models and reality. If you got a big discrepancy, then you did \
something wrong.\
\>", "SmallText",
 CellChangeTimes->{{3.631537121787468*^9, 
  3.631537122042376*^9}},ExpressionUUID->"7161c779-98d7-4e80-99c4-\
31c2e887ea15"],

Cell["\<\
3.c.iii) Estimate:\tHow many American troops were knocked out of action?
How many Japanese troops bit the dust?\
\>", "Text",
 CellChangeTimes->{{3.631537128971019*^9, 
  3.631537129210095*^9}},ExpressionUUID->"f53ac7ee-a6c6-4caa-9ed7-\
2445ea0f3d6e"],

Cell["\<\
3.d.i) Modifying the Battle of Iwo Jima 
Take the battle of Iwo Jima model       
        usa'[t] = -0.0544 japan[t] + f[t]
      \[NonBreakingSpace]\[NonBreakingSpace]\[NonBreakingSpace]\
\[NonBreakingSpace]  japan'[t] = -0.0106 usa[t] + g[t]
     with  usa[0] = 5.4 and japan[0] = 2.15  where f[t] and g[t] are the \
reinforcement rates.
Report what might have happened if the Americans had no reinforcements. 
Would the Americans still have won in 28 days?   How long would it have taken \
to secure the island? 
How many American troops would have been lost? \
\>", "Text",
 CellChangeTimes->{{3.631537136434902*^9, 
  3.631537138369294*^9}},ExpressionUUID->"28632b70-29f1-4256-8c97-\
d14b2da30546"],

Cell["Tip: This means f[t] = g[t] = 0 for all t's.", "SmallText",
 CellChangeTimes->{{3.6315371467385*^9, 
  3.6315371469693403`*^9}},ExpressionUUID->"c8e45ad5-eeb4-497a-a48a-\
6626ef75eda9"],

Cell["\<\
d.ii)  Take the battle of Iwo Jima model       
        usa'[t] = -0.0544 japan[t] + f[t]
      \[NonBreakingSpace]\[NonBreakingSpace]\[NonBreakingSpace]\
\[NonBreakingSpace]  japan'[t] = -0.0106 usa[t] + g[t]
  with  usa[0] = 5.4 - r and japan[0] = 2.15  where f[t] and g[t] are the \
reinforcement rates. But go with\
\>", "Text",
 CellChangeTimes->{{3.6315371526341467`*^9, 
  3.6315371530171757`*^9}},ExpressionUUID->"b34262a2-ba55-4386-a39f-\
93bc82c0324b"],

Cell["\<\
Clear[f,t]
f[t_] := 0.5 r/; t < 2;
f[t_] := 0.6/;2 <= t <= 3;
f[t_] := 0.0/;3 < t < 5;  
f[t_] := 1.3/;5 <= t <= 6;
f[t_] :=  0.0/;6 < t;\
\>", "Input",ExpressionUUID->"5be9a198-2538-4d7f-890c-3c24658597c2"],

Cell["and:", "Text",ExpressionUUID->"f9198c5f-7d8d-4c4a-8fe0-c2bd05b3efb4"],

Cell["\<\
Clear[g,t]
g[t_] = 0;\
\>", "Input",ExpressionUUID->"6cf624ee-2bfb-47f4-93fb-b1bd4511ec1f"],

Cell["\<\
This means that you are withholding r (0 \[LessEqual] r \[LessEqual] 5.4) \
troops from the main assault force and are using them as reinforcements \
spread out over the first two days. Is there a way to set r to improve the \
outcome from the American point of view?\
\>", "Text",ExpressionUUID->"4f19c9c0-b876-4d20-b607-342ae9d2fcef"],

Cell["Tip: Try out a few r's and assess the results.", "SmallText",
 CellChangeTimes->{{3.631537161433902*^9, 
  3.6315371616407824`*^9}},ExpressionUUID->"cdd10e92-d136-4c6b-9c9e-\
02bb224de6de"],

Cell["\<\
d.iii)  Put yourself in the role of the Japanese high command or the American \
high command or both and then try out possible scenarios that come to mind.   \
        \
\>", "Text",
 CellChangeTimes->{{3.631537167641684*^9, 
  3.631537167856682*^9}},ExpressionUUID->"9d59ff18-6791-42fb-a63f-\
54129bd9f2d3"]
}, Closed]]
}, Open  ]]
}, Open  ]]
},
