Cell["Note that the solutions to ", "Text",
 CellChangeTimes->{{3.631536315635168*^9, 
  3.631536321138277*^9}},ExpressionUUID->"543a3380-a7d2-42d5-9365-\
c63ba10298f4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NSolve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"a", "*", "x"}], "-", 
       RowBox[{"\[Alpha]", "*", "y", "*", "x"}]}], "\[Equal]", "0"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "c"}], "*", "y"}], "+", 
       RowBox[{"\[Gamma]", "*", "y", "*", "x"}]}], "\[Equal]", "0"}]}], "}"}],
    ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.631536180329163*^9, 
  3.631536227999659*^9}},ExpressionUUID->"5e0b0514-921c-4ee2-ae3f-\
4e5ad2ebe504"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", "1.9999999999999996`"}], ",", 
     RowBox[{"y", "\[Rule]", "1.4999999999999998`"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x", "\[Rule]", "0.`"}], ",", 
     RowBox[{"y", "\[Rule]", "0.`"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.631536205045411*^9, 3.631536228769684*^9}, 
   3.631621523527644*^9},ExpressionUUID->"1d074f2d-3d9d-48f2-b51c-\
762b00338cc3"]
}, Open  ]],

Cell["\<\
are called critical points or equilibrium points - the populations remain \
constant.\
\>", "Text",
 CellChangeTimes->{{3.631536337562332*^9, 3.63153636812815*^9}, 
   3.725727014147307*^9},ExpressionUUID->"ae9b77f7-1b15-4677-a8a6-\
6e5347c6a747"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Your Homework", "Section",
 Evaluatable->False,
 CellChangeTimes->{{3.528050511344143*^9, 3.5280505308390923`*^9}, {
   3.528109993920311*^9, 3.52811000042187*^9}, 3.528112122089964*^9},
 AspectRatioFixed->
  True,ExpressionUUID->"a599d026-fe58-42b9-b3c7-d0db222d2e0c"],

Cell[CellGroupData[{

Cell["The drug equations", "Subsection",
 CellChangeTimes->{
  3.757204058584556*^9, {3.757204395644517*^9, 3.7572043962987347`*^9}},
 CellTags->"1.08.G4",ExpressionUUID->"c7d5e56a-dc14-48fa-b219-14e56c2fe734"],

Cell[TextData[{
 "Pharmacokineticists have determined that if a given human being has a given \
concentration of a given drug at time ",
 Cell[BoxData[
  RowBox[{"t", " ", "=", " ", "0"}]],ExpressionUUID->
  "bf9d79a8-635e-484f-9f0f-c3f7d08b4c45"],
 ", then there are always positive constants ",
 Cell[BoxData["A"],ExpressionUUID->"8ef18b3a-b6cf-4d16-84f4-69b44eede7d5"],
 " and ",
 Cell[BoxData["k"],ExpressionUUID->"c457b0cc-fd31-40f2-a9c5-d86c85887ef7"],
 " such that the amount in grams ",
 Cell[BoxData[
  RowBox[{"y", "[", "t", "]"}]],ExpressionUUID->
  "4836b0a4-8ad3-4381-8eb4-4ef97c239971"],
 " of the drug in the body fluids is governed by the differential equation\n  \
      ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"k", " ", 
      RowBox[{"y", "[", "t", "]"}]}], 
     RowBox[{"A", " ", "+", " ", 
      RowBox[{"y", "[", "t", "]"}]}]]}]}]],ExpressionUUID->
  "8f6ac79c-0ece-45a4-8637-a134e922a449"],
 "\n        with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "0", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"concentration", " ", "at", " ", "time", " ", "t"}], " ", "=", 
    " ", "0"}]}]],ExpressionUUID->"c80b1105-bfc8-4227-8f32-0437fd7525a0"],
 "."
}], "Text",ExpressionUUID->"55fe0312-6905-46b4-a229-5863d202cbc4"],

Cell["\<\
Pharmacokineticists call this model the Michaelis-Menten equation and have \
used it since 1913.\
\>", "Text",ExpressionUUID->"b71b03fc-75b4-450e-a8e0-d1aa813718ca"],

Cell["\<\
The original paper is Michaelis and Menten, \"Die Kinetik der \
Invertinwirkung,\" Biochem Z., 49(1913), 333-369.\
\>", "Special2",ExpressionUUID->"dcc3588b-6478-463c-a343-862da2f75bac"],

Cell["\<\
Before you get serious about this differential equation, there are two cases \
of big-time interest.\
\>", "Text",ExpressionUUID->"6d8f8867-f22f-4289-a11a-1e291330e929"],

Cell[CellGroupData[{

Cell["A  Cocaine and related drugs.", "Subsubsection",
 CellChangeTimes->{
  3.757204138252016*^9, {3.757204430348216*^9, 
   3.757204430700062*^9}},ExpressionUUID->"1b50a0ab-3a6c-44e3-b349-\
7d7527a42752"],

Cell[TextData[{
 "(i) For drugs like cocaine, ",
 Cell[BoxData[
  RowBox[{"y", "[", "0", "]"}]],ExpressionUUID->
  "7e843ff3-2d61-4170-a0ab-ee9acad9b285"],
 " is usually very small relative to ",
 Cell[BoxData["A"],ExpressionUUID->"2ae4bb7e-9501-429c-8998-9d77f228d13e"],
 ". In fact for cocaine, if ",
 Cell[BoxData[
  RowBox[{"y", "[", "0", "]"}]],ExpressionUUID->
  "005a5a38-5593-4818-96a6-7785be6dbbf7"],
 " is big relative to ",
 Cell[BoxData["A"],ExpressionUUID->"445c07fe-b0cc-4fcd-b684-a84d30773206"],
 ", then there is nothing to plot because a big ",
 Cell[BoxData[
  RowBox[{"y", "[", "0", "]"}]],ExpressionUUID->
  "9f62815e-7ca5-432f-bff3-0b97b5e68605"],
 " is lethal.\nHere is a sample with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "0", "]"}], " ", "=", " ", "0.0025"}]],ExpressionUUID->
  "ff3af1d6-2996-4e06-b9e8-e4751c7d8b16"],
 ", ",
 Cell[BoxData[
  RowBox[{"A", " ", "=", " ", "6"}]],ExpressionUUID->
  "0f45c0e1-fc20-4dd0-93e8-0695fdfc12ca"],
 ", and ",
 Cell[BoxData[
  RowBox[{"k", " ", "=", " ", "3"}]],ExpressionUUID->
  "6c7e62d9-c7b7-4b98-b5fa-e8ed29ef3815"],
 ":          "
}], "Text",
 CellChangeTimes->{{3.757204423220048*^9, 
  3.757204426788175*^9}},ExpressionUUID->"6c20ae60-607f-4de5-861f-\
c62d6e7d97a2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"endtime", " ", "=", " ", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"A", " ", "=", " ", "6"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"k", " ", "=", " ", "3"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"starter", " ", "=", " ", "0.0025"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"t", ",", "y", ",", "Derivative"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"solution", " ", "=", " ", "\n", " ", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"-", 
         FractionBox[
          RowBox[{"k", " ", 
           RowBox[{"y", "[", "t", "]"}]}], 
          RowBox[{"A", "+", 
           RowBox[{"y", "[", "t", "]"}]}]]}]}], ",", " ", "\n", 
       "            ", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], " ", "==", " ", "starter"}]}], "}"}], 
     ",", 
     RowBox[{"y", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "endtime"}], "}"}]}], "]"}]}], ";"}], "\n", 

 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"coke", "[", "t_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"y", "[", "t", "]"}], "/.", 
     RowBox[{"solution", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"cokeplot", " ", "=", " ", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"coke", "[", "t", "]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "endtime"}], "}"}], ",", "\n", "       ", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<t\>\"", ",", "\"\<cocaine\>\""}], "}"}]}], ",", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.757204229927593*^9, 
  3.757204253631401*^9}},ExpressionUUID->"fcf24b1c-6169-40c6-9dc9-\
97be1aa1dead"],

