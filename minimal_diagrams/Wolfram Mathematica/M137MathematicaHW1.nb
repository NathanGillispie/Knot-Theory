Cell[TextData[{
 "Holding the same constants, look at  the differential equation again: \n    \
   ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"k", " ", 
      RowBox[{"y", "[", "t", "]"}]}], 
     RowBox[{"A", " ", "+", " ", 
      RowBox[{"y", "[", "t", "]"}]}]]}]}]],ExpressionUUID->
  "c7df269a-8e5b-45e1-9626-257a952f9715"],
 ".\nBecause ",
 Cell[BoxData[
  RowBox[{"y", "[", "t", "]"}]],ExpressionUUID->
  "52d464ff-0157-4557-bf2d-88bda6b29465"],
 " is very small all the time, you can expect the solution ",
 Cell[BoxData[
  RowBox[{"y", "[", "t", "]"}]],ExpressionUUID->
  "0feaf9ea-1467-498e-94ef-a6a94c969e71"],
 " to plot out about the same as the exponential solution of\n       ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"k", " ", 
       RowBox[{"y", "[", "t", "]"}]}], 
      RowBox[{"A", " ", "+", " ", "0"}]]}], "=", " ", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["k", "A"]}], " ", 
     RowBox[{"y", "[", "t", "]"}]}]}]}]],ExpressionUUID->
  "ed87c4f1-fe3e-4cd0-891e-b02671331a46"],
 ".\nCheck this out. "
}], "Text",ExpressionUUID->"347576f5-5297-4485-894e-11d67a5d3553"],

Cell["Tip:", "Special1",ExpressionUUID->"fb70fb7b-4e78-4796-aa97-dd9144198e5c"],

Cell[TextData[{
 "In case you've forgotten, the solution of  \n        ",
 Cell[BoxData[
  RowBox[{" ", 
   RowBox[{
    RowBox[{
     RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["k", "A"]}], " ", 
     RowBox[{"y", "[", "t", "]"}]}]}]}]],ExpressionUUID->
  "b9c87761-376f-4ff8-84d3-a2e2c4aca73b"],
 " with a given ",
 Cell[BoxData[
  RowBox[{"y", "[", "0", "]"}]],ExpressionUUID->
  "5664f0d3-fd29-48fc-85d3-5b8b9988fee3"],
 "\nhas a nice, easy formula. It is:\n         ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "t", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"y", "[", "0", "]"}], " ", 
    SuperscriptBox["E", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"k", " ", "t"}], "A"]}]]}]}]],ExpressionUUID->
  "b9d10437-33e9-43b0-9b2b-a78e0909ecc2"],
 ".\nYou should know this formula cold. It's a matter of basic calculus \
literacy."
}], "SmallText",ExpressionUUID->"888ff251-179a-4a34-865a-87616acca9b3"],

Cell["", "Text",
 CellChangeTimes->{{3.7572043095458384`*^9, 
  3.757204345409555*^9}},ExpressionUUID->"45c1883e-b357-476c-b733-\
58a76da2b8ee"],

Cell[TextData[{
 "(ii)  Do a two more samples of your own choice with ",
 Cell[BoxData[
  RowBox[{"y", "[", "0", "]"}]],ExpressionUUID->
  "ef496211-6c08-4742-8c49-e8ee757d4207"],
 " small relative to ",
 Cell[BoxData["A"],ExpressionUUID->"195cb2db-df0b-4fa8-9f46-7bffe6b4f027"],
 " and then explain the statement: \nFor studying the decay of cocaine, most \
pharmacokineticists are happy to replace the basic model   \n            ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", " ", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"k", " ", 
      RowBox[{"y", "[", "t", "]"}]}], 
     RowBox[{"A", " ", "+", " ", 
      RowBox[{"y", "[", "t", "]"}]}]]}]}]],ExpressionUUID->
  "00df8da2-2a6d-4058-b966-4aa573041928"],
 "\n            with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "0", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"concentration", " ", "at", " ", "time", " ", "t"}], " ", "=", 
    " ", "0"}]}]],ExpressionUUID->"c5a5068e-7425-493f-a2ca-c3d4ec0a460e"],
 "\nby the simpler exponential model\n            ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"y", "'"}], "[", "t", "]"}], " ", "=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"k", " ", 
      RowBox[{"y", "[", "t", "]"}]}], "A"]}]}]],ExpressionUUID->
  "315e5081-915e-46b2-8a8f-e30d3526896a"],
 "\n            with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "0", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"concentration", " ", "at", " ", "time", " ", "t"}], " ", "=", 
    " ", "0"}]}]],ExpressionUUID->"46664b39-73a6-44d3-ac11-eb365f75662d"],
 "."
}], "Text",
 CellChangeTimes->{{3.757204348918985*^9, 3.757204349162937*^9}, {
  3.7572705693325777`*^9, 
  3.757270570282236*^9}},ExpressionUUID->"90a06709-87be-48c8-a0be-\
fe0fcd09c56e"],

Cell["\<\
Explain why most folks say that cocaine concentration decays exponentially.\
\>", "Text",
 CellChangeTimes->{
  3.757204379381557*^9},ExpressionUUID->"7c590547-f581-4b86-a29f-\
4aa946f2218c"]
}, Closed]],

Cell[CellGroupData[{

Cell["B Alcohol and related drugs", "Subsubsection",
 CellChangeTimes->{
  3.757204459108807*^9},ExpressionUUID->"509a3b95-1735-4c68-9a1a-\
63376b3f11e3"],

Cell[TextData[{
 "(i) For drugs like alcohol, ",
 Cell[BoxData[
  RowBox[{"y", "[", "0", "]"}]],ExpressionUUID->
  "358a15d5-601c-41d4-a71b-fb1cd8e5c63e"],
 " is usually rather large relative to ",
 Cell[BoxData["A"],ExpressionUUID->"58c7c250-fd56-41fb-87ab-e7a6f5941802"],
 ". \nHere is a sample with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"y", "[", "0", "]"}], " ", "=", " ", "0.025"}]],ExpressionUUID->
  "d5e9758a-cf30-4e86-a9fe-b9990fc21b9b"],
 ", ",
 Cell[BoxData[
  RowBox[{"A", " ", "=", " ", "0.005"}]],ExpressionUUID->
  "6bbf10a6-e230-453e-8de7-479677e5bdc0"],
 ", and ",
 Cell[BoxData[
  RowBox[{"k", " ", "=", " ", "0.01"}]],ExpressionUUID->
  "06ab54d9-9f88-4ddb-b3fa-227c2b0a6df6"],
 ":          "
}], "Text",
 CellChangeTimes->{{3.757204461805645*^9, 
  3.757204465525558*^9}},ExpressionUUID->"c12d1cd0-e867-4560-a68b-\
5115c602a722"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"endtime", " ", "=", " ", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"A", " ", "=", " ", "0.005"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"k", " ", "=", " ", "0.01"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"starter", " ", "=", " ", "0.025"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"solution", " ", "=", " ", "\n", " ", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"-", 
         FractionBox[
          RowBox[{"k", " ", 
           RowBox[{"y", "[", "t", "]"}]}], 
          RowBox[{"A", "+", 
           RowBox[{"y", "[", "t", "]"}]}]]}]}], ",", " ", "\n", 
       "            ", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], " ", "==", " ", "starter"}]}], "}"}], 
     ",", 
     RowBox[{"y", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "endtime"}], "}"}]}], "]"}]}], ";"}], "\n", 

 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"alcohol", "[", "t_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"y", "[", "t", "]"}], "/.", 
     RowBox[{"solution", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"sloshplot", " ", "=", " ", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"alcohol", "[", "t", "]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "endtime"}], "}"}], ",", "\n", "       ", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<t\>\"", ",", "\"\<alcohol\>\""}], "}"}]}], ",", "\n", 
    "       ", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.7572045018884907`*^9, 
  3.7572045254238653`*^9}},ExpressionUUID->"07270ed0-0910-4135-9d65-\
db9b185c1038"],

