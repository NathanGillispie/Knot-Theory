Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{
   "a", ",", "b", ",", "\[Alpha]", ",", "\[Gamma]", ",", "a", ",", "b"}], 
   "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "=", ".6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]", "=", ".4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "=", ".5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]", "=", ".25"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"start", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"stop", "=", "50"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"rabbitstart", ":=", "3.5"}], "\[IndentingNewLine]", 
 RowBox[{"foxstart", ":=", "4.5"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"x1", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{"a", "*", 
            RowBox[{"x1", "[", "t", "]"}]}], "-", 
           RowBox[{"\[Alpha]", "*", 
            RowBox[{"y1", "[", "t", "]"}], "*", 
            RowBox[{"x1", "[", "t", "]"}]}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"y1", "'"}], "[", "t", "]"}], "\[Equal]", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "c"}], "*", 
            RowBox[{"y1", "[", "t", "]"}]}], "+", 
           RowBox[{"\[Gamma]", "*", 
            RowBox[{"y1", "[", "t", "]"}], "*", 
            RowBox[{"x1", "[", "t", "]"}]}]}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"x1", "[", "start", "]"}], "\[Equal]", "rabbitstart"}], ",", 
         RowBox[{
          RowBox[{"y1", "[", "start", "]"}], "\[Equal]", "foxstart"}]}], 
        "}"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x1", "[", "t", "]"}], ",", 
       RowBox[{"y1", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "start", ",", "stop"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"x2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"x1", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y2", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{"y1", "[", "t", "]"}], "/.", 
    RowBox[{"sol", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"plotx", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"x2", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "start", ",", "stop"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<rabbits \>\"", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<x\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Red"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"0", ",", "10"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ploty", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"y2", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "start", ",", "stop"}], "}"}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<foxes \>\"", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<y\>\"", ",", "Italic"}], "]"}]}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Blue"}], ",", 
    RowBox[{"PlotRange", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"0", ",", "10"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"curveplot2", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x2", "[", "t", "]"}], ",", 
      RowBox[{"y2", "[", "t", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
